// Generic function to show a specific section
// Function called by other functions from within this library
function showSection(sectionName) {
    Xrm.Page.ui.tabs.get("general_tab").sections.get(sectionName).setVisible(true);
    //formContext.ui.tabs.get("general_tab").sections.get(sectionName).setVisible(true);
};

// Generic function to hide a specific section
// Function called by other functions from within this library
function hideSection(sectionName) {
    Xrm.Page.ui.tabs.get("general_tab").sections.get(sectionName).setVisible(false);
    //formContext.ui.tabs.get("general_tab").sections.get(sectionName).setVisible(false);
};