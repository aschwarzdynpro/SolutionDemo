                  "title": "strItemNumber",
                  "type": "string",
                  "x-ms-dynamically-added": true,
                  "description": "Itemnumber for creation of product category assignment.",
                  "x-ms-content-hint": "TEXT"
                },
                "text_3": {
                  "title": "strTenant",
                  "type": "string",
                  "x-ms-dynamically-added": true,
                  "description": "Tenant ID",
                  "x-ms-content-hint": "TEXT"
                },
                "text_4": {
                  "title": "strClient",
                  "type": "string",
