function setCalculationStatus(formContext) {
        const bottomUpStatus = formContext.getAttribute("hso_bottomupcalculation_status").getValue();

        // Bottom up not calculated
        if (bottomUpStatus == 864640001) {
                formContext.ui.clearFormNotification("BottomUp_Calculated_InformationNotification");
                formContext.ui.setFormNotification("Die Kosten und Preise der Kalkulationsversion sind nicht aktuell! Bitte führen sie eine manuelle Bottom-Up Berechnung aus um die Kosten und Preise entsprechend zu aktualisieren.", "WARNING", "BottomUp_NotCalculated_WarningNotification");
        }
        // Bottom up calculated
        else if (bottomUpStatus == 864640000) {
                formContext.ui.clearFormNotification("BottomUp_NotCalculated_WarningNotification");
                formContext.ui.setFormNotification("Die Kosten und Preise der Kalkulationsversion sind aktuell!", "INFO", "BottomUp_Calculated_InformationNotification");
        }
}



