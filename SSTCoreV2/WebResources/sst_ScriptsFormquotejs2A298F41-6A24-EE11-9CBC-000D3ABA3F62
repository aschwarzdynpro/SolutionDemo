Schulz.QuoteForm.hideTypespecificElements = (executionContext) => {
    const formContext = executionContext.getFormContext();
    const quoteType = formContext.getAttribute("sst_angebotstyp_opt").getValue();

    // Get configuration for the quote type
    const config = Schulz.QuoteForm.UI_CONFIGURATIONS[quoteType] || Schulz.QuoteForm.UI_CONFIGURATIONS.default;

    // Apply section visibility
    Schulz.QuoteForm.applySectionVisibility(formContext, config.sections);

    // Apply tab visibility
    Schulz.QuoteForm.applyTabVisibility(formContext, config.tabs);

    // Apply control visibility
    Schulz.QuoteForm.applyControlVisibility(formContext, config.controls);

    // Apply required levels
    Schulz.QuoteForm.applyRequiredLevels(formContext, config.requiredLevels);
};

// Helper function to apply section visibility
Schulz.QuoteForm.applySectionVisibility = (formContext, sectionsConfig) => {
    Object.entries(sectionsConfig).forEach(([tabName, sections]) => {
        const tab = formContext.ui.tabs.get(tabName);
        if (tab) {
            Object.entries(sections).forEach(([sectionName, isVisible]) => {
                const section = tab.sections.get(sectionName);
                if (section) {
                    section.setVisible(isVisible);
                }
            });
        }
    });
};

// Helper function to apply tab visibility
Schulz.QuoteForm.applyTabVisibility = (formContext, tabsConfig) => {
    Object.entries(tabsConfig).forEach(([tabName, isVisible]) => {
        const tab = formContext.ui.tabs.get(tabName);
        if (tab) {
            tab.setVisible(isVisible);
        }
    });
};

// Helper function to apply control visibility
Schulz.QuoteForm.applyControlVisibility = (formContext, controlsConfig) => {
    Object.entries(controlsConfig).forEach(([controlName, isVisible]) => {
        const control = formContext.getControl(controlName);
        if (control) {
            control.setVisible(isVisible);
        }
    });
};

// Helper function to apply required levels
Schulz.QuoteForm.applyRequiredLevels = (formContext, requiredLevelsConfig) => {
    Object.entries(requiredLevelsConfig).forEach(([attributeName, requiredLevel]) => {
        const attribute = formContext.getAttribute(attributeName);
        if (attribute) {
            attribute.setRequiredLevel(requiredLevel);
        }
    });
};

// Filter customerid lookup based on sst_hasdebitor_opt field
Schulz.QuoteForm.filterCustomerIdLookup = (executionContext) => {
    const formContext = executionContext.getFormContext();
    const hasDebitor = formContext.getAttribute("sst_hasdebitor_opt").getValue();
    const customerAttribute = formContext.getAttribute("customerid");
    const notificationId = "CustomerFilterNotification";

    if (!customerAttribute) return;

    customerAttribute.controls.forEach(control => {
        // Note: There's no direct way to remove pre-search in Dynamics 365
        // The filter will be reapplied on next pre-search event
        control.addPreSearch(() => {
            Schulz.QuoteForm.addCustomerTypeFilter(customerAttribute, null);
        });
    });
};

// Helper function to add customer type filter
Schulz.QuoteForm.addCustomerTypeFilter = (customerAttribute, customerTypeCode) => {
    if (customerTypeCode) {
        // Filter for accounts with specific customer type code
        const accountFilter = `<filter type="and"><condition attribute="customertypecode" operator="eq" value="${customerTypeCode}" /></filter>`;

        customerAttribute.controls.forEach(control => {
            control.addCustomFilter(accountFilter, "account");
            // Remove contacts from the lookup completely
            control.addCustomFilter("<filter type='and'><condition attribute='contactid' operator='null' /></filter>", "contact");
        });
    } else {
        // Allow all accounts but always exclude contacts
        const permissiveFilter = "<filter type='or'><condition attribute='accountid' operator='not-null' /><condition attribute='accountid' operator='null' /></filter>";

        customerAttribute.controls.forEach(control => {
            control.addCustomFilter(permissiveFilter, "account");
            // Always remove contacts from the lookup
            control.addCustomFilter("<filter type='and'><condition attribute='contactid' operator='null' /></filter>", "contact");
        });
    }
};

