// Re-Calculate Cost Price
// Function triggered in the Calculation Position form onChange event handler for field hso_costpriceperunit
ETO.CalculationPositionForm.onChangeCostPricePerUnit = (executionContext) => {
    console.log("onChangeCostPricePerUnit triggered...");
    // get the form context
    var formContext = executionContext.getFormContext();
    // get the Cost Price per unit
    let CalculatedCostPricePerUnit = formContext.getAttribute("hso_costpriceperunit").getValue()
    // get the Element Type
    let ElementType = formContext.getAttribute("hso_positionelementtype").getValue();
    // get the Position Quantity
    let Quantity = formContext.getAttribute("hso_positionquantity").getValue();
    if (ElementType == 100000000 || ElementType == 100000002) {
        // get Metallabels
        let SelectedProduct_MetalLabel = formContext.getAttribute("hso_product_metallabelid").getValue();
        let SelectedProduct_MetalLabel2 = formContext.getAttribute("hso_product_metallabelid_2").getValue();
        let SelectedProduct_MetalLabel3 = formContext.getAttribute("hso_product_metallabelid_3").getValue();
        // if without Metallabels
        if (SelectedProduct_MetalLabel == null && SelectedProduct_MetalLabel2 == null && SelectedProduct_MetalLabel3 == null) {
            ETO.CalculationPositionForm.calculateCostPrice(formContext, Quantity, "onChangeCostPricePerUnit");
        } else { // if with Metallabels
            if (SelectedProduct_MetalLabel != null) { product_metalsurchargeperunit = formContext.getAttribute("hso_product_metalsurchargeperunit").getValue(); } else { product_metalsurchargeperunit = 0 };
            if (SelectedProduct_MetalLabel2 != null) { product_metalsurchargeperunit_2 = formContext.getAttribute("hso_product_metalsurchargeperunit_2").getValue(); } else { product_metalsurchargeperunit_2 = 0 };
            if (SelectedProduct_MetalLabel3 != null) { product_metalsurchargeperunit_3 = formContext.getAttribute("hso_product_metalsurchargeperunit_3").getValue(); } else { product_metalsurchargeperunit_3 = 0 };
            let SelectedProduct_BasePriceWithoutMetalSurcharge = CalculatedCostPricePerUnit - (product_metalsurchargeperunit + product_metalsurchargeperunit_2 + product_metalsurchargeperunit_3);
            formContext.getAttribute("hso_product_basepricewithoutmetalsurcharge").setValue(SelectedProduct_BasePriceWithoutMetalSurcharge);
            ETO.CalculationPositionForm.calculateCostPrice(formContext, Quantity, "onChangeCostPricePerUnit");
        };
    } else { // Another Element Types
        ETO.CalculationPositionForm.calculateCostPrice(formContext, Quantity, "onChangeCostPricePerUnit");
    };
};

