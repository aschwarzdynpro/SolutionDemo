        "Update_Calculation_Position_Processing_Status": {
          "type": "Scope",
          "description": "After creating new Calculation Positions the Processing Status must be updated to ensure that the Plug-In to eventually update the Parents Processing Status is executed. An additional Dataverse Update is necessary because of BypassCustomPlugInExecution.",
          "actions": {
            "Select_Payload_for_Update": {
              "type": "Select",
              "inputs": {
                "from": "@body('Parse_JSON')",
                "select": {
                  "@{string('@odata.type')}": "@item()?['@odata.type']",
                  "hso_calculationdetailid": "@item()?['hso_calculationdetailid']",
                  "hso_processingstatus": "@false"
                }
              }
            },
            "Calculate_Parallelism_for_Update": {
              "type": "Compose",
              "inputs": "@min(\r\n  max(\r\n    div(\r\n      length(body('Select_Payload_for_Update')),\r\n      variables('varBatchSettings')?['maxBatchSize']\r\n    ),\r\n    variables('varBatchSettings')?['minBatchSize']\r\n  ),\r\n  variables('varBatchSettings')?['maxParallelism']\r\n)",
              "runAfter": {
                "Append_update_Calculation_Positions_to_Log": [
                  "Succeeded"
                ]
              }
            },
            "Calculate_Batch_Size_for_Update": {
              "type": "Compose",
              "inputs": "@add(\r\n  div(\r\n    length(body('Select_Payload_for_Update')), \r\n    outputs('Calculate_Parallelism_for_Update')\r\n  ), \r\n  if(\r\n    greaterOrEquals(\r\n      mod(\r\n        length(body('Select_Payload_for_Update')),\r\n        outputs('Calculate_Parallelism_for_Update')\r\n      ),\r\n      1\r\n    ), \r\n    1, \r\n    0\r\n  )\r\n)\r\n",
              "runAfter": {
                "Calculate_Parallelism_for_Update": [
                  "Succeeded"
                ]
              }
            },
            "Split_Records_into_Chunks_for_Update": {
              "type": "Compose",
              "inputs": "@chunk(\r\n  body('Select_Payload_for_Update'),\r\n  outputs('Calculate_Batch_Size_for_Update')\r\n)",
              "runAfter": {
                "Calculate_Batch_Size_for_Update": [
                  "Succeeded"
                ]
              }
            },
            "Process_Updates_for_each_Chunk": {
              "type": "Foreach",
              "foreach": "@outputs('Split_Records_into_Chunks_for_Update')",
              "actions": {
                "Items_to_update": {
                  "type": "Compose",
                  "inputs": "@items('Process_Updates_for_each_Chunk')"
                },
                "Update_Calculation_Positions": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "parameters": {
                      "request/method": "POST",
                      "request/url": "https://@{parameters('EnvVar | Dataverse Instance (hso_EnvVarDataverseInstance)')}/api/data/v9.2/hso_calculationdetails/Microsoft.Dynamics.CRM.UpdateMultiple",
                      "request/headers": {
                        "OData-MaxVersion": "4.0",
                        "OData-Version": "4.0",
                        "If-None-Match": "null",
                        "Accept": "application/json",
                        "Content-Type": "application/json; charset=utf-8"
                      },
                      "request/body": "{\n \"Targets\": @{items('Process_Updates_for_each_Chunk')}\n}"
                    },
                    "host": {
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_webcontents",
                      "operationId": "InvokeHttp",
                      "connectionName": "shared_webcontents"
                    }
                  },
                  "runAfter": {
                    "Items_to_update": [
                      "Succeeded"
                    ]
                  }
                }
              },
              "runAfter": {
                "Split_Records_into_Chunks_for_Update": [
                  "Succeeded"
                ]
              },
              "runtimeConfiguration": {
                "concurrency": {
                  "repetitions": 20
                }
              }
            },
            "Append_update_Calculation_Positions_to_Log": {
              "type": "AppendToStringVariable",
              "inputs": {
                "name": "varLog",
                "value": "[INF] - [@{utcNow()}] - Update Processing Status for @{length(body('Select_Payload_for_Update'))} new Calculation Positions to check Parents Processing Status. @{decodeUriComponent('%0A')}"
              },
              "runAfter": {
                "Select_Payload_for_Update": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "43abaca5-e993-4bd4-b6df-850a27ea537d"
              }
            },
            "Append_updated_Calculation_Positions_to_Log": {
              "type": "AppendToStringVariable",
              "inputs": {
                "name": "varLog",
                "value": "[INF] - [@{utcNow()}] - Processing Status for @{length(body('Select_Payload_for_Update'))} Calculation Positions updated. @{decodeUriComponent('%0A')}"
              },
              "runAfter": {
                "Process_Updates_for_each_Chunk": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "43abaca5-e993-4bd4-b6df-850a27ea537d"
              }
            }
          },
          "runAfter": {
            "Respond_to_App": [
              "Succeeded",
              "TimedOut",
              "Failed"
            ]
          }
        }
      }
    },
