            ]
          },
          "metadata": {
            "operationMetadataId": "2260efe3-f8d5-45b1-94f1-fd69bd208108"
          },
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "varBudgetRevisionID",
                "type": "string",
                "value": "@replace(body('Parse_JSON')?['SerializedWorkflowDocumentData']?[8],'RevisionId:','')"
              }
            ]
          }
        },
        "Initialize_varSubmitter": {
          "runAfter": {
            "Initialize_BudgetRevisionID": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "0ccfbe8f-8f03-4953-bd5a-2936fa6686fe"
          },
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "varSubmitter",
                "type": "string",
                "value": "@body('Parse_JSON')?['WorkflowLastActionUser']"
              }
            ]
          }
        },
        "Initialize_varFODeepLink": {
          "runAfter": {
            "Initialize_varSubmitter": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "7202ba91-9f08-4d49-8a72-f11cc92dee70"
          },
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "varFODeepLink",
                "type": "string",
                "value": "@body('Parse_JSON')?['LinkToWeb']"
              }
            ]
          }
        },
        "Initialize_varApprovaldateTime": {
          "runAfter": {
            "Parse_JSON": [
