if (typeof (ETO) === "undefined") { ETO = {}; };
if (typeof (ETO.WorkOrderForm) === "undefined") { ETO.WorkOrderForm = {}; }

ETO.WorkOrderForm.onLoad = (executionContext) => {
    let formContext = executionContext.getFormContext();
    //ETO.WorkOrderForm.registerEvents(formContext);

    if (formContext.ui.getFormType() > 2) // Skip if form is not create or update
        return;

    if (formContext.getAttribute("msdyn_systemstatus").getValue() >= 690970003)
    {
        ETO.Common.disableAllFields(formContext);
        formContext.getControl("msdyn_systemstatus").setDisabled(false);
        formContext.getControl("hso_targetworkorder_id").setDisabled(false);
        formContext.getControl("workorderproductsgrid").setDisabled(false);
        formContext.ui.setFormNotification("The work order has been completed. Changes are no longer possible.", "INFO", "wo_readonly");
        return;
    }

    ETO.WorkOrderForm.setWorkorderDefaults(executionContext);

    const currentForm = formContext.ui.formSelector.getCurrentItem();

    if (currentForm.getId() === "adada18b-44a1-ed11-aad1-0022489de585") // Work Order Main Form
    {
        ETO.WorkOrderForm.checkParentWorkOrder(executionContext);
        ETO.WorkOrderForm.prefilterTargetWorkOrder(executionContext);
    }
    
    formContext.getAttribute("msdyn_billingaccount").addOnChange(ETO.WorkOrderForm.loadPaymentTerms);
    formContext.getAttribute("msdyn_parentworkorder").addOnChange(ETO.WorkOrderForm.checkParentWorkOrder);
};


ETO.WorkOrderForm.onQuickCreateLoad = (executionContext) => {
    let formContext = executionContext.getFormContext();

    ETO.WorkOrderForm.setWorkorderDefaults(executionContext);

    formContext.getAttribute("msdyn_billingaccount").addOnChange(ETO.WorkOrderForm.loadPaymentTerms);
};
