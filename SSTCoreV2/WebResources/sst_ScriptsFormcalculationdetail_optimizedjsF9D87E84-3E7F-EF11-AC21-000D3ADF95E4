    let ElementType = formContext.getAttribute('hso_positionelementtype').getValue();
    let CalculationType = formContext.getAttribute('hso_calculationtype').getValue();
    let ProjectType = formContext.getAttribute('hso_projecttype').getValue();
    let PositionLevel = formContext.getAttribute('hso_level').getValue();
    // Get Option Set Values for Calculation Type
    let CalculationTypeOptions = formContext.getControl("hso_calculationtype").getOptions();
    if (CalculationType != 100000002) {
        // switch between Project Types to set available Option Set Values
        switch (ProjectType) {
