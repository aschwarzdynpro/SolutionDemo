// Function triggered in the Calculation Position form onChange event handler for field hso_isbillofmaterials
Schulz.ProjectProductForm.setFieldVisibility_MainForm = (formContext) => {
        // get the ProjectProduct Type
        let BOMProjectProduct = formContext.getAttribute('hso_isbillofmaterials').getValue();
        //Filter Product
        formContext.getControl("hso_productid").addPreSearch(filterProduct);

        if (formContext.getAttribute("hso_templateid").getValue() == null && formContext.getAttribute("hso_calculationid").getValue() == null) {
                showField(formContext, 'hso_templateid');
                showField(formContext, 'header_hso_templateid');
                showField(formContext, 'hso_calculationid');
                showField(formContext, 'header_hso_calculationid');
                recommendedField(formContext, 'hso_templateid');
                recommendedField(formContext, 'hso_calculationid');
        } else if (formContext.getAttribute("hso_templateid").getValue() != null) {
                showField(formContext, 'hso_templateid');
                showField(formContext, 'header_hso_templateid');
                requiredField(formContext, 'hso_templateid');
                hideField(formContext, 'hso_calculationid');
                hideField(formContext, 'header_hso_calculationid');
                noneField(formContext, 'hso_calculationid');
        } else {
                showField(formContext, 'hso_calculationid');
                showField(formContext, 'header_hso_calculationid');
                requiredField(formContext, 'hso_calculationid');
                hideField(formContext, 'hso_templateid');
                hideField(formContext, 'header_hso_templateid');
                noneField(formContext, 'hso_templateid');
        };
        if (BOMProjectProduct == true) {
                // Position Project Type - BOM
                noneField(formContext, 'hso_surchargegroup_baseid');
                noneField(formContext, 'hso_costprice');
                hideField(formContext, 'hso_costprice');
                hideField(formContext, 'hso_surchargegroup_baseid');
                hideField(formContext, 'hso_salesprice');
                hideSection('suppliercatalogue_section');
                showSection('billofmaterials_section');
                requiredField(formContext, 'hso_projecttype');
                formContext.ui.tabs.get("metallabel_tab").setVisible(false);
                formContext.ui.tabs.get("calculation_details_tab").setVisible(true);
        } else {
                // Position Project Type - Not BOM
                requiredField(formContext, 'hso_surchargegroup_baseid');
                requiredField(formContext, 'hso_costprice');
                showField(formContext, 'hso_costprice');
                showSection('suppliercatalogue_section');
                showField(formContext, 'hso_surchargegroup_baseid');
                showField(formContext, 'hso_salesprice');
                hideSection('billofmaterials_section');
                noneField(formContext, 'hso_projecttype');
                formContext.ui.tabs.get("metallabel_tab").setVisible(true);
                formContext.ui.tabs.get("calculation_details_tab").setVisible(false);
        };
};

