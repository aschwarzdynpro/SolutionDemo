if (typeof (ETO) === "undefined") { ETO = {}; };
if (typeof (ETO.AccountRibbon) === "undefined") { ETO.AccountRibbon = {}; }

ETO.AccountRibbon.erpRelevantFields = [
    "name",
    "address1_line1",
    "address1_line2",
    "address1_postalcode",
    "address1_city",
    "hso_address1country_ref",
    "hso_companyregistrationnumber_txt",
    "hso_taxid_txt"
];

ETO.AccountRibbon.unlockErpRelevantFields = (formContext) => {
    ETO.AccountRibbon.erpRelevantFields.forEach(field => {
        let attribute = formContext.getAttribute(field);

        ETO.AccountRibbon.controlDisabled(attribute, false);
    });

    Xrm.Navigation.openAlertDialog({ text: "You can now edit all ERP-relevant fields." });
};

ETO.AccountRibbon.controlDisabled = (attribute, disabled) => {
    attribute?.controls.forEach(control => {
        control.setDisabled(disabled);
    });
};

ETO.AccountRibbon.sendCustomerDataRequestTriggered = false;

ETO.AccountRibbon.sendCustomerDataRequest = async (formContext) => {
    if (!ETO.AccountRibbon.sendCustomerDataRequestTriggered) {
        ETO.AccountRibbon.sendCustomerDataRequestTriggered = true;

        let saveResult = await formContext.data.save().then((result) => {
            return result;
        }, error => {
            console.log(error);
        });

        if (!saveResult) {
            ETO.AccountRibbon.sendCustomerDataRequestTriggered = false;
            return;
        }

        let email = formContext.getAttribute("emailaddress1")?.getValue();

        if (!email) {
            await Xrm.Navigation.openAlertDialog({
                text: "The field: E-mail is empty or contains an invalid value. Please enter a valid recipient address."
            });

            ETO.AccountRibbon.sendCustomerDataRequestTriggered = false;
            return;
        }

        confirmResult = await Xrm.Navigation.openConfirmDialog({
            text: `Are you sure that you want to sent a customer data request to ${email}?`
        });

        if(!confirmResult?.confirmed){
            ETO.AccountRibbon.sendCustomerDataRequestTriggered = false;
            return;    
        }

        Xrm.Utility.showProgressIndicator("Sending...");

        var accountId = formContext.data.entity.getId().replace("{", "").replace("}", "")
        let updateResult = await Xrm.WebApi.updateRecord("account", accountId, {
            hso_triggercustomerdatarequest_dat: new Date().toISOString()
        });

        if (updateResult) {
            await Xrm.Navigation.openAlertDialog({
                text: "The customer data request was sent successfully!"
            });
        } else {
            await Xrm.Navigation.openErrorDialog({
                message: "Error sending the customer data request. Please contact your administrator."
            });
        }

        Xrm.Utility.closeProgressIndicator();
        ETO.AccountRibbon.sendCustomerDataRequestTriggered = false;
    }
};