    } else {
        noneField(formContext, 'hso_productid');
        noneField(formContext, 'hso_projectproductid');
        noneField(formContext, 'hso_projectexpenseid');
        noneField(formContext, 'hso_productionhourid');
        noneField(formContext, 'hso_externalserviceid');
        noneField(formContext, 'hso_projecthourid');
    };
    if (formType_OnChangeElementType == "IsMainForm") {
        clearFieldOption(formContext, 'hso_processingstatus');
        if (ElementType == 100000006) {
            alert("Änderung auf 'Titel' löscht alle preisrelevanten Informationen!");
        } else {
            alert("Änderung auf anderen Element Typ löscht auswahlspezifische Informationen!");
        };
    };
};

