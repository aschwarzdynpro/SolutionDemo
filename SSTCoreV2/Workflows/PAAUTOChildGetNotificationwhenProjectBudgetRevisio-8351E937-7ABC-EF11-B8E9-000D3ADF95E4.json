            },
            "authentication": {
              "type": "Raw",
              "value": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$ConnectionKey']"
            }
          }
        },
        "Get_business_unit_ID": {
          "runAfter": {
            "Get_project_ID": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "8f70d2c6-af17-4ed7-ab70-c9e7fab23a4b"
          },
          "type": "OpenApiConnection",
          "inputs": {
            "host": {
              "connectionName": "shared_commondataserviceforapps_1",
              "operationId": "ListRecords",
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
            },
            "parameters": {
              "entityName": "businessunits",
              "$select": "businessunitid,name",
              "$filter": "name eq '@{body('Parse_JSON')?['BusinessEventLegalEntity']}'"
            },
            "authentication": {
              "type": "Raw",
              "value": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$ConnectionKey']"
            }
          }
        },
        "Project_budget_revision_data": {
          "runAfter": {
            "Get_business_unit_ID": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "3bea558c-5cb5-410f-9ff3-8055ece73c03"
          },
          "type": "Compose",
          "inputs": {
            "Überarbeitungskennung": "@variables('varBudgetRevisionID')",
            "Überarbeitungsstatus": "@body('Parse_JSON')?['OutcomeName']",
            "Kommentar": "@body('Parse_JSON')?['WorkflowComment']",
            "Projekt": "@first(outputs('Get_project_ID')?['body/value'])?['msdyn_projectid']",
            "Anforderungsdatum": "@variables('varApprovalDateTime')",
            "Projektkennung": "@first(outputs('Get_project_ID')?['body/value'])?['sst_projectnumber']",
            "Unternehmenseinheit": "@first(outputs('Get_business_unit_ID')?['body/value'])?['businessunitid']",
            "Prüfer": "@variables('varApproverName')",
            "Besitzer der Budgetüberarbeitung": "@variables('varSubmitter')",
            "Überarbeitung Link": "@variables('varFODeepLink')"
          }
        },
        "Parse_JSON_budget_revision_data": {
          "runAfter": {
            "Project_budget_revision_data": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "271c9d93-6ae5-4c7f-a8ab-58df988fa6b1"
          },
          "type": "ParseJson",
          "inputs": {
            "content": "@outputs('Project_budget_revision_data')",
            "schema": {
              "type": "object",
              "properties": {
                "Überarbeitungskennung": {
                  "type": "string"
                },
                "Überarbeitungsstatus": {
                  "type": "string"
                },
                "Kommentar": {
                  "type": "string"
                },
                "Projekt": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "Anforderungsdatum": {
                  "type": "string"
                },
                "Projektkennung": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "Unternehmenseinheit": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "Prüfer": {
                  "type": "string"
                },
                "Besitzer der Budgetüberarbeitung": {
                  "type": "string"
                },
                "Überarbeitung Link": {
                  "type": "string"
                }
              }
            }
          }
        },
        "Get_rejected_Project_Budget_Revision": {
          "runAfter": {
