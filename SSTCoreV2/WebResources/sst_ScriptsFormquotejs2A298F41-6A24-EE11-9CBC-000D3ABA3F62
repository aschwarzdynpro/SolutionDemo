Schulz.QuoteForm.requiredFieldsCheck = (executionContext) => {
    var formContext = executionContext.getFormContext();
    // Only on update form (not on create) and for project quote
    if (formContext.ui.getFormType() === 2 && formContext.getAttribute("sst_angebotstyp_opt").getValue() === Schulz.QuoteForm.QUOTE_TYPES.PROJEKT) {
        var warehouseLookupValue = formContext.getAttribute("msdyn_defaultshippingwarehouse").getValue();
        var operationalSiteLookupValue = formContext.getAttribute("msdyn_defaultshippingsite").getValue();
        var requiredFieldsMissingNotification = "requiredFieldsMissingNotification";

        if (warehouseLookupValue == null || warehouseLookupValue[0] == null || operationalSiteLookupValue == null || operationalSiteLookupValue[0] == null) {
            formContext.ui.setFormNotification("Lagerort und Standort müssen zwingend angegeben werden, bevor die Angebotskalkulation zum Projekt gewandelt wird!", "ERROR", requiredFieldsMissingNotification);
        }
        else
            formContext.ui.clearFormNotification(requiredFieldsMissingNotification);
    }
};

Schulz.QuoteForm.notifyUserIfQuoteIsActiveAndWriteInProductsExist = (executionContext) => {
    var formContext = executionContext.getFormContext();
    var notificationIDWriteInProductWarning = "write-in-product-warning";
    var stateCodeValue = formContext.getAttribute("statecode").getValue();
    var quoteTypeValue = formContext.getAttribute("sst_angebotstyp_opt").getValue();
    var writeInProductsExistValue = formContext.getAttribute("sst_containswriteinproduct").getValue();

    if (stateCodeValue === Schulz.QuoteForm.STATE_CODES.ACTIVE && quoteTypeValue === Schulz.QuoteForm.QUOTE_TYPES.ARTIKEL && writeInProductsExistValue === true)
        formContext.ui.setFormNotification("Es befinden sich noch Write-In Produkte in diesem Angebot. Bitte ersetzen Sie diese zunächst, bevor Sie den Auftrag erstellen können.", "WARNING", notificationIDWriteInProductWarning);
};

Schulz.QuoteForm.setStatusForActiveCalculation = (executionContext) => {
    var formContext = executionContext.getFormContext();
    if (formContext.getAttribute("hso_activecalculation_id").getValue() !== null)
        formContext.getAttribute("statuscode").setValue(867520002);
};

Schulz.QuoteForm.setTypeReadOnly = (executionContext) => {
    var formContext = executionContext.getFormContext();
    if (formContext.getAttribute("sst_angebotstyp_opt").getValue() != null)
        formContext.getControl("sst_angebotstyp_opt").setDisabled(true);
};

Schulz.QuoteForm.setPrintTypeToQuoteIfQuoteIsActive = (executionContext) => {
    var formContext = executionContext.getFormContext();
    var stateCodeValue = formContext.getAttribute("statecode").getValue();
    var printTypeValue = formContext.getAttribute("hso_printtype_opt").getValue();
    var quoteTypeValue = formContext.getAttribute("sst_angebotstyp_opt").getValue();

    if (stateCodeValue === Schulz.QuoteForm.STATE_CODES.ACTIVE && quoteTypeValue === Schulz.QuoteForm.QUOTE_TYPES.ARTIKEL)
        formContext.getAttribute("hso_printtype_opt").setValue(100000001);
};

Schulz.QuoteForm.printPreviewLogicArticelsales = (executionContext) => {
    const formContext = executionContext.getFormContext();
    const stateCode = formContext.getAttribute("statecode").getValue();
    const quoteType = formContext.getAttribute("sst_angebotstyp_opt").getValue();

    // Only process for article quotes (Artikelangebot)
    if (quoteType === Schulz.QuoteForm.QUOTE_TYPES.ARTIKEL) {
        const previewPrintValue = stateCode === Schulz.QuoteForm.STATE_CODES.DRAFT;
        formContext.getAttribute("sst_previewprint_opt").setValue(previewPrintValue);
    }
};

