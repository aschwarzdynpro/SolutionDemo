                    "value": "@items('Apply_to_each_Error_Summary_[Process_Payload]')"
                  }
                }
              },
              "runAfter": {
                "Select_Error_Summary_[Process_Payload]": [
                  "Succeeded"
                ]
              }
            },
            "Set_varIsError_when_processing_Payload_failed": {
              "type": "SetVariable",
              "inputs": {
                "name": "varIsError",
                "value": true
              }
            },
            "Append_Process_Payload_Error_to_Log": {
              "type": "AppendToStringVariable",
              "inputs": {
                "name": "varLog",
                "value": "[ERR] - [@{utcNow()}] - Error when creating Calculation Positions. @{decodeUriComponent('%0A')}"
              },
              "runAfter": {
                "Set_varIsError_when_processing_Payload_failed": [
                  "Succeeded"
                ]
              }
            },
            "Respond_to_App_[Error]": {
              "type": "Response",
              "kind": "PowerApp",
              "inputs": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "title": "Result",
                      "x-ms-dynamically-added": true,
                      "type": "string"
                    },
                    "errormessage": {
                      "title": "ErrorMessage",
                      "x-ms-dynamically-added": true,
                      "type": "string"
                    }
                  },
                  "additionalProperties": {}
                },
                "statusCode": 200,
                "body": {
                  "result": "Error",
                  "errormessage": "Error when creating Calculation Positions. "
                }
              },
              "runAfter": {
                "Apply_to_each_Error_Summary_[Process_Payload]": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "ce5af8a3-e40c-436f-9b1f-0bb7687963c6"
              }
            }
          },
          "runAfter": {
            "Process_Payload": [
              "TimedOut",
              "Failed"
            ]
          }
        },
        "Call_Custom_API": {
          "type": "Scope",
          "actions": {
            "Switch_on_Operation_Type": {
              "type": "Switch",
              "expression": "@triggerBody()?['text_1']",
              "default": {
                "actions": {}
              },
              "cases": {
