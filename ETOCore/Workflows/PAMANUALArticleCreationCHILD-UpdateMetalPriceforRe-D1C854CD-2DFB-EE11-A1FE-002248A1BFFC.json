                  "metadata": {
                    "operationMetadataId": "1e4808a7-40c6-4ba8-9020-83417a66b7d0"
                  },
                  "type": "SetVariable",
                  "inputs": {
                    "name": "strResponseMsg",
                    "value": "Prices updated."
                  }
                }
              },
              "runAfter": {
                "List_CDS_Released_Products_[crosscompany]": [
                  "Succeeded"
                ]
              },
              "else": {
                "actions": {
                  "Set_strResponseMsg_not_found": {
                    "runAfter": {},
                    "metadata": {
                      "operationMetadataId": "1e4808a7-40c6-4ba8-9020-83417a66b7d0"
                    },
                    "type": "SetVariable",
                    "inputs": {
                      "name": "strResponseMsg",
                      "value": "No product found."
                    }
                  }
                }
              },
              "expression": {
                "greater": [
                  "@length(body('List_CDS_Released_Products_[crosscompany]')?['value'])",
                  0
                ]
              },
              "metadata": {
                "operationMetadataId": "832dd361-d97a-4929-a264-712088659268"
              },
              "type": "If"
            }
          },
          "runAfter": {
            "Init_strStatus": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "49ff1c3f-90fc-4c18-b01c-39972dbb9acc"
          },
          "type": "Scope"
        },
