        "Add_BOM_Project_Products": {
          "type": "Scope",
          "actions": {
            "List_Templates_with_Production_Hours": {
              "type": "OpenApiConnection",
              "description": "Templates with Production Hours but no BOM Project Product",
              "inputs": {
                "parameters": {
                  "entityName": "hso_templates",
                  "fetchXml": "<fetch distinct=\"true\">\n  <entity name=\"hso_template\">\n    <attribute name=\"hso_name\" alias=\"TemplateName\" />\n    <attribute name=\"hso_templatetype\" alias=\"TemplateType\" />\n    <attribute name=\"hso_templateid\" />\n    <filter>\n      <condition attribute=\"hso_templatetype\" operator=\"eq\" value=\"100000001\" />\n    </filter>\n    <link-entity name=\"hso_templatedetail\" from=\"hso_templateid\" to=\"hso_templateid\" link-type=\"inner\" alias=\"TemplateDetails\">\n      <filter>\n        <condition attribute=\"hso_positionelementtype\" operator=\"eq\" value=\"100000003\" />\n        <condition attribute=\"hso_isbillofmaterial\" operator=\"eq\" value=\"1\" />\n        <condition attribute=\"hso_billofmaterial_projectproductid\" operator=\"null\" value=\"\" />\n      </filter>\n    </link-entity>\n  </entity>\n</fetch>"
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                  "operationId": "ListRecords",
                  "connectionName": "shared_commondataserviceforapps_1"
                }
              },
              "metadata": {
                "operationMetadataId": "614c3e7a-5bad-4e08-b679-243531880b2c"
              }
            },
            "Select_Template_BOM_Project_Product": {
              "type": "Select",
              "inputs": {
                "from": "@outputs('List_Templates_with_Production_Hours')?['body/value']",
                "select": {
                  "@{variables('varOdataType')}": "#Microsoft.Dynamics.CRM.hso_projectproduct",
                  "hso_name": "@item()?['TemplateName']",
                  "hso_uomid@odata.bind": "/uoms(msdyn_symbol='Stück')",
                  "hso_templateid@odata.bind": "/hso_templates(@{item()?['hso_templateid']})",
                  "hso_projecttype": 100000002,
                  "hso_isbillofmaterials": "true"
                }
              },
              "runAfter": {
                "List_Templates_with_Production_Hours": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "b8f737ba-d652-4db9-b8ed-b34984eb4450"
              }
            },
            "Create_Template_BOM_Project_Products": {
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "request/method": "POST",
                  "request/url": "https://@{parameters('EnvVar | Dataverse Instance (hso_EnvVarDataverseInstance)')}/api/data/v9.2/hso_projectproducts/Microsoft.Dynamics.CRM.CreateMultiple",
                  "request/headers": {
                    "OData-MaxVersion": "4.0",
                    "OData-Version": "4.0",
                    "If-None-Match": "null",
                    "Accept": "application/json",
                    "Content-Type": "application/json; charset=utf-8",
                    "MSCRM.BypassCustomPluginExecution": "true",
                    "MSCRM.BypassBusinessLogicExecution": "CustomSync"
                  },
                  "request/body": "{\n \"Targets\": @{body('Select_Template_BOM_Project_Product')}\n}"
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_webcontents",
                  "operationId": "InvokeHttp",
                  "connectionName": "shared_webcontents"
                }
              },
              "runAfter": {
                "Select_Template_BOM_Project_Product": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "e9c99fc5-0fc0-4b36-acef-9fe5793039ff"
              }
            }
          },
          "runAfter": {
            "Initialize_varOdataType": [
              "Succeeded"
            ]
          }
        },
        "Assign_BOM_Project_Product_to_Template_Positions": {
          "type": "Scope",
          "actions": {
            "List_Production_Hour_Template_Positions_with_missing_BOM_Project_Product_": {
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "entityName": "hso_templates",
                  "fetchXml": "<fetch>\n  <entity name=\"hso_template\">\n    <attribute name=\"hso_name\" alias=\"TemplateName\" />\n    <attribute name=\"hso_templatetype\" alias=\"TemplateType\" />\n    <attribute name=\"hso_templateid\" />\n    <filter>\n      <condition attribute=\"hso_templatetype\" operator=\"eq\" value=\"100000001\" />\n    </filter>\n    <link-entity name=\"hso_templatedetail\" from=\"hso_templateid\" to=\"hso_templateid\" link-type=\"inner\" alias=\"TemplateDetails\">\n      <attribute name=\"hso_billofmaterial_projectproductid\" alias=\"BOMProjectProductID\" />\n      <attribute name=\"hso_displayname\" alias=\"TemplateDetailName\" />\n      <attribute name=\"hso_positionelementtype\" alias=\"TemplateDetailElementType\" />\n      <attribute name=\"hso_productionhourid\" alias=\"TemplateDetailProductionHourID\" />\n      <attribute name=\"hso_templatedetailid\" alias=\"TemplateDetailID\" />\n      <filter>\n        <condition attribute=\"hso_positionelementtype\" operator=\"eq\" value=\"100000003\" />\n        <condition attribute=\"hso_isbillofmaterial\" operator=\"eq\" value=\"1\" />\n        <condition attribute=\"hso_billofmaterial_projectproductid\" operator=\"null\" value=\"\" />\n      </filter>\n    </link-entity>\n    <link-entity name=\"hso_projectproduct\" from=\"hso_templateid\" to=\"hso_templateid\" alias=\"ProjectProducts\">\n      <attribute name=\"hso_projectproductid\" alias=\"TemplateBOMProjectProductID\" />\n      <filter>\n        <condition attribute=\"hso_isbillofmaterials\" operator=\"eq\" value=\"1\" />\n      </filter>\n    </link-entity>\n  </entity>\n</fetch>"
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                  "operationId": "ListRecords",
                  "connectionName": "shared_commondataserviceforapps_1"
                }
              }
            },
            "Select_Template_Position_BOM_Project_Product": {
              "type": "Select",
              "inputs": {
                "from": "@outputs('List_Production_Hour_Template_Positions_with_missing_BOM_Project_Product_')?['body/value']",
                "select": {
                  "@{variables('varOdataType')}": "#Microsoft.Dynamics.CRM.hso_templatedetail",
                  "hso_templatedetailid": "@item()?['TemplateDetailID']",
                  "hso_billofmaterial_projectproductid@odata.bind": "/hso_projectproducts(@{item()?['TemplateBOMProjectProductID']})"
                }
              },
              "runAfter": {
                "List_Production_Hour_Template_Positions_with_missing_BOM_Project_Product_": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "b8f737ba-d652-4db9-b8ed-b34984eb4450"
              }
