if (typeof (Schulz) === "undefined") { Schulz = {}; };
if (typeof (Schulz.OrderForm) === "undefined") { Schulz.OrderForm = {}; }

Schulz.OrderForm.onLoad = (executionContext) => {
    let formContext = executionContext.getFormContext();
    Schulz.OrderForm.debitorCheck(executionContext);
    Schulz.OrderForm.filterTextblocks(executionContext);
    Schulz.OrderForm.fillERPRoleFields(executionContext);
    Schulz.OrderForm.registerEvents(formContext);
    Schulz.OrderForm.checkPositionsMandatoryFields(formContext);

    Schulz.OrderForm.isOrderReleased(executionContext);

    if (formContext.ui.getFormType() === 1) {
        Schulz.OrderForm.getAddressFromCustomer(executionContext);
    }
};

Schulz.OrderForm.isOrderReleased = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let orderReleasedValue = formContext.getAttribute("sst_orderreleased_bol").getValue();
    let releaseMessageId = "releaseMessageID";

    if (!orderReleasedValue) {
        formContext.ui.setFormNotification("Auftrag zur Bestellung noch nicht freigegeben. Zum Freigeben bitte auf 'Auftrag freigeben' klicken.", "INFO", releaseMessageId);
    }
};

Schulz.OrderForm.getAddressFromCustomer = (executionContext) => {
    let formContext = executionContext.getFormContext();

    if (formContext.ui.getFormType() === 1 && formContext.getAttribute("sst_address_delivery_ref").getValue() !== null) // New record and delivery address already set
        return;

    let customer = formContext.getAttribute("customerid").getValue();
    if (!customer)
        return;

    let customerId = customer[0].id;
    let customerType = customer[0].entityType;

    Xrm.WebApi.retrieveRecord(customerType, customerId, "?$select=sst_adresse1_locationid")
        .then(result => {

            if (result["sst_adresse1_locationid"] == null) // No address available
                return;

            let addressId = result["sst_adresse1_locationid"];
            Xrm.WebApi.retrieveMultipleRecords("sst_address", "?$select=sst_location_id_txt&$filter=sst_locationid_str eq " + addressId)
                .then(result => {
                    if (result.entities && result.entities.length > 0) {
                        let address = result.entities[0];
                        const addressLookup = [{
                            id: address["sst_addressid"],
                            entityType: "sst_address",
                            name: address["sst_location_id_txt"]
                        }];
                        formContext.getAttribute("sst_address_delivery_ref").setValue(addressLookup);
                    }
                }, error => {
                    console.log(error.message);
                });
        });

};

Schulz.OrderForm.registerEvents = (formContext) => {

    formContext.getAttribute("msdyn_company")?.addOnChange(Schulz.OrderForm.debitorCheck);
    formContext.getAttribute("customerid")?.addOnChange(Schulz.OrderForm.debitorCheck);
    formContext.getAttribute("customerid")?.addOnChange(Schulz.OrderForm.getAddressFromCustomer);
    formContext.getAttribute("sst_debitor_id")?.addOnChange(Schulz.OrderForm.fillERPRoleFields);
    formContext.getAttribute("sst_footertextblock_id")?.addOnChange(Schulz.OrderForm.setTextblockFooter);
    formContext.getAttribute("sst_headertextblock_id")?.addOnChange(Schulz.OrderForm.setTextblockHeader);
};

Schulz.OrderForm.checkPositionsMandatoryFields = (formContext) => {
    var salesOrderId = formContext.data.entity.getId();
    Xrm.WebApi.retrieveMultipleRecords("salesorderdetail", "?$select=_msdyn_shippingsite_value,_msdyn_shippingwarehouse_value&$filter=_salesorderid_value eq '" + salesOrderId + "' and (_msdyn_shippingwarehouse_value eq null or _msdyn_shippingsite_value eq null)").then(
        function success(result) {
            if (result.entities.length > 0) {
                formContext.ui.setFormNotification("Bitte Versandlagerort und Lieferort in den Positionen prüfen.", "WARNING", "productMandatoryFieldsWarning");
            }
            // perform additional operations on retrieved records
        },
        function (error) {
            console.log(error.message);
            // handle error conditions
        }
    );

};

Schulz.OrderForm.debitorCheck = (executionContext) => {
    var formContext = executionContext.getFormContext();
    if (formContext.getAttribute("msdyn_company").getValue() != null) {
        var company = formContext.getAttribute("msdyn_company").getValue()[0].id;
        var companyid = company.replace('{', '').replace('}', '');

    }
    if (formContext.getAttribute("customerid").getValue() != null) {
        var customer = formContext.getAttribute("customerid").getValue();
        var customertype = customer[0].entityType;
        if (customertype == 'account') {
            var accountid = formContext.getAttribute("customerid").getValue()[0].id;
            accountid = accountid.substring(1, accountid.length - 1);
        } if (customertype == 'contact') {
            var contactid = formContext.getAttribute("customerid").getValue()[0].id;
            contactid = contactid.substring(1, contactid.length - 1);
        }
    }
    switch (customertype) {
        case 'account':
            if (accountid != null && companyid != null) {
                Xrm.WebApi.retrieveMultipleRecords("sst_erprole", "?$select=_sst_account_ref_value,_sst_company_ref_value,sst_name_str,sst_erproleid,sst_invoicedeliveryonhold_opt,_sst_taxgroup_ref_value&$filter=_sst_account_ref_value eq '" + accountid + "' and _sst_company_ref_value eq '" + companyid + "'").then(
                    function success(results) {
                        if (results.entities && results.entities.length > 0) {
                            var sst_erprole = results.entities[0];
                            const erprole = {
                                id: sst_erprole["sst_erproleid"],
                                entityType: "sst_erprole",
                                name: sst_erprole["sst_name_str"]
                            }
                            if (formContext.getAttribute("sst_debitor_id").getValue() == null) {
                                formContext.getAttribute("sst_debitor_id").setValue([erprole]);
                            }
                            if (sst_erprole["sst_invoicedeliveryonhold_opt"] == 806380000 && !formContext.getAttribute("sst_hasdebitor_opt").getValue()) {
                                formContext.getAttribute("sst_hasdebitor_opt").setValue(true);
                                formContext.ui.clearFormNotification("MissingDebitorNotification");
                            }
                            else if (!formContext.getAttribute("sst_hasdebitor_opt").getValue()) {
                                formContext.getAttribute("sst_hasdebitor_opt").setValue(false);
                                formContext.ui.setFormNotification("Der Debitor in diesem Mandanten ist noch nicht freigegeben.", "WARNING", "MissingDebitorNotification");
                            }

                            Schulz.OrderForm.fillDefaultSalesTaxPercentage(formContext, sst_erprole["_sst_taxgroup_ref_value"]);
                        }
                        else {
                            if (formContext.getAttribute("sst_debitor_id").getValue() != null) {
                                formContext.getAttribute("sst_debitor_id").setValue(null);
                            }
                            if (!formContext.getAttribute("sst_hasdebitor_opt").getValue()) {
                                formContext.getAttribute("sst_hasdebitor_opt").setValue(false);
                            }
                            formContext.ui.setFormNotification("In diesem Mandanten gibt es keinen Debitor für diese Firma.", "WARNING", "MissingDebitorNotification");
                            Schulz.OrderForm.clearDefaultSalesTaxPercentage(formContext);
                        }
                        Schulz.OrderForm.fillERPRoleFields(executionContext);
                    },
                    function (error) {
                    }
                );
            }
            break;
        case 'contact':
            if (contactid != null && companyid != null) {
                Xrm.WebApi.retrieveMultipleRecords("sst_erprole", "?$select=_sst_account_ref_value,_sst_company_ref_value,sst_name_str,sst_erproleid,sst_invoicedeliveryonhold_opt,_sst_taxgroup_ref_value&$filter=_sst_contact_id_value eq '" + contactid + "' and _sst_company_ref_value eq '" + companyid + "'").then(
                    function success(results) {
                        if (results.entities && results.entities.length > 0) {
                            var sst_erprole = results.entities[0];
                            const erprole = {
                                id: sst_erprole["sst_erproleid"],
                                entityType: "sst_erprole",
                                name: sst_erprole["sst_name_str"]
                            }
                            if (formContext.getAttribute("sst_debitor_id").getValue() == null) {
                                formContext.getAttribute("sst_debitor_id").setValue([erprole]);
                            }
                            if (sst_erprole["sst_invoicedeliveryonhold_opt"] == 806380000 && !formContext.getAttribute("sst_hasdebitor_opt").getValue()) {
                                formContext.getAttribute("sst_hasdebitor_opt").setValue(true);
                                formContext.ui.clearFormNotification("MissingDebitorNotification");
                            }
                            else if (!formContext.getAttribute("sst_hasdebitor_opt").getValue()) {
                                formContext.getAttribute("sst_hasdebitor_opt").setValue(false);
                                formContext.ui.setFormNotification("Der Debitor in diesem Mandanten ist noch nicht freigegeben.", "WARNING", "MissingDebitorNotification");
                            }

                            //Schulz.OrderForm.fillDefaultSalesTaxPercentage(formContext, sst_erprole["_sst_taxgroup_ref_value"]);
                        }
                        else {
                            if (formContext.getAttribute("sst_debitor_id").getValue() != null) {
                                formContext.getAttribute("sst_debitor_id").setValue(null);
                            }
                            if (!formContext.getAttribute("sst_hasdebitor_opt").getValue()) {
                                formContext.getAttribute("sst_hasdebitor_opt").setValue(false);
                            }
                            formContext.ui.setFormNotification("In diesem Mandanten gibt es keinen Debitor für diese Firma.", "WARNING", "MissingDebitorNotification");
                            //Schulz.OrderForm.clearDefaultSalesTaxPercentage(formContext);
                        }
                        Schulz.OrderForm.fillERPRoleFields(executionContext);

                    },
                    function (error) {
                    }
                );
            }
            break;
    }
};

Schulz.OrderForm.fillERPRoleFields = (executionContext) => {
    var formContext = executionContext.getFormContext();

    if (formContext.getAttribute("sst_debitor_id").getValue() != null) {
        var erproleid = formContext.getAttribute("sst_debitor_id").getValue()[0].id;
        erproleid = erproleid.substring(1, erproleid.length - 1);
    }
    if (erproleid != null && formContext.getAttribute("msdyn_paymentterms").getValue() == null) {
        Xrm.WebApi.retrieveMultipleRecords("sst_erprole", "?$select=sst_paymentterms_id,sst_erproleid,&$top=1&$filter=sst_erproleid eq '" + erproleid + "'&$expand=sst_paymentterms_id($select=msdyn_paymenttermid,msdyn_name)", 1)
            .then(result => {
                if (result.entities && result.entities.length > 0) {
                    var results = result.entities[0];
                    const payt = {
                        id: results.sst_paymentterms_id.msdyn_paymenttermid,
                        entityType: "msdyn_paymentterm",
                        name: results.sst_paymentterms_id.msdyn_name
                    }
                    if (results.sst_paymentterms_id != null) {
                        formContext.getAttribute("msdyn_paymentterms").setValue([payt]);
                    }
                }
            }, error => {
                console.log(error.message); // TODO: implement better error approach.
            });
    }
};

Schulz.OrderForm.fillDefaultSalesTaxPercentage = (formContext, salesTaxGroupRef) => {
    if (salesTaxGroupRef) {
        Xrm.WebApi.retrieveRecord("msdyn_taxgroup", salesTaxGroupRef, "?$select=hso_defaultsalestaxcodepercentage")
            .then(result => {
                formContext.getAttribute("sst_salestaxcodepercentage").setValue(result["hso_defaultsalestaxcodepercentage"]);
            }, error => {
                console.log(error.message);
            });
    }
    else {
        Schulz.OrderForm.clearDefaultSalesTaxPercentage(formContext);
    }
};

Schulz.OrderForm.clearDefaultSalesTaxPercentage = (formContext) => {
    formContext.getAttribute("sst_salestaxcodepercentage").setValue(null);
};

Schulz.OrderForm.setTextblockHeader = (executionContext) => {
    Schulz.OrderForm.setTextblock(executionContext, "sst_headertextblock_id", "sst_headtext_txt");
};

Schulz.OrderForm.setTextblockFooter = (executionContext) => {
    Schulz.OrderForm.setTextblock(executionContext, "sst_footertextblock_id", "sst_foottext_txt");
};

Schulz.OrderForm.setTextblock = (executionContext, lookupname, txtname) => {
    let formContext = executionContext.getFormContext();

    if (formContext.getAttribute(lookupname).getValue()) {
        let textblock = formContext.getAttribute(lookupname).getValue()[0].id;
        Xrm.WebApi.retrieveRecord("sst_textblocks", textblock, "?$select=sst_textblock_txt")
            .then(result => {
                if (result?.sst_textblock_txt) {
                    if (!formContext.getAttribute(txtname).getValue()) {
                        formContext.getAttribute(txtname).setValue(result.sst_textblock_txt);
                    } else {
                        let txt = formContext.getAttribute(txtname).getValue();
                        txt += "\n";
                        txt += result.sst_textblock_txt;
                        formContext.getAttribute(txtname).setValue(txt);
                    }
                }
            }, error => {
                console.log(error.message); // TODO: implement better error approach.
            });
    }
};

Schulz.OrderForm.filterTextblocks = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let headerAttribute = formContext.getAttribute("sst_headertextblock_id");
    let footerAttribute = formContext.getAttribute("sst_footertextblock_id");

    headerAttribute?.controls.forEach(control => {
        control.addPreSearch(Schulz.OrderForm.setTextblocksPreSearch);
    });
    footerAttribute?.controls.forEach(control => {
        control.addPreSearch(Schulz.OrderForm.setTextblocksPreSearch);
    });
};

Schulz.OrderForm.setTextblocksPreSearch = (executionContext) => {
    let formContext = executionContext.getFormContext();

    let headertextblock = formContext.getAttribute("sst_headertextblock_id");
    let footertextblock = formContext.getAttribute("sst_footertextblock_id");
    let companyAttribute = formContext.getAttribute("msdyn_company")?.getValue();
    let language = formContext.getAttribute("msdyn_language")?.getValue();

    if (companyAttribute) {
        let companyId = companyAttribute[0].id;
        let filterheader = `<filter type="and"><condition attribute="sst_language_opt" operator="eq" value="${language}" /><condition attribute="sst_type_opt" operator="eq" value="867520000" /><filter type="or"><condition attribute="sst_company_id" operator="eq" uitype="msdyn_company" value="${companyId}" /><condition attribute="sst_company_id" operator="null" /></filter></filter>`;
        let filterfooter = `<filter type="and"><condition attribute="sst_language_opt" operator="eq" value="${language}" /><condition attribute="sst_type_opt" operator="eq" value="867520001" /><filter type="or"><condition attribute="sst_company_id" operator="eq" uitype="msdyn_company" value="${companyId}" /><condition attribute="sst_company_id" operator="null" /></filter></filter>`;
        headertextblock?.controls.forEach(control => {
            control.addCustomFilter(filterheader, "sst_textblocks");
        });
        footertextblock?.controls.forEach(control => {
            control.addCustomFilter(filterfooter, "sst_textblocks");
        });
    }
};