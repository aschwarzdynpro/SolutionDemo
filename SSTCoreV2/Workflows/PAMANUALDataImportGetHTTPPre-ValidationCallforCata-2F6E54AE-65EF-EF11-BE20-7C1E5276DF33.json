              "inputs": {
                "parameters": {
                  "request/method": "PATCH",
                  "request/url": "https://@{parameters('EnvVar | Dataverse Instance (hso_EnvVarDataverseInstance)')}/api/data/v9.2/hso_catalogueimports(hso_runid='@{triggerOutputs()?['body/hso_runid']}')",
                  "request/headers": {
