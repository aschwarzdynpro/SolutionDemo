// (Re-) Calculate the Position Quantity
// Function called by other function 'onChangeQuantity' from within this library
ETO.CalculationPositionForm.calculatePositionQuantity = async (executionContext) => {
    // get the form context
    let formContext = executionContext.getFormContext();
    // check if Quantity is set
    if (formContext.getAttribute("hso_quantity").getValue() != null) {
        let Quantity = formContext.getAttribute("hso_quantity").getValue();
        if (formContext.getAttribute("hso_calculationdetail_parentid").getValue() != null) {
            // Parent Position Quantity
            let ParentCalculationPosition_PositionQuantity = ParentCalculationPosition_Record.hso_positionquantity;
            // calculate Position Quantity
            let calculatedPositionQuantity = Quantity * ParentCalculationPosition_PositionQuantity;
            calculatedPositionQuantity = Number(calculatedPositionQuantity.toFixed(5));
            formContext.getAttribute("hso_positionquantity").setValue(calculatedPositionQuantity);
            // set Parent Quantity to retrieved value
            ParentCalculationPosition_PositionQuantity = Number(ParentCalculationPosition_PositionQuantity.toFixed(5));
            formContext.getAttribute("hso_parentquantity").setValue(ParentCalculationPosition_PositionQuantity);
            // Set Default Duration in Minutes Position Quantity for Calculation Position 
            ETO.CalculationPositionForm.setDurationInMinutes(formContext);
        } else {
            // if Parent Calculation Position is not set, set Position Quantity to Quantity
            // set Position Quantity to Quantity
            let calculatedPositionQuantity = Quantity;
            calculatedPositionQuantity = Number(calculatedPositionQuantity.toFixed(5));
            formContext.getAttribute("hso_positionquantity").setValue(calculatedPositionQuantity);
            // Set Default Duration in Minutes Position Quantity for Calculation Position 
            ETO.CalculationPositionForm.setDurationInMinutes(formContext);

        };
    } else {
        if (formContext.getAttribute("hso_calculationdetail_parentid").getValue() != null) {
            // Parent Position Quantity
            let ParentCalculationPosition_PositionQuantity = ParentCalculationPosition_Record.hso_positionquantity;
            // calculate Position Quantity
            let calculatedPositionQuantity = 1 * ParentCalculationPosition_PositionQuantity;
            calculatedPositionQuantity = Number(calculatedPositionQuantity.toFixed(5));
            formContext.getAttribute("hso_positionquantity").setValue(calculatedPositionQuantity);
            // set Parent Quantity to retrieved value
            ParentCalculationPosition_PositionQuantity = Number(ParentCalculationPosition_PositionQuantity.toFixed(5));
            formContext.getAttribute("hso_parentquantity").setValue(ParentCalculationPosition_PositionQuantity);
            // Set Default Duration in Minutes Position Quantity for Calculation Position 
            ETO.CalculationPositionForm.setDurationInMinutes(formContext);
        } else {
            // if Parent Calculation Position is not set, set Position Quantity to Quantity
            // set Position Quantity to Quantity
            let calculatedPositionQuantity = 1;
            calculatedPositionQuantity = Number(calculatedPositionQuantity.toFixed(5));
            formContext.getAttribute("hso_positionquantity").setValue(calculatedPositionQuantity);
            // Set Default Duration in Minutes Position Quantity for Calculation Position 
            ETO.CalculationPositionForm.setDurationInMinutes(formContext);
        }
    };
};

// Re-Calculate Position Quantity
// Function triggered in the Calculation Position form onChange event handler for field hso_durationinminutes
ETO.CalculationPositionForm.calculateQuantityDurationInMinutes = (executionContext) => {
    // get the form context
    let formContext = executionContext.getFormContext();
    // get selected Position Element Type
    let ElementType = formContext.getAttribute("hso_positionelementtype").getValue();
    // get Quantity (if already set)
    let Quantity = formContext.getAttribute("hso_quantity").getValue();
    // get Quantity (if already set)
    let DurationInMinutes = formContext.getAttribute("hso_durationinminutes").getValue();
    if (ElementType == 100000003 || ElementType == 100000004 || ElementType == 100000008 && DurationInMinutes != null) {
        // Position Element Type 'Production Hour' 'Project Hour' and 'External Service'
        // calculate Position Quantity
        Quantity = DurationInMinutes / 60;
        Quantity = Number(Quantity);
        formContext.getAttribute("hso_quantity").setValue(Quantity);
        // proceed with the calculation of the Position Quantity
        ETO.CalculationPositionForm.onChangeQuantity(executionContext);;
    } else if (ElementType != 100000006) {
        formContext.getAttribute("hso_quantity").setValue(null);
    };
};

//Filter LookUp Field Projectproduct for BOM
function filterProjectProduct(executionContext) {
    // 'JSFilterBlankProjectProductFilterTESTJS'- not Exist name, BOM need neu Project Product 
    var formContext = executionContext.getFormContext();
    let ProjectType = formContext.getAttribute("hso_projecttype").getValue();
    if (ProjectType != null) {
        switch (ProjectType) {
            case 100000000: // Project Type 'Aufwand'
                var ProjectProductFilter = "<filter type='and'><condition attribute='hso_isbillofmaterials' operator='eq' value='1'/><condition attribute='hso_projecttype' operator='eq' value='100000000'/></filter>";
                formContext.getControl("hso_billofmaterial_projectproductid").addCustomFilter(ProjectProductFilter);
                break;
            case 100000001: // Project Type 'Aufmaß'
                var ProjectProductFilter = "<filter type='and'><condition attribute='hso_isbillofmaterials' operator='eq' value='1'/><condition attribute='hso_projecttype' operator='eq' value='100000001'/></filter>";
                formContext.getControl("hso_billofmaterial_projectproductid").addCustomFilter(ProjectProductFilter);
                break;
            case 100000002: // Project Type 'Festpreis'
                var ProjectProductFilter = "<filter type='and'><condition attribute='hso_isbillofmaterials' operator='eq' value='1'/><condition attribute='hso_projecttype' operator='eq' value='100000002'/></filter>";
                formContext.getControl("hso_billofmaterial_projectproductid").addCustomFilter(ProjectProductFilter);
                break;
        }
    } else { var ProjectProductFilter = "<filter type='and'><condition attribute='hso_name' operator='eq' value='JSFilterBlankProjectProductFilterTESTJS'/></filter>"; };
    formContext.getControl("hso_billofmaterial_projectproductid").addCustomFilter(ProjectProductFilter);
};

