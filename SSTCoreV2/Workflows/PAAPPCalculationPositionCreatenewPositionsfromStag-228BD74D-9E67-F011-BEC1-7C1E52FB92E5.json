        "Initialize_varBatchSettings": {
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "varBatchSettings",
                "type": "object",
                "value": {
                  "maxBatchSize": 10,
                  "minBatchSize": 1,
                  "maxParallelism": 20,
                  "minParallelism": 1
                }
              }
            ]
          },
          "runAfter": {
