            showField(formContext, 'hso_pricecomponent_devices');
            showField(formContext, 'hso_pricecomponent_others');
            showField(formContext, 'hso_pricecomponent_unknown');
        } else { 
            // hide Price Compononent Fields if Price Component
            hideField(formContext, 'hso_pricecomponent_salaries');
            hideField(formContext, 'hso_pricecomponent_material');
            hideField(formContext, 'hso_pricecomponent_devices');
            hideField(formContext, 'hso_pricecomponent_others');
            hideField(formContext, 'hso_pricecomponent_unknown');
        };
    } else {
        // disable Price Component Breakdown
        disableField(formContext, 'hso_pricecomponentbreakdown');
    };
};    

// FETCH LINE Infos
// Get Calculation Type of Node located on the highest level
// Function called by other function 'filterCalculationTypeOptions' from within this library
Schulz.CalculationPositionForm.retrieveTopLevelCalculationType = function (formContext, param_Calculation, param_CalculationPosition_LineNumber) {
    return new Promise(function (resolve, reject) {
        // Search for Top Level Node of specific Calculation Position
        Xrm.WebApi.retrieveMultipleRecords("hso_calculationdetail", "?$select=hso_calculationdetailid,hso_name,hso_linenumber,hso_calculationtype&$filter=_hso_calculationid_value eq '" + param_Calculation + "' and hso_level eq 1 and hso_linenumber_level eq '" + param_CalculationPosition_LineNumber + "'").then(
            result => {
                for (var i = 0; i < result.entities.length; i++) {
                }
                if (result != null) {
                    let TopLevelNode_CalculationType = result.entities[0].hso_calculationtype;
                    resolve(TopLevelNode_CalculationType);
                }
            },
            error => {
                reject(error);
            }
        );
    })
};

// (Re-) Calculate the Position Quantity
// Function called by other function 'onChangeQuantity' from within this library
Schulz.CalculationPositionForm.calculatePositionQuantity = (executionContext) => {
    // get the form context
    let formContext = executionContext.getFormContext();
    // check if Quantity is set
    if (formContext.getAttribute("hso_quantity").getValue() != null) {
        let Quantity = formContext.getAttribute("hso_quantity").getValue();
        if (formContext.getAttribute("hso_calculationdetail_parentid").getValue() != null) {
            // Parent Position Quantity
            let ParentCalculationPosition_PositionQuantity = formContext.getAttribute("hso_parentquantity").getValue();
            // calculate Position Quantity
            let calculatedPositionQuantity = Quantity * ParentCalculationPosition_PositionQuantity;
            calculatedPositionQuantity = Number(calculatedPositionQuantity.toFixed(5));
            formContext.getAttribute("hso_positionquantity").setValue(calculatedPositionQuantity);
            // Set Default Duration in Minutes Position Quantity for Calculation Position 
            Schulz.CalculationPositionForm.setDurationInMinutes(formContext);
        } else {
            // if Parent Calculation Position is not set, set Position Quantity to Quantity
            // set Position Quantity to Quantity
            let calculatedPositionQuantity = Quantity;
            calculatedPositionQuantity = Number(calculatedPositionQuantity.toFixed(5));
            formContext.getAttribute("hso_positionquantity").setValue(calculatedPositionQuantity);
            // Set Default Duration in Minutes Position Quantity for Calculation Position 
            Schulz.CalculationPositionForm.setDurationInMinutes(formContext);
            // proceed with the calculation of the Cost Price
            Schulz.CalculationPositionForm.calculateCostPrice(formContext, calculatedPositionQuantity, "calculatePositionQuantity");
        };
    } else {
        if (formContext.getAttribute("hso_calculationdetail_parentid").getValue() != null) {
            // Parent Position Quantity
            let ParentCalculationPosition_PositionQuantity = formContext.getAttribute("hso_parentquantity").getValue();
            // calculate Position Quantity
            let calculatedPositionQuantity = 1 * ParentCalculationPosition_PositionQuantity;
            calculatedPositionQuantity = Number(calculatedPositionQuantity.toFixed(5));
            formContext.getAttribute("hso_positionquantity").setValue(calculatedPositionQuantity);
            // Set Default Duration in Minutes Position Quantity for Calculation Position 
            Schulz.CalculationPositionForm.setDurationInMinutes(formContext);
        } else {
            // if Parent Calculation Position is not set, set Position Quantity to Quantity
            // set Position Quantity to Quantity
            let calculatedPositionQuantity = 1;
            calculatedPositionQuantity = Number(calculatedPositionQuantity.toFixed(5));
            formContext.getAttribute("hso_positionquantity").setValue(calculatedPositionQuantity);
            // Set Default Duration in Minutes Position Quantity for Calculation Position 
            Schulz.CalculationPositionForm.setDurationInMinutes(formContext);
            // proceed with the calculation of the Cost Price
            Schulz.CalculationPositionForm.calculateCostPrice(formContext, calculatedPositionQuantity, "calculatePositionQuantity");
        }
    };
};

// Re-Calculate Position Quantity
// Function triggered in the Calculation Position form onChange event handler for field hso_durationinminutes
Schulz.CalculationPositionForm.calculateQuantityDurationInMinutes = (executionContext) => {
    // get the form context
    let formContext = executionContext.getFormContext();
    // get selected Position Element Type
    let ElementType = formContext.getAttribute("hso_positionelementtype").getValue();
    // get Quantity (if already set)
    let Quantity = formContext.getAttribute("hso_quantity").getValue();
    // get Quantity (if already set)
    let DurationInMinutes = formContext.getAttribute("hso_durationinminutes").getValue();
    if (ElementType == 100000003 || ElementType == 100000004 || ElementType == 100000008 && DurationInMinutes != null) {
        // Position Element Type 'Production Hour' 'Project Hour' and 'External Service'
        // calculate Position Quantity
        Quantity = DurationInMinutes / 60;
        Quantity = Number(Quantity);
        formContext.getAttribute("hso_quantity").setValue(Quantity);
        // proceed with the calculation of the Position Quantity
        Schulz.CalculationPositionForm.onChangeQuantity(executionContext);;
    } else if (ElementType != 100000006) {
        formContext.getAttribute("hso_quantity").setValue(null);
    };
};

// (Re-) Calculate the Cost Price
// Function called by other functions from within this library
// (by functions - formOnSave, onChangeBasePriceWithoutMetalSurcharge, onChangeCostPricePerUnit, retrieveCalculationSurchargegroups, retrieveCalculationMetalPrices)
// (by functions - retrieveCalculationSalesPrice_Category, retrieveParentCalculationPosition, calculatePositionQuantity, retrieveCalculationSalesPrice_Product)
Schulz.CalculationPositionForm.calculateCostPrice = (formContext, Quantity, TriggerBy) => {
    // check if Cost Price per Unit and Position Quantity are set
    var calculatedCostPrice;
    if (formContext.getAttribute("hso_costpriceperunit").getValue() != null && Quantity != null) {
        let CostPricePerUnit = formContext.getAttribute("hso_costpriceperunit").getValue();
        CostPricePerUnit = Number(CostPricePerUnit.toFixed(2));
        // Calculate the CostPrice
        calculatedCostPrice = Quantity * CostPricePerUnit;
    } else {
        // set the CostPrice to zero
        calculatedCostPrice = 0;
    };
    // set the CostPrice to the calculated value
    formContext.getAttribute("hso_costprice").setValue(calculatedCostPrice);
    // check whether Cost Price is Zero  
    if (calculatedCostPrice == 0) {
        // in case the Cost Price is 0 (zero) no further calculations are required because all other values are 0 (zero) as well
        Schulz.CalculationPositionForm.calculateCostOfZero(formContext)
    } else {
