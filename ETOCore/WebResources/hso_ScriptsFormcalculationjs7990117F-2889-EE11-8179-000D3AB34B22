// openSidePanel's in the Calculation Position form onLoad event handler
ETO.CalculationForm.openSidePanel = function (formContext, showCalculationParameters, Calculation) {
        // open Navigation Parameters Side Panel (Surcharge Groups + Metal Prices + Sales Prices)
        if (showCalculationParameters == "openCalculationParameters") {
                // get the Calculation Parameters Side Panel
                let SidePanel_CalculationParameters_CustomPage = Xrm.App.sidePanes.getPane("CalculationParameters_SidePanel");
                // Calculation Position: Parent Calculation - Metal Prices
                if (SidePanel_CalculationParameters_CustomPage != null) {
                        Xrm.App.sidePanes.getPane("CalculationParameters_SidePanel").navigate({
                                pageType: "custom",
                                name: "hso_calculationparameters_ad6ee",
                                recordId: Calculation,
                                hidden: false
                        });
                } else {
                        Xrm.App.sidePanes.createPane({
                                title: "Calculation Parameters",
                                paneId: "CalculationParameters_SidePanel",
                                imageSrc: "WebResources/hso_addfragment_icon",
                                hideHeader: false,
                                canClose: false,
                                width: 800,
                                isSelected: false,
                                hidden: false
                        }).then((pane) => {
                                pane.navigate({
                                        pageType: "custom",
                                        name: "hso_calculationparameters_ad6ee",
                                        recordId: Calculation,
                                        hidden: false
                                })
                        });
                }
        };
};

