if (typeof (ETO) === "undefined") { ETO = {}; };
if (typeof (ETO.WorkOrderServiceForm) === "undefined") { ETO.WorkOrderServiceForm = {}; }

ETO.WorkOrderServiceForm.onLoad = (executionContext) => {
    let formContext = executionContext.getFormContext();
    //ETO.WorkOrderForm.registerEvents(formContext);

        ETO.WorkOrderServiceForm.setFormReadonlyIfWorkOrderIsFinished(formContext);    

};

ETO.WorkOrderServiceForm.setFormReadonlyIfWorkOrderIsFinished = (formContext) => {

    var workOrderId = formContext.getAttribute("msdyn_workorder").getValue()[0].id;
    Xrm.WebApi.retrieveRecord("msdyn_workorder", workOrderId, "?$select=msdyn_systemstatus").then(
    function success(result) {
        if (result.msdyn_systemstatus >= 690970003)
        {
            ETO.Common.disableAllFields(formContext);
            formContext.ui.setFormNotification("The work order has been completed. Changes are no longer possible.", "INFO", "wo_readonly");
        }
    },
    function (error) {
        console.log(error.message);
        // handle error conditions
    }
);
}