        'hso_product_metalsurchargeperunit_3',
        'hso_surchargegroup_calculationid',
        'hso_overheadsurchargepercentage',
        'hso_profitsurchargepercentage',
        'hso_discountpercentage',
        'hso_textblock_name',
        'hso_textblock_description_max',
        'hso_quantity',
        'hso_positionquantity',
        'hso_costpriceperunit',
        'hso_costprice',
        'hso_overheadsurcharge',
        'hso_costofmaterialsperunit',
        'hso_costofmaterials',
        'hso_profitsurcharge',
        'hso_salespriceperunit',
        'hso_salesprice',
        'hso_discount',
        'hso_contributionmargintargetsalespricepercent',
        'hso_negotiationsurchargepercentage',
        'hso_quotedpriceperunit',
        'hso_quotedprice',
        'hso_margin',
        'hso_marginpercentage'
    ];
    // Loop through the array and clear each field
    fieldsToClear.forEach(function (fieldName) {
        clearField(formContext, fieldName);
    });
    clearFieldOption(formContext, 'hso_subproject');
    if (ElementType == null || ElementType == 100000005 || ElementType == 100000001 || ElementType == 100000006) {
        noneField(formContext, 'hso_costpriceperunit');
        noneField(formContext, 'hso_surchargegroup_baseid');
