              "type": "Http",
              "inputs": {
                "method": "GET",
                "uri": "@{variables('strInlineFinOpsURL')}/data/ProductDefaultOrderSettings?$filter=%20ItemNumber eq '@{triggerBody()['text']}'&$select=dataAreaId&cross-company=true",
                "headers": {
                  "Content-Type": "application/json"
                },
                "authentication": {
                  "type": "ActiveDirectoryOAuth",
                  "tenant": "@triggerBody()['text_1']",
                  "audience": "@variables('strInlineFinOpsURL')",
                  "clientId": "@triggerBody()['text_2']",
