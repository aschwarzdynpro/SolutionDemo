{
  "properties": {
    "connectionReferences": {
      "shared_commondataserviceforapps_1": {
        "runtimeSource": "embedded",
        "connection": {
          "connectionReferenceLogicalName": "hso_CRDataverse"
        },
        "api": {
          "name": "shared_commondataserviceforapps"
        }
      }
    },
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "parameters": {
        "$connections": {
          "defaultValue": {},
          "type": "Object"
        },
        "$authentication": {
          "defaultValue": {},
          "type": "SecureObject"
        }
      },
      "triggers": {
        "When_a_bookable_resource_booking_has_been_created": {
          "metadata": {
            "operationMetadataId": "42451828-6aeb-4fe6-8a2c-250d9d9ac640"
          },
          "type": "OpenApiConnectionWebhook",
          "inputs": {
            "host": {
              "connectionName": "shared_commondataserviceforapps_1",
              "operationId": "SubscribeWebhookTrigger",
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
            },
            "parameters": {
              "subscriptionRequest/message": 1,
              "subscriptionRequest/entityname": "msdyn_resourcerequirement",
              "subscriptionRequest/scope": 4
            },
            "authentication": "@parameters('$authentication')"
          }
        }
      },
      "actions": {
        "If_project_is_set": {
          "actions": {
            "Get_the_related_project": {
              "runAfter": {},
              "metadata": {
                "operationMetadataId": "98677a0e-f722-453a-b48e-a603280b9b20"
              },
              "type": "OpenApiConnection",
              "inputs": {
                "host": {
                  "connectionName": "shared_commondataserviceforapps_1",
                  "operationId": "GetItem",
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                },
                "parameters": {
                  "entityName": "msdyn_projects",
                  "recordId": "@if(equals(triggerOutputs()?['body/_msdyn_projectid_value'], null), triggerOutputs()?['body/_hso_projectassembly_ref_value'], triggerOutputs()?['body/_msdyn_projectid_value'])",
                  "$select": "hso_latitude_flt,hso_longitude_flt,hso_deliverystreet_txt,hso_city_txt,hso_postalcode_txt,_hso_country_id_value,hso_deliveryname_txt"
                },
                "authentication": "@parameters('$authentication')"
              },
              "description": "Only address and lat/long"
            },
            "Copy_address_to_booking": {
              "runAfter": {
                "Get_the_related_project": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "28822b78-dc91-4ef9-bf44-ca2856bcd3fe"
              },
              "type": "OpenApiConnection",
              "inputs": {
                "host": {
                  "connectionName": "shared_commondataserviceforapps_1",
                  "operationId": "UpdateRecord",
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                },
                "parameters": {
                  "entityName": "msdyn_resourcerequirements",
                  "recordId": "@triggerOutputs()?['body/msdyn_resourcerequirementid']",
                  "item/msdyn_latitude": "@outputs('Get_the_related_project')?['body/hso_latitude_flt']",
                  "item/msdyn_longitude": "@outputs('Get_the_related_project')?['body/hso_longitude_flt']",
                  "item/hso_address_name_str": "@outputs('Get_the_related_project')?['body/hso_deliveryname_txt']",
                  "item/hso_country_id@odata.bind": "hso_countries(@{outputs('Get_the_related_project')?['body/_hso_country_id_value']})",
                  "item/msdyn_city": "@outputs('Get_the_related_project')?['body/hso_city_txt']",
                  "item/hso_postalcode_txt": "@outputs('Get_the_related_project')?['body/hso_postalcode_txt']",
                  "item/hso_street_txt": "@outputs('Get_the_related_project')?['body/hso_deliverystreet_txt']"
                },
                "authentication": "@parameters('$authentication')"
              }
            }
          },
          "runAfter": {},
          "expression": {
            "or": [
              {
                "not": {
                  "equals": [
                    "@triggerOutputs()?['body/_msdyn_projectid_value']",
                    "@null"
                  ]
                }
              },
              {
                "not": {
                  "equals": [
                    "@triggerOutputs()?['body/_hso_projectassembly_ref_value']",
                    "@null"
                  ]
                }
              }
            ]
          },
          "metadata": {
            "operationMetadataId": "23b85d7e-ee32-445a-889f-86833559097d"
          },
          "type": "If"
        }
      },
      "outputs": {}
    },
    "templateName": ""
  },
  "schemaVersion": "1.0.0.0"
}