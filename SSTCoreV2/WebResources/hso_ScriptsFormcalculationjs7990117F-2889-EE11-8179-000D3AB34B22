Schulz.CalculationForm.formOnLoad = (executionContext, formType, showCalculationParameters) => {
        let formContext = executionContext.getFormContext();
        // Get Quote
        let Quote = formContext.getAttribute("hso_quoteid").getValue();
        console.log(Quote);
        if (Quote && Quote.length > 0) {
                var QuoteGUID = Quote[0].id;
        } else {
                console.warn("Quote is not set or invalid.");
        };
        // Get Quote Currency
        if (formType == "IsQuickCreateForm") {
                // Set Default Currency of new Calculation to "Euro"
                Schulz.CalculationForm.retrieveDefaultCurrency(formContext).then(function (RetrievedCurrencyName) {
                }).catch(function (error) {
                        alert(error.message);
                });
                // Set Quote Currency of new Calculation to Currency from Quote
                Schulz.CalculationForm.retrieveQuote(formContext, QuoteGUID).then(function (RetrievedQuoteCurrencyName) {
                }).catch(function (error) {
                        alert(error.message);
                });
        } else {
                // Get & format Calculation GUID
                let CalculationGUID = formContext.data.entity.getId();
                CalculationGUID_formatted = CalculationGUID.replace(/[{}]/g, "");
                // Register onChange Events for Main Forms
                Schulz.CalculationForm.registerEvents_MainForm(executionContext, formContext);
                // Restrict options to set Calculation Type
                Schulz.CalculationForm.filterCalculationTypeOptions(formContext, CalculationGUID_formatted);
                // Display a notification with information regarding the project creation process in FinOps
                Schulz.CalculationForm.displayFormNotification(formContext);
                // Open Side Panels
                Schulz.CalculationForm.openSidePanel(formContext, showCalculationParameters, CalculationGUID_formatted);
                // Check Calculation Positions with Product Lifecycle Warning
                Schulz.CalculationForm.retrieveCalculationPositionsWithProductLifecycleWarning(formContext, CalculationGUID).then(function (NumberOfCalculationPositionsWithProductLifecycleWarning) {
                        if (NumberOfCalculationPositionsWithProductLifecycleWarning > 1) {// Processing Status Project = In Progress
                                formContext.ui.setFormNotification("ACHTUNG: Die Kalkulationsversion enthält Positionen mit Artikeln, welche einen auslaufenden Produktlebenszyklusstatus aufweisen.", "INFO", "ProductLifecycleWarning_InformationNotification");
                        }
                }).catch(function (error) {
                        alert(error.message);
                });

                // Check Project Products with Supplier Not Available for Calculation 
                Schulz.CalculationForm.retrieveProjectProductswithSupplierNotAvailable(formContext, CalculationGUID).then(function (NumberOfCalculationPositionsWithProjectProductswithSupplierNotAvailable) {
                        if (NumberOfCalculationPositionsWithProjectProductswithSupplierNotAvailable >= 1) {// Processing Status Project = In Progress
                                formContext.ui.setFormNotification("ACHTUNG: Die Kalkulationsversion enthält Projektartikel, welche bei dem jeweiligen Lieferanten nicht mehr verfügbar sind.", "INFO", "ProjectProductswithSupplierNotAvailable_InformationNotification");
                        }
                }).catch(function (error) {
                        alert(error.message);
                });

                // Get Navigation Calculation Position
                let navigationCalculationPosition = formContext.getAttribute("hso_navigationkalkulationposition").getValue();
                if (navigationCalculationPosition && navigationCalculationPosition.length > 0) {
                        let NavigationCalculationPosition_ID = navigationCalculationPosition[0].id;

                        // Open Calculation Position Pricing Details and Search & Replace Side Panels
                        Schulz.CalculationForm.openCalculationPositionSidePanel(formContext, NavigationCalculationPosition_ID);
                } else {
                        console.warn("Navigation Calculation Position is not set or invalid.");
                };
        }
};

// Register onChange Events for Main Forms
Schulz.CalculationForm.registerEvents_MainForm = (executionContext, formContext) => {
        // onChange Event Handler for Elementtype
        formContext.getAttribute("hso_navigationkalkulationposition")?.addOnChange(Schulz.CalculationForm.onChangeNavigationPosition);
};

// Function triggered in the Calculation Position form onChange event handler for field hso_productid
Schulz.CalculationForm.onChangeNavigationPosition = (executionContext) => {
        // get the form context
        var formContext = executionContext.getFormContext();

        // Get Navigation Calculation Position
        let navigationCalculationPosition = formContext.getAttribute("hso_navigationkalkulationposition").getValue();
        if (navigationCalculationPosition && navigationCalculationPosition.length > 0) {
                let NavigationCalculationPosition_ID = navigationCalculationPosition[0].id;

                // Open Calculation Position Pricing Details and Search & Replace Side Panels
                Schulz.CalculationForm.openCalculationPositionSidePanel(formContext, NavigationCalculationPosition_ID);
        } else {
                console.warn("Navigation Calculation Position is not set or invalid.");
        }
};


Schulz.CalculationForm.formOnSave = (executionContext) => {
        var formContext = executionContext.getFormContext();
        // Retrieve required fields
        var Company = formContext.getAttribute("hso_companyid").getValue();
        var Quote = formContext.getAttribute("hso_quoteid").getValue();
        var Department = formContext.getAttribute("hso_departmentid").getValue();
        var Currency = formContext.getAttribute("transactioncurrencyid").getValue();
        var QuoteCurrency = formContext.getAttribute("hso_transactioncurrencyid_quote").getValue();
        var Language = formContext.getAttribute("hso_language").getValue();
        // Validate Company
        if (Company == null || Company === "") {
                formContext.ui.setFormNotification("Bitte wählen Sie ein Unternehmen für das Angebot aus. Das Unternehmen ist für das Erstellen einer Kalkulationsversion zwingend erforderlich.", "ERROR", "1");
                executionContext.getEventArgs().preventDefault(); // Prevents save
        };
        // Validate Quote
        if (Quote == null || Quote === "") {
                formContext.ui.setFormNotification("Eine neue Kalkulationsversion muss einem Angebot zugeordnet werden. Bitte wiederholen Sie den Vorgang.", "ERROR", "1");
                executionContext.getEventArgs().preventDefault(); // Prevents save
        };
        // Validate Department
        if (Department == null || Department === "") {
                formContext.ui.setFormNotification("Bitte wählen Sie eine Abteilung für das Angebot aus. Die Abteilung ist für das Erstellen einer Kalkulationsversion zwingend erforderlich.", "ERROR", "1");
                executionContext.getEventArgs().preventDefault(); // Prevents save
        };
        // Validate Currency
        if (Currency == null || Currency === "") {
                formContext.ui.setFormNotification("Die Standardwährung für eine Kalkulationsversion ist EURO. Bitte wiederholen Sie den Vorgang.", "ERROR", "1");
                executionContext.getEventArgs().preventDefault(); // Prevents save
        };
        // Validate Quote Currency
        if (QuoteCurrency == null || QuoteCurrency === "") {
                formContext.ui.setFormNotification("Bitte wählen Sie eine Währung für das Angebot aus. Die Angebotswährung ist für das Erstellen einer Kalkulationsversion erforderlich.", "ERROR", "1");
                executionContext.getEventArgs().preventDefault(); // Prevents save
        };
        // Validate Language
        if (Language == null || Language === "") {
                formContext.ui.setFormNotification("Bitte wählen Sie eine Sprache für das Angebot aus. Die Sprache ist für das Erstellen einer Kalkulationsversion zwingend erforderlich.", "ERROR", "1");
                executionContext.getEventArgs().preventDefault(); // Prevents save
        };
};

// Filter available Calculation Type options
// Function called by other function 'formOnLoad' from within this library
Schulz.CalculationForm.filterCalculationTypeOptions = (formContext, Calculation) => {
        // Get Option Set Values for Calculation Type
        let CalculationTypeOptions = formContext.getControl("hso_calculationtype").getOptions();
        let optionUseDefaultPrice = CalculationTypeOptions[1]; // Standardpreis verwenden
        let optionOverwriteDefaultPrice = CalculationTypeOptions[2]; // Standardpreis überschreiben
        // Clear choices for Calculation Type
        formContext.getControl("hso_calculationtype").clearOptions();
        //Add choices that should be available for selection
        formContext.getControl("hso_calculationtype").addOption(optionUseDefaultPrice);
        // Check Top-Level-Nodes for Projecttype "Effort"
        Schulz.CalculationForm.retrieveLevel1CalculationPositions(formContext, Calculation).then(function (NumberOfTopLevelCalculationPositions) {
                console.log("Number of Top-Level-Nodes with Projecttype 'Effort' retrieved = " + NumberOfTopLevelCalculationPositions);
                if (NumberOfTopLevelCalculationPositions == 0) {
                        // allow possibility to overwrite the Default prices by triggering the Top-Down-Calculation
                        console.log("Allow Top-Down-Calculation because no Top-Level-Nodes with Projecttype 'Effort' found");
                        formContext.getControl("hso_calculationtype").addOption(optionOverwriteDefaultPrice);
                } else {
                        console.log("Top-Down-Calculation not allowed because no Top-Level-Nodes with Projecttype 'Effort' found");
                        formContext.ui.setFormNotification("Die Berechnungsart der gesamten Kalkulationsversion kann nicht auf 'Standardpreis überschreiben' geändert werden, da der Projekttyp 'Aufwand' verwendet wird. Bitte nutzen Sie die Level-1-Knotenpunkte, welche nicht dem Projekttyp 'Aufwand' zugeordnet sind, um eine Top-Down-Berechnung vorzugeben.", "INFO", "TopDownCalculationNotAllowed_InformationNotification");

                }
        }).catch(function (error) {
                alert(error.message);
        });
};

