// Generic function to show a specific field 
//(for multiple Fields, e.g. 2 Fields for 'hso_productid')
// Function called by other functions from within this library
function enableMultipleFields(formContext, fieldName) {
    formContext.getAttribute(fieldName).controls.forEach(
        function (control, i) {
            control.setDisabled(false);;
        });
