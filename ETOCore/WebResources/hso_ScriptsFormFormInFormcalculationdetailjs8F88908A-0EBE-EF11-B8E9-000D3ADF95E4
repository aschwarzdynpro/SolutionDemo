                formContext.getControl("hso_billofmaterial_projectproductid").addCustomFilter(ProjectProductFilter);
                break;
            case 100000002: // Project Type 'Festpreis'
                var ProjectProductFilter = "<filter type='and'><condition attribute='hso_isbillofmaterials' operator='eq' value='1'/><condition attribute='hso_projecttype' operator='eq' value='100000002'/></filter>";
                formContext.getControl("hso_billofmaterial_projectproductid").addCustomFilter(ProjectProductFilter);
                break;
        }
    } else { var ProjectProductFilter = "<filter type='and'><condition attribute='hso_name' operator='eq' value='JSFilterBlankProjectProductFilterTESTJS'/></filter>"; };
    formContext.getControl("hso_billofmaterial_projectproductid").addCustomFilter(ProjectProductFilter);
