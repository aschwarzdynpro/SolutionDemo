      "triggers": {
        "If_a_time_report_has_been_created": {
          "type": "OpenApiConnectionWebhook",
          "inputs": {
            "parameters": {
              "subscriptionRequest/message": 1,
              "subscriptionRequest/entityname": "hso_timereports",
              "subscriptionRequest/scope": 4
            },
            "host": {
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
              "operationId": "SubscribeWebhookTrigger",
              "connectionName": "shared_commondataserviceforapps-1"
            }
          },
          "metadata": {
            "operationMetadataId": "5a3f7a25-aac5-4be8-a729-4d8c743f6692"
          }
        }
      },
      "actions": {
        "Get_first_time_entry": {
          "type": "OpenApiConnection",
          "inputs": {
            "parameters": {
              "entityName": "hso_roundedtimeentrieses",
              "fetchXml": "<fetch>\n    <entity name=\"hso_roundedtimeentries\">\n        <attribute name=\"hso_name\" />\n        <attribute name=\"statecode\" />\n        <attribute name=\"hso_roundedtimeentriesid\" />\n        <attribute name=\"hso_workorder\" />\n        <attribute name=\"hso_timereport\" />\n        <attribute name=\"hso_description_txt\" />\n        <attribute name=\"hso_project_id\" />\n        <filter type=\"and\">\n            <condition attribute=\"hso_timereport\" operator=\"eq\"\n                value=\"{@{triggerOutputs()?['body/hso_timereportsid']}}\" />\n        </filter>\n        <link-entity name=\"msdyn_workorder\" from=\"msdyn_workorderid\" to=\"hso_workorder\"\n            link-type=\"outer\" alias=\"WorkOrderNummerr\" visible=\"false\">\n            <attribute name=\"msdyn_name\" />\n        </link-entity>\n    </entity>\n</fetch>",
              "$top": 1
            },
            "host": {
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
              "operationId": "ListRecords",
              "connectionName": "shared_commondataserviceforapps-1"
            }
          },
          "runAfter": {},
          "metadata": {
            "operationMetadataId": "27cb2a53-6a8a-46b1-a12b-4c84cb945607"
          }
        },
        "Compose": {
          "type": "Compose",
          "inputs": "@outputs('Get_first_time_entry')?['body/value']",
          "runAfter": {
            "Get_first_time_entry": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "62016bcd-3c41-4e5f-b762-0130533348b7"
          }
        },
        "Set_project_and_work_order": {
          "type": "OpenApiConnection",
          "inputs": {
            "parameters": {
              "entityName": "hso_timereportses",
              "recordId": "@triggerOutputs()?['body/hso_timereportsid']",
              "item/hso_name": "AZN für @{First(outputs('Get_first_time_entry')?['body/value'])?['WorkOrderNummerr.msdyn_name']} vom @{formatDateTime(parseDateTime(triggerOutputs()?['body/createdon'], 'de-DE', 'yyyy''-''MM''-''dd''T''HH'':''mm'':''ss''Z'''), 'dd.MM.yyyy', 'de-DE')}",
              "item/hso_Projekt@odata.bind": "msdyn_projects(@{first(outputs('Get_first_time_entry')?['body/value'])?['_hso_project_id_value']})",
              "item/hso_workorder_ref@odata.bind": "msdyn_workorders(@{first(outputs('Get_first_time_entry')?['body/value'])?['_hso_workorder_value']})"
            },
            "host": {
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
              "operationId": "UpdateRecord",
              "connectionName": "shared_commondataserviceforapps-1"
            }
          },
          "runAfter": {
            "Compose": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "e76b858d-6e38-4e67-9b1d-209ca6ffefb9"
          }
        }
      }
    },
    "templateName": null
