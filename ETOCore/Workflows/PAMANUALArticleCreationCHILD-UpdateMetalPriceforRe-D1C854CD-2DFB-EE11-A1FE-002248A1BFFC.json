                        "authentication": {
                          "type": "ActiveDirectoryOAuth",
                          "tenant": "@triggerBody()['text']",
                          "audience": "https://@{parameters('EnvVar | Unified Operations Instance (hso_EnvVarUnifiedOperationsInstance)')}/",
