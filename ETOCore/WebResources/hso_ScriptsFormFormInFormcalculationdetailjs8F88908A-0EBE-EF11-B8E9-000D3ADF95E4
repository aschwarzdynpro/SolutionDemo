// Generic function to show a specific Tab
// Function called by other functions from within this library
function showTab(formContext, fieldName) {
    formContext.ui.tabs.get(fieldName).setDisabled(true);
};

// Generic function to hide a specific Tab
// Function called by other functions from within this library
function hideTab(formContext, fieldName) {
    formContext.ui.tabs.get(fieldName).setDisabled(false);
};
