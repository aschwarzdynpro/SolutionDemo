{
  "properties": {
    "connectionReferences": {
      "shared_commondataserviceforapps_1": {
        "runtimeSource": "embedded",
        "connection": {
          "connectionReferenceLogicalName": "sst_CRDataverse"
        },
        "api": {
          "name": "shared_commondataserviceforapps"
        }
      },
      "shared_teams": {
        "runtimeSource": "embedded",
        "connection": {
          "connectionReferenceLogicalName": "hso_ConRefTeamsArticlesearch"
        },
        "api": {
          "name": "shared_teams"
        }
      }
    },
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "parameters": {
        "$connections": {
          "defaultValue": {},
          "type": "Object"
        },
        "$authentication": {
          "defaultValue": {},
          "type": "SecureObject"
        }
      },
      "triggers": {
        "manual": {
          "metadata": {
            "operationMetadataId": "6f9fc6cd-662a-4cc3-99e3-dce401f49767"
          },
          "type": "Request",
          "kind": "Button",
          "inputs": {
            "schema": {
              "type": "object",
              "properties": {
                "text": {
                  "description": "Geben Sie Ihre Eingabe ein.",
                  "title": "Business Event JSON",
                  "type": "string",
                  "x-ms-content-hint": "TEXT",
                  "x-ms-dynamically-added": true
                }
              },
              "required": [
                "text"
              ]
            }
          }
        }
      },
      "actions": {
        "Parse_JSON": {
          "runAfter": {},
          "metadata": {
            "operationMetadataId": "bd057cdf-1de7-435e-934c-099ee6cdbc1c"
          },
          "type": "ParseJson",
          "inputs": {
            "content": "@triggerBody()?['text']",
            "schema": {
              "type": "object",
              "properties": {
                "BusinessEventId": {
                  "type": "string"
                },
                "BusinessEventLegalEntity": {
                  "type": "string"
                },
                "ContextRecId": {
                  "type": "integer"
                },
                "ContextRecordSubject": {
                  "type": "string"
                },
                "ControlNumber": {
                  "type": "integer"
                },
                "ElementId": {
                  "type": "string"
                },
                "ElementName": {
                  "type": "string"
                },
                "ElementType": {
                  "type": "string"
                },
                "ElementTypeName": {
                  "type": "string"
                },
                "EventCategory": {
                  "type": "string"
                },
                "EventId": {
                  "type": "string"
                },
                "EventTime": {
                  "type": "string"
                },
                "EventTimeIso8601": {
                  "type": "string"
                },
                "InitiatingUserAADObjectId": {
                  "type": "string"
                },
                "MajorVersion": {
                  "type": "integer"
                },
                "MinorVersion": {
                  "type": "integer"
                },
                "OutcomeName": {
                  "type": "string"
                },
                "ParentContextRecordSubjects": {},
                "TaskEventCategory": {
                  "type": "string"
                },
                "WorkflowConfigurationId": {
                  "type": "string"
                },
                "WorkflowCorrelationId": {
                  "type": "string"
                },
                "WorkflowDocument": {
                  "type": "string"
                },
                "WorkflowTemplateName": {
                  "type": "string"
                },
                "Outcomename": {
                  "type": "string"
                }
              }
            }
          }
        },
        "Check_if_Revision_is_approved_or_rejected": {
          "actions": {
            "Get_budget_revision_by_status_null_and_ID": {
              "runAfter": {},
              "metadata": {
                "operationMetadataId": "ffed9077-1f29-4580-9d3f-58fcc9524209"
              },
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "entityName": "sst_projbudgetrevisions",
                  "$filter": "sst_uberarbeitungsstatus eq null and sst_revisionid eq '@{outputs('Get_Project_Budget_Revision_ID')}'"
                },
                "host": {
                  "connectionName": "shared_commondataserviceforapps_1",
                  "operationId": "ListRecords",
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                },
                "authentication": "@parameters('$authentication')"
              }
            },
            "Set_project_budget_revision_to_approve": {
              "runAfter": {
                "Get_budget_revision_by_status_null_and_ID": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "c1f32394-f66f-4e42-b7ab-15aa93759e0f"
              },
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "entityName": "sst_projbudgetrevisions",
                  "recordId": "@first(outputs('Get_budget_revision_by_status_null_and_ID')?['body/value'])?['sst_projbudgetrevisionid']",
                  "item/sst_revisiondate": "@variables('varEventTime')",
                  "item/sst_uberarbeitungsstatus": 0
                },
                "host": {
                  "connectionName": "shared_commondataserviceforapps_1",
                  "operationId": "UpdateRecord",
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                },
                "authentication": "@parameters('$authentication')"
              }
            },
            "Revision_Link": {
              "runAfter": {
                "Get_Email_Address_of_Approver": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "cd748fa5-b188-45fa-8171-c9861f5d7985"
              },
              "type": "Compose",
              "inputs": "<a href=\"@{body('Set_project_budget_revision_to_approve')?['sst_uberarbeitunglink']}\">Web</a>"
            },
            "Teams_Recipient": {
              "runAfter": {
                "Revision_Link": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "ab632cbb-18d6-4d57-8e58-52954021be8d"
              },
              "type": "Compose",
              "inputs": "@first(outputs('Get_Email_Address_of_Approver')?['body/value'])?['internalemailaddress']"
            },
            "Post_Message_to_Applicant": {
              "runAfter": {
                "Teams_Recipient": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "cc7e4200-a0d9-4088-b0d5-b77ffebb5b81"
              },
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "poster": "Flow bot",
                  "location": "Chat with Flow bot",
                  "body/recipient": "@outputs('Teams_Recipient')",
                  "body/messageBody": "<p class=\"editor-paragraph\"><b><strong class=\"editor-text-bold\">Budgetüberarbeitung </strong></b><strong>@{outputs('Set_project_budget_revision_to_approve')?['body/sst_revisionid']}</strong><b><strong class=\"editor-text-bold\"> wurde genehmigt</strong></b><br><br>Hallo @{outputs('Set_project_budget_revision_to_approve')?['body/sst_revisionitemowner']},<br><br>deine Budgetüberarbeitung wurde von @{outputs('Set_project_budget_revision_to_approve')?['body/sst_controler']} genehmigt. Hier findest du die Informationen zu der Budgetüberarbeitung:</p><br><p class=\"editor-paragraph\">@{body('Create_HTML_table_approve')}<br><br>Für weitere Infos: @{outputs('Revision_Link')}</p><br><p class=\"editor-paragraph\"><span style=\"font-size: 10px;\">*Systemgenerierte Nachricht, Fragen und Antworten in diesem Chat werden nicht bearbeitet.</span></p>"
                },
                "host": {
                  "connectionName": "shared_teams",
                  "operationId": "PostMessageToConversation",
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_teams"
                },
                "authentication": "@parameters('$authentication')"
              }
            },
            "Create_HTML_table_approve": {
              "runAfter": {
                "Set_project_budget_revision_to_approve": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "0fb4c960-e1d4-4a8d-8c5c-00fb12a37ed9"
              },
              "type": "Table",
              "inputs": {
                "from": "@array(outputs('Set_project_budget_revision_to_approve')?['body'])",
                "format": "HTML",
                "columns": [
                  {
                    "header": "Projekt",
                    "value": "@outputs('Set_project_budget_revision_to_approve')?['body/sst_foprojectid']"
                  },
                  {
                    "header": "Überarbeitungskennung",
                    "value": "@outputs('Set_project_budget_revision_to_approve')?['body/sst_revisionid']"
                  },
                  {
                    "header": "Anforderungsdatum",
                    "value": "@formatDateTime(convertTimeZone(outputs('Set_project_budget_revision_to_approve')?['body/sst_requesteddate'], 'UTC', 'W. Europe Standard Time'),'dd-MM-yyyy, HH:mm:ss')"
                  },
                  {
                    "header": "Genehmigungsdatum",
                    "value": "@formatDateTime(convertTimeZone(variables('varEventTime'), 'UTC', 'W. Europe Standard Time'),'dd-MM-yyyy, HH:mm:ss')"
                  },
                  {
                    "header": "Kommentar der Anfrage",
                    "value": "@outputs('Set_project_budget_revision_to_approve')?['body/sst_comment']"
                  }
                ]
              }
            },
            "Get_Email_Address_of_Approver": {
              "runAfter": {
                "Create_HTML_table_approve": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "dc7a367a-8dc9-4907-b494-82c7bcef4a5a"
              },
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "entityName": "systemusers",
                  "$select": "internalemailaddress",
                  "$filter": "fullname eq '@{first(outputs('Get_budget_revision_by_status_null_and_ID')?['body/value'])?['sst_revisionitemowner']}'"
                },
                "host": {
                  "connectionName": "shared_commondataserviceforapps_1",
                  "operationId": "ListRecords",
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                },
                "authentication": "@parameters('$authentication')"
              }
            },
            "Respond_to_Parent_Flow_-_Approved": {
              "runAfter": {
                "Post_Message_to_Applicant": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "5d5ae8ff-547f-4cdc-ba47-d388df5dfa29"
              },
              "type": "Response",
              "kind": "PowerApp",
              "inputs": {
                "statusCode": 200,
                "body": {
                  "result": "Success"
                },
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "title": "Result",
                      "x-ms-dynamically-added": true,
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "runAfter": {
            "varEventTime": [
              "Succeeded"
            ]
          },
          "else": {
            "actions": {
              "Cancel_due_to_Revision_being_rejected": {
                "runAfter": {
                  "Respond_to_Parent_Flow_-_Cancel": [
                    "Succeeded"
                  ]
                },
                "metadata": {
                  "operationMetadataId": "03c68b63-1381-4259-b224-e077b4703cdd"
                },
                "type": "Terminate",
                "inputs": {
                  "runStatus": "Cancelled"
                }
              },
              "Respond_to_Parent_Flow_-_Cancel": {
                "runAfter": {},
                "metadata": {
                  "operationMetadataId": "5c5b5b7c-e59b-4a03-ad89-effdd95cb24d"
                },
                "type": "Response",
                "kind": "PowerApp",
                "inputs": {
                  "statusCode": 200,
                  "body": {
                    "result": "Sucess"
                  },
                  "schema": {
                    "type": "object",
                    "properties": {
                      "result": {
                        "title": "Result",
                        "x-ms-dynamically-added": true,
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "expression": {
            "and": [
              {
                "equals": [
                  "@body('Parse_JSON')?['OutcomeName']",
                  "Approve"
                ]
              }
            ]
          },
          "metadata": {
            "operationMetadataId": "98badcaf-60d9-48e6-ae48-5aa8ac6b3b13"
          },
          "type": "If"
        },
        "Get_Project_Budget_Revision_ID": {
          "runAfter": {
            "Parse_JSON": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "524eaea9-4bf8-4806-9646-3128148f1136"
          },
          "type": "Compose",
          "inputs": "@trim(split(split(body('Parse_JSON')?['WorkflowDocument'],':')[1],',')[0])"
        },
        "varEventTime": {
          "runAfter": {
            "Get_Project_Budget_Revision_ID": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "f881f84d-2303-4aad-bbfb-16ba7628d73c"
          },
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "varEventTime",
                "type": "string",
                "value": "@formatDateTime(body('Parse_JSON')?['EventTimeIso8601'],'yyyy-MM-ddTHH:mm:ss')"
              }
            ]
          }
        }
      }
    },
    "templateName": ""
  },
  "schemaVersion": "1.0.0.0"
}