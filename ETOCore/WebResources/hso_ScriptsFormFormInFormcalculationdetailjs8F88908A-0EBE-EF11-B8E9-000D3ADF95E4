// Fetch Product that has been selected for a Calculation Position (ARTIKELSTAMM)
// Function called by other function 'onChangeProduct' from within this library
ETO.CalculationPositionForm.retrieveProduct = (formContext, Calculation, SelectedProduct, Language) => {
    // Get Product by selecting fields Name, Surchargegroup Base, Current Cost and expanding Surchargegroup Base to receive Name 
    Xrm.WebApi.retrieveRecord("product", SelectedProduct, "?$select=name,hso_manualmetalsurcharges,description,_defaultuomid_value,_hso_surchargegroup_baseid_value,price,currentcost,_hso_globalproductid_value,hso_basepricewithoutmetalsurcharge,_hso_metallabelid_value,hso_metalbase,hso_metalnumber,_hso_metallabelid_2_value,hso_metalbase_2,hso_metalnumber_2,_hso_metallabelid_3_value,hso_metalbase_3,hso_metalnumber_3&$expand=hso_surchargegroup_baseid($select=hso_name),defaultuomid($select=name),hso_metallabelid($select=hso_name),hso_metallabelid_2($select=hso_name),hso_metallabelid_3($select=hso_name)").then(
        result => {
            // set selected Product Name as default value for Name 
            formContext.getAttribute("hso_name").setValue(result.name);
            // set Surchargegroup Base with Surchargegroup Base set of selected Product
            let SelectedProduct_SurchargeGroupBase = result._hso_surchargegroup_baseid_value;
            // better approach: create object for LookUp -> use object in setValue() (Performance improvement + better debugging possible)
            let SurchargeGroup = [{ id: SelectedProduct_SurchargeGroupBase, name: result.hso_surchargegroup_baseid.hso_name, entityType: "hso_surchargegroup_base" }];
            formContext.getAttribute("hso_surchargegroup_baseid").setValue(SurchargeGroup);
            //formContext.getAttribute("hso_surchargegroup_baseid").setValue([{ id: SelectedProduct_SurchargeGroupBase, name: result.hso_surchargegroup_baseid.hso_name, entityType: "hso_surchargegroup_base" }]);
            // format Surchargegroup Base GUID
            SelectedProduct_SurchargeGroupBase = SelectedProduct_SurchargeGroupBase.replace(/[{}]/g, "");
            // set Global Product and format GUID
            let SelectedProduct_GlobalProduct = result._hso_globalproductid_value;
            SelectedProduct_GlobalProduct = SelectedProduct_GlobalProduct.replace(/[{}]/g, "");
            // Fetch Global Product to set Text Block
            ETO.CalculationPositionForm.retrieveGlobalProduct(formContext, SelectedProduct_GlobalProduct, Language, result.name, result.description, result.price);
            // get the Position Quantity
            let Quantity = formContext.getAttribute("hso_positionquantity").getValue();
            // Get Project Type
            let ProjectType = formContext.getAttribute('hso_projecttype').getValue();
            // set Unit with Unit set of selected Product
            formContext.getAttribute("hso_uomid").setValue([{ id: result._defaultuomid_value, name: result.defaultuomid.name, entityType: "uom" }]);
        }, error => {
            console.log(error.message);
        }
    );
};

