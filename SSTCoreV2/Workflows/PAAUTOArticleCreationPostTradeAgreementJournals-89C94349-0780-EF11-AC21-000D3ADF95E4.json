                      "recordId": "@items('Apply_to_each_related_journal_record')?['hso_articlerequirement_tajournalid']",
                      "item/hso_status_opt": 3
                    },
                    "host": {
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                      "operationId": "UpdateRecord",
                      "connectionName": "shared_commondataserviceforapps-1"
                    }
                  }
                },
                "Update_status_of_trade_agreement_record_on_success": {
                  "runAfter": {
