//This script is set up in the ribbon bar of catalogue import jobs.
//Reads the current value of the relevant environment variable and opens the link to the target.
//Target: Blob container for XML and Excel Import

if (typeof (hso) === "undefined") { hso = {}; };
if (typeof (hso.CatalogueImportRibbon) === "undefined") { hso.CatalogueImportRibbon = {}; }


 hso.CatalogueImportRibbon.OpenBlob = () =>
 {
 
    var definitionSchemaName = "hso_EnvVarArticlesearchBlobLink"; //logical name of environment variable
    var BaseURL = "https://portal.azure.com/#view/Microsoft_Azure_Storage/ContainerMenuBlade/~/overview/";
 
    var req = {};
    req.DefinitionSchemaName = definitionSchemaName;
    req.getMetadata = function () {
        return {
            boundParameter: null,
            parameterTypes: {
                "DefinitionSchemaName": {
                    "typeName": "Edm.String",
                    "structuralProperty": 1
                }
            },
         operationType: 1,
         operationName: "RetrieveEnvironmentVariableValue"
        };
    };
 
    Xrm.WebApi.online.execute(req).then( 
        function success(result) {
            if (result.ok) {
                result.json().then(
                    function (responseBody) {
                        console.log("Hyperlink to Blob: " + BaseURL + responseBody.Value);
                        window.open(BaseURL + responseBody.Value, '_blank').focus();
                                 
                    });
            }
        },
        function (error) {
            Xrm.Utility.alertDialog(error.message);
        });
}



