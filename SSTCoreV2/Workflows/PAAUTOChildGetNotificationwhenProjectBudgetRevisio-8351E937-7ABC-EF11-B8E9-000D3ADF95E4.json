                "ElementName": {
                  "type": "string"
                },
                "ElementType": {
                  "type": "string"
                },
                "ElementTypeName": {
                  "type": "string"
                },
                "EventCategory": {
                  "type": "string"
                },
                "EventId": {
                  "type": "string"
                },
                "EventTime": {
                  "type": "string"
                },
                "EventTimeIso8601": {
                  "type": "string"
                },
                "InitiatingUserAADObjectId": {
                  "type": "string"
                },
                "MajorVersion": {
                  "type": "integer"
                },
                "MinorVersion": {
                  "type": "integer"
                },
                "OutcomeName": {
                  "type": "string"
                },
                "ParentContextRecordSubjects": {},
                "TaskEventCategory": {
                  "type": "string"
                },
                "WorkflowConfigurationId": {
                  "type": "string"
                },
                "WorkflowCorrelationId": {
                  "type": "string"
                },
                "WorkflowDocument": {
                  "type": "string"
                },
                "WorkflowTemplateName": {
                  "type": "string"
                },
                "WorkflowLastActionUser": {
