    } else { hideField(formContext, 'header_hso_calculationmetalpriceid'); };
    if (formContext.getAttribute("hso_calculationmetalpriceid_2").getValue() != null) {
        showField(formContext, 'header_hso_calculationmetalpriceid_2');
    } else { hideField(formContext, 'header_hso_calculationmetalpriceid_2'); };
    if (formContext.getAttribute("hso_calculationmetalpriceid_3").getValue() != null) {
        showField(formContext, 'header_hso_calculationmetalpriceid_3');
    } else { hideField(formContext, 'header_hso_calculationmetalpriceid_3'); };
    // switch on Element Type to show / hide fields
    if (Status == 0) {
        switch (ElementType) {
            case 100000006: //Position Element Type 'Title'
                disableField(formContext, 'hso_costpriceperunit');
                break;
            /*  case 100000009: // Position Element Type 'BOM'
                  disableField(formContext, 'hso_costpriceperunit');
                  break;*/
            case 100000000: // Position Element Type 'Product'
                enableField(formContext, 'hso_costpriceperunit');
                break;
            case 100000002: // Position Element Type 'Project Product'
                enableField(formContext, 'hso_costpriceperunit');
                break;
            case 100000003: // Position Element Type 'Production Hour'
                enableField(formContext, 'hso_costpriceperunit');
                break;
            case 100000004: // Position Element Type 'Project Hour'
                enableField(formContext, 'hso_costpriceperunit');
                break;
            case 100000007: // Position Element Type 'Project Expense'
                enableField(formContext, 'hso_costpriceperunit');
                break;
            case 100000008: // Position Element Type 'External Service'
                enableField(formContext, 'hso_costpriceperunit');
                break;
            case 100000010: // Position Element Type 'Hinweistext'
                formContext.ui.tabs.get("details_tab").setVisible(false);
                formContext.ui.tabs.get("notes_tab").setVisible(false);
                break;
        };
    };
    Schulz.CalculationPositionForm.setVisibilityForNonGaebPositions(formContext); // Call the Function to show/hide several Price Component Fields for Non-Gaeb-Positions dependent on Price Component Breakdown
