// Fetch Product that has been selected for a Calculation Position (ARTIKELSTAMM)
// Function called by other function 'onChangeProduct' from within this library
ETO.CalculationPositionForm.retrieveProduct = (formContext, Calculation, SelectedProduct, Language) => {
    // Get Product by selecting fields Name, Surchargegroup Base, Current Cost and expanding Surchargegroup Base to receive Name 
    Xrm.WebApi.retrieveRecord("product", SelectedProduct, "?$select=name,hso_manualmetalsurcharges,description,_defaultuomid_value,_hso_surchargegroup_baseid_value,price,currentcost,_hso_globalproductid_value,hso_basepricewithoutmetalsurcharge,_hso_metallabelid_value,_hso_metallabelid_2_value,_hso_metallabelid_3_value&$expand=hso_surchargegroup_baseid($select=hso_name),defaultuomid($select=name)").then(
        result => {
            // set selected Product Name as default value for Name 
            formContext.getAttribute("hso_name").setValue(result.name);
            // set Surchargegroup Base with Surchargegroup Base set of selected Product
            let SelectedProduct_SurchargeGroupBase = result._hso_surchargegroup_baseid_value;
            // better approach: create object for LookUp -> use object in setValue() (Performance improvement + better debugging possible)
            let SurchargeGroup = [{ id: SelectedProduct_SurchargeGroupBase, name: result.hso_surchargegroup_baseid.hso_name, entityType: "hso_surchargegroup_base" }];
            formContext.getAttribute("hso_surchargegroup_baseid").setValue(SurchargeGroup);
            //formContext.getAttribute("hso_surchargegroup_baseid").setValue([{ id: SelectedProduct_SurchargeGroupBase, name: result.hso_surchargegroup_baseid.hso_name, entityType: "hso_surchargegroup_base" }]);
            // format Surchargegroup Base GUID
            SelectedProduct_SurchargeGroupBase = SelectedProduct_SurchargeGroupBase.replace(/[{}]/g, "");
            // set Global Product and format GUID
            let SelectedProduct_GlobalProduct = result._hso_globalproductid_value;
            SelectedProduct_GlobalProduct = SelectedProduct_GlobalProduct.replace(/[{}]/g, "");
            // Fetch Global Product to set Text Block
            ETO.CalculationPositionForm.retrieveGlobalProduct(formContext, SelectedProduct_GlobalProduct, Language, result.name, result.description, result.price);
            // set Unit with Unit set of selected Product
            formContext.getAttribute("hso_uomid").setValue([{ id: result._defaultuomid_value, name: result.defaultuomid.name, entityType: "uom" }]);
            // Check Metalsurcharges that need to be calculated
            var calculateMetalSurcharges = "";
            if (result._hso_metallabelid_value != null | result._hso_metallabelid_2_value != null | result._hso_metallabelid_3_value != null) {
                calculateMetalSurcharges = true;
                console.log("Metal Surcharges to be calculated!");
            } else {
                calculateMetalSurcharges = false;
                console.log("No Metals assigned to Product");
            };
            // set Cost Price per Unit by iterating through multiple validation steps
            if(result.hso_manualmetalsurcharges == true) {
                // set initial Cost Price per Unit to Current Cost if manual metalsurcharges are set to true
                formContext.getAttribute("hso_costpriceperunit").setValue(result.currentcost);
                console.log("Cost Price per Unit set to Products current costs");
            } else if (result.hso_manualmetalsurcharges == false && calculateMetalSurcharges == true) {
                // set Base Price without Metalsurcharges to Base Price without Metalsurcharges if manual metalsurcharges are set to false but Metals are assigned to the Product
                // Cost Price per Unit is calculated by adding the required Metalsurcharges to the Base Price without Metal Surcharges
                formContext.getAttribute("hso_product_basepricewithoutmetalsurcharge").setValue(result.hso_basepricewithoutmetalsurcharge);
                console.log("Base Price without Metalsurcharges set to Products base price without metalsurcharges");
                // show Base Price without Metalsurcharges
                showField(formContext, 'hso_product_basepricewithoutmetalsurcharge');
                // hide Cost Price per Unit
                hideField(formContext, 'hso_costpriceperunit');
            } else if (result.hso_manualmetalsurcharges == false && calculateMetalSurcharges == false) {
                // set initial Cost Price per Unit to Base Price without Metalsurcharges if manual metalsurcharges are set to false and no Metals are assigned to the Product
                formContext.getAttribute("hso_costpriceperunit").setValue(result.hso_basepricewithoutmetalsurcharge);
                console.log("Cost Price per Unit set to Products base price without metalsurcharges");
            };
        }, error => {
            console.log(error.message);
        }
    );
};

