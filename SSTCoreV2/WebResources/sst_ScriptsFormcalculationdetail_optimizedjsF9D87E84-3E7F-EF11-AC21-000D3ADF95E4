// Fetch Calculation Metal Prices for Metal Label retrieved from selected Item to set Metal Price related information and calculate Metal Surcharge for a Calculation Position
// Function called by other functions (RetrieveProduct / RetrieveProjectProduct) from within this library
Schulz.CalculationPositionForm.retrieveCalculationMetalPrices = (formContext, Calculation, SelectedProduct_MetalLabel, SelectedProduct_MetalNumber, SelectedProduct_MetalBase, SelectedProduct_BasePriceWithoutMetalSurcharge, AssignedMetalNumber, FirstMetalSurchargePerUnit, SecondMetalSurchargePerUnit, ThirdMetalSurchargePerUnit, formTypeProjectProduct) => {
    return new Promise(function (resolve, reject) {
        // Search for fitting Calculation Metal Price
        Xrm.WebApi.retrieveMultipleRecords("hso_calculationmetalprice", "?$select=hso_calculationmetalpriceid,hso_name,hso_currentcost,hso_currentcost_converted_calc,hso_purchasecostpercentage,hso_quantity&$filter=_hso_calculationid_value eq '" + Calculation + "' and _hso_metallabelid_value eq '" + SelectedProduct_MetalLabel + "'").then(
            result => {
                for (var i = 0; i < result.entities.length; i++) {
                };
                if (result != null) {
                    let CalculationMetalPrice = result.entities[0].hso_calculationmetalpriceid;
                    let CalculationMetalPrice_Name = result.entities[0].hso_name;
                    let CalculationMetalPrice_Quantity = result.entities[0].hso_quantity;
                    let CalculationMetalPrice_CurrentCost = result.entities[0].hso_currentcost_converted_calc;
                    let CalculationMetalPrice_PurchaseCostPercentage = result.entities[0].hso_purchasecostpercentage;
                    if (AssignedMetalNumber == 1) {
                        // set Calculation Metal Price with Calculation Metal Price found based on Product Metal Label
                        formContext.getAttribute("hso_calculationmetalpriceid").setValue([{ id: CalculationMetalPrice, name: CalculationMetalPrice_Name, entityType: "hso_calculationmetalprice" }]);

                        // calculate Metal Surcharge per Unit
                        var CalculatedMetalSurchargePerUnit = SelectedProduct_MetalNumber * ((CalculationMetalPrice_CurrentCost * (1 + CalculationMetalPrice_PurchaseCostPercentage / 100) - (100 * SelectedProduct_MetalBase)) / 100) // CalculationMetalPrice_Quantity)
                        // set calculated Metal Surcharge per Unit
                        formContext.getAttribute("hso_product_metalsurchargeperunit").setValue(CalculatedMetalSurchargePerUnit);
                        // calculate Cost Price per Unit
                        let CalculatedCostPricePerUnit = SelectedProduct_BasePriceWithoutMetalSurcharge + CalculatedMetalSurchargePerUnit
                        // set Cost Price per Unit with Calculated Cost Price per Unit based on Metal Price
                        formContext.getAttribute("hso_costpriceperunit").setValue(CalculatedCostPricePerUnit);
                    } else if (AssignedMetalNumber == 2) {
                        // set Calculation Metal Price with Calculation Metal Price found based on Product Metal Label
                        formContext.getAttribute("hso_calculationmetalpriceid_2").setValue([{ id: CalculationMetalPrice, name: CalculationMetalPrice_Name, entityType: "hso_calculationmetalprice" }]);
                        // calculate Metal Surcharge per Unit
                        var CalculatedMetalSurchargePerUnit = SelectedProduct_MetalNumber * ((CalculationMetalPrice_CurrentCost * (1 + CalculationMetalPrice_PurchaseCostPercentage / 100) - (100 * SelectedProduct_MetalBase)) / 100)// CalculationMetalPrice_Quantity)
                        // set calculated Metal Surcharge per Unit
                        formContext.getAttribute("hso_product_metalsurchargeperunit_2").setValue(CalculatedMetalSurchargePerUnit);
                        // calculate Cost Price per Unit
                        let CalculatedCostPricePerUnit = SelectedProduct_BasePriceWithoutMetalSurcharge + FirstMetalSurchargePerUnit + CalculatedMetalSurchargePerUnit
                        // set Cost Price per Unit with Calculated Cost Price per Unit based on Metal Price
                        formContext.getAttribute("hso_costpriceperunit").setValue(CalculatedCostPricePerUnit);
                    } else if (AssignedMetalNumber == 3) {
                        // set Calculation Metal Price with Calculation Metal Price found based on Product Metal Label
                        formContext.getAttribute("hso_calculationmetalpriceid_3").setValue([{ id: CalculationMetalPrice, name: CalculationMetalPrice_Name, entityType: "hso_calculationmetalprice" }]);
                        // calculate Metal Surcharge per Unit
                        var CalculatedMetalSurchargePerUnit = SelectedProduct_MetalNumber * ((CalculationMetalPrice_CurrentCost * (1 + CalculationMetalPrice_PurchaseCostPercentage / 100) - (100 * SelectedProduct_MetalBase)) / 100) // CalculationMetalPrice_Quantity)
                        // set calculated Metal Surcharge per Unit
                        formContext.getAttribute("hso_product_metalsurchargeperunit_3").setValue(CalculatedMetalSurchargePerUnit);
                        // calculate Cost Price per Unit
                        let CalculatedCostPricePerUnit = SelectedProduct_BasePriceWithoutMetalSurcharge + FirstMetalSurchargePerUnit + SecondMetalSurchargePerUnit + CalculatedMetalSurchargePerUnit
                        // set Cost Price per Unit with Calculated Cost Price per Unit based on Metal Price
                        formContext.getAttribute("hso_costpriceperunit").setValue(CalculatedCostPricePerUnit);
                    };
                    // get the Position Quantity
                    let Quantity = formContext.getAttribute("hso_positionquantity").getValue();
                    // proceed with the calculation of the Cost Price
                    Schulz.CalculationPositionForm.calculateCostPrice(formContext, Quantity, "retrieveCalculationMetalPrices");
                    // show required Metal Fields
                    Schulz.CalculationPositionForm.setFieldVisibility_Metallabels(formContext);
                    resolve(CalculatedMetalSurchargePerUnit);
                }
            },
            error => {
                reject(error);
            });
    })
};

