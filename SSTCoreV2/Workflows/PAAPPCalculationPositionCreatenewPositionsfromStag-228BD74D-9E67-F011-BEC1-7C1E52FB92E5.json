        "Process_Payload": {
          "type": "Scope",
          "actions": {
            "Append_Calculation_Positions_to_process_to_Log": {
              "type": "AppendToStringVariable",
              "inputs": {
                "name": "varLog",
                "value": "[INF] - [@{utcNow()}] - @{variables('varNumberOfRecords')} Calculation Positions to create. @{decodeUriComponent('%0A')}"
              }
            },
            "Append_processed_Calculation_Positions_to_Log": {
              "type": "AppendToStringVariable",
              "inputs": {
                "name": "varLog",
                "value": "[INF] - [@{utcNow()}] - @{variables('varNumberOfRecords')} Calculation Positions created. @{decodeUriComponent('%0A')}"
              },
              "runAfter": {
                "Do_until_all_Levels_are_processed": [
                  "Succeeded"
                ]
              }
            },
            "Do_until_all_Levels_are_processed": {
              "type": "Until",
              "expression": "@equals(variables('varIterationLevel'),add(\r\n  max(variables('varProcessingLevels')), \r\n  1\r\n))",
              "limit": {
                "count": 60,
                "timeout": "PT1H"
              },
              "actions": {
                "Filter_Payload_by_Level": {
                  "type": "Query",
                  "inputs": {
                    "from": "@body('Remove_Overrides_from_JSON')",
                    "where": "@equals(item()['hso_level'],variables('varIterationLevel'))"
                  }
                },
                "Calculate_Parallelism": {
                  "type": "Compose",
                  "inputs": "@min(\r\n  max(\r\n    div(\r\n      length(body('Filter_Payload_by_Level')),\r\n      variables('varBatchSettings')?['maxBatchSize']\r\n    ),\r\n    variables('varBatchSettings')?['minBatchSize']\r\n  ),\r\n  variables('varBatchSettings')?['maxParallelism']\r\n)",
                  "runAfter": {
                    "Filter_Payload_by_Level": [
                      "Succeeded"
                    ]
                  }
                },
                "Calculate_Batch_Size": {
                  "type": "Compose",
                  "inputs": "@add(\r\n  div(\r\n    length(body('Filter_Payload_by_Level')), \r\n    outputs('Calculate_Parallelism')\r\n  ), \r\n  if(\r\n    greaterOrEquals(\r\n      mod(\r\n        length(body('Filter_Payload_by_Level')),\r\n        outputs('Calculate_Parallelism')\r\n      ),\r\n      1\r\n    ), \r\n    1, \r\n    0\r\n  )\r\n)\r\n",
                  "runAfter": {
                    "Calculate_Parallelism": [
                      "Succeeded"
                    ]
                  }
                },
                "Split_Records_into_Chunks": {
                  "type": "Compose",
                  "inputs": "@chunk(\r\n  body('Filter_Payload_by_Level'),\r\n  outputs('Calculate_Batch_Size')\r\n)",
                  "runAfter": {
                    "Calculate_Batch_Size": [
                      "Succeeded"
                    ]
                  }
                },
                "Apply_to_each_Chunk": {
                  "type": "Foreach",
                  "foreach": "@outputs('Split_Records_into_Chunks')",
                  "actions": {
                    "Items_to_process": {
                      "type": "Compose",
                      "inputs": "@items('Apply_to_each_Chunk')"
                    },
                    "Create_Calculation_Positions_by_Level": {
                      "type": "OpenApiConnection",
                      "inputs": {
                        "parameters": {
                          "request/method": "POST",
                          "request/url": "https://@{parameters('EnvVar | Dataverse Instance (hso_EnvVarDataverseInstance)')}/api/data/v9.2/hso_calculationdetails/Microsoft.Dynamics.CRM.CreateMultiple",
                          "request/headers": {
                            "OData-MaxVersion": "4.0",
                            "OData-Version": "4.0",
                            "If-None-Match": "null",
                            "Accept": "application/json",
                            "Content-Type": "application/json; charset=utf-8",
                            "MSCRM.BypassCustomPluginExecution": "true",
                            "MSCRM.SuppressDuplicateDetection": "true",
                            "MSCRM.BypassBusinessLogicExecution": "CustomSync,CustomAsync",
                            "MSCRM.SuppressCallbackRegistrationExpanderJob": "true"
                          },
                          "request/body": "{\n \"Targets\": @{items('Apply_to_each_Chunk')}\n}"
                        },
                        "host": {
                          "apiId": "/providers/Microsoft.PowerApps/apis/shared_webcontents",
                          "operationId": "InvokeHttp",
                          "connectionName": "shared_webcontents"
                        }
                      },
                      "runAfter": {
                        "Items_to_process": [
                          "Succeeded"
                        ]
                      }
                    }
                  },
                  "runAfter": {
                    "Append_processing_Level_to_Log": [
                      "Succeeded"
                    ]
                  },
                  "runtimeConfiguration": {
                    "concurrency": {
                      "repetitions": 20
                    }
                  }
                },
                "Increment_varIterationLevel_by_1": {
                  "type": "IncrementVariable",
                  "inputs": {
                    "name": "varIterationLevel",
                    "value": 1
                  },
                  "runAfter": {
                    "Apply_to_each_Chunk": [
                      "Succeeded"
                    ]
                  }
                },
                "Append_processing_Level_to_Log": {
                  "type": "AppendToStringVariable",
                  "inputs": {
                    "name": "varLog",
                    "value": "[INF] - [@{utcNow()}] - Process @{length(body('Filter_Payload_by_Level'))} Level-@{variables('varIterationLevel')} Items with @{outputs('Calculate_Parallelism')} Batch(es) (Batch Size: @{outputs('Calculate_Batch_Size')}). @{decodeUriComponent('%0A')}"
                  },
                  "runAfter": {
                    "Split_Records_into_Chunks": [
                      "Succeeded"
                    ]
                  }
                }
              },
              "runAfter": {
                "Remove_Overrides_from_JSON": [
                  "Succeeded"
                ]
              }
            },
            "Remove_Overrides_from_JSON": {
              "type": "Select",
              "inputs": {
                "from": "@body('Parse_JSON')",
                "select": "@removeProperty(item(), 'Overrides')"
              },
              "runAfter": {
                "Append_Calculation_Positions_to_process_to_Log": [
                  "Succeeded"
                ]
              }
            }
          },
          "runAfter": {
