                      "metadata": {
                        "operationMetadataId": "413941d6-35c1-4448-a1c6-569a77f690b1"
                      },
                      "type": "AppendToArrayVariable",
                      "inputs": {
                        "name": "arrNewPrices",
                        "value": "@body('Update_prices')"
                      }
                    },
                    "Append_to_ResponseMessage": {
                      "runAfter": {
                        "Update_prices": [
                          "Failed",
                          "TimedOut"
                        ]
                      },
                      "metadata": {
                        "operationMetadataId": "1ed15260-809c-467b-96b5-e355b502539a"
