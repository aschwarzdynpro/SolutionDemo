<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>README</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fluentui/web-components/dist/esm/index.css">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 20px;
            background-color: #f3f2f1;
        }
        .code-container {
            background-color: #ffffff;
            border: 1px solid #d2d0ce;
            border-radius: 4px;
            padding: 16px;
            overflow-x: auto;
            box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.2);
        }
        code {
            font-family: Consolas, "Courier New", monospace;
            color: #3b3a39;
            white-space: pre-wrap;
        }
    </style>
</head>
<body>
    <h1>README</h1>
    <div class="code-container">
        <code>
            // Harmonize different language keys! German can for example be "de" and "de-DE" - this will transform it to a uniform schema - e.g. "DE"<br>
            nfAppLanguage = Switch(<br>
                &nbsp;&nbsp;Language(),<br>
                &nbsp;&nbsp;"de-DE", // Language()<br>
                &nbsp;&nbsp;"DE",    // Set language<br>
                &nbsp;&nbsp;"de",    // Language()<br>
                &nbsp;&nbsp;"DE",    // Set language<br>
                &nbsp;&nbsp;"EN"     // Fallback<br>
            );<br>
            <br>
            // Fetch Display String, if not found display key.<br>
            With(<br>
                &nbsp;&nbsp;{_key: "lblItemNumber"},<br>
                &nbsp;&nbsp;Coalesce(<br>
                    &nbsp;&nbsp;&nbsp;&nbsp;LookUp(<br>
                        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;'App Translations',<br>
                        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Key = _key And 'App Language'.Code = nfAppLanguage,<br>
                        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Translation<br>
                    ),<br>
                    &nbsp;&nbsp;&nbsp;&nbsp;_key<br>
                )<br>
            )
        </code>
    </div>
</body>
</html>