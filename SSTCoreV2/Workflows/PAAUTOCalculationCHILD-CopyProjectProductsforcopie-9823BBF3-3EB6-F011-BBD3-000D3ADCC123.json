        "Calculation_Project_Products": {
          "actions": {
            "Get_Calculation_Project_Products": {
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "entityName": "hso_projectproducts",
                  "$select": "hso_name,hso_description,hso_costprice,_hso_uomid_value,_hso_metallabelid_value,hso_metalbase,hso_metalnumber,_hso_metallabelid_2_value,hso_metalbase_2,hso_metalnumber_2,_hso_metallabelid_3_value,hso_metalbase_3,hso_metalnumber_3,hso_basepricewithoutmetalsurcharge,_hso_surchargegroup_baseid_value,_hso_manufacturer_id_value,hso_productnumber_manufacturer,hso_typenumber_manufacturer,hso_suppliercatalogreference,hso_productnumber_supplier,hso_manufacturer_name,hso_europeanarticlenumber,hso_isbillofmaterials,hso_projecttype",
                  "$filter": "_hso_calculationid_value eq '@{triggerBody()?['text_1']}'",
                  "$expand": "hso_textblock_hso_projectproduct($select=hso_name, hso_description, hso_language)"
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                  "operationId": "ListRecords",
                  "connectionName": "shared_commondataserviceforapps"
                }
              }
            },
            "Project_Products_to_process": {
              "runAfter": {
                "Get_Calculation_Project_Products": [
                  "Succeeded"
                ]
              },
              "type": "Compose",
              "inputs": "@setProperty(\r\n  variables('varProjectProduct_Parameters'),\r\n  'ProjectProductsToProcess',\r\n  length(outputs('Get_Calculation_Project_Products')?['body/value'])\r\n)"
            },
            "Project_Products_to_copy": {
              "actions": {
                "Copy_Calculation_Project_Products": {
                  "actions": {
                    "Create_Calculation_Project_Products": {
                      "runAfter": {
                        "Remove_NumberOfTextBlocks_from_Payload": [
                          "Succeeded"
                        ]
                      },
                      "metadata": {
                        "operationMetadataId": "e97a7bc8-3487-48b1-b52c-4e7862965a44"
                      },
                      "type": "OpenApiConnection",
                      "inputs": {
                        "parameters": {
                          "request/method": "POST",
                          "request/url": "https://@{parameters('EnvVar | Dataverse Instance (hso_EnvVarDataverseInstance)')}/api/data/v9.2/hso_projectproducts/Microsoft.Dynamics.CRM.CreateMultiple",
                          "request/headers": {
                            "OData-MaxVersion": "4.0",
                            "OData-Version": "4.0",
                            "If-None-Match": "null",
                            "Accept": "application/json",
                            "Content-Type": "application/json; charset=utf-8"
                          },
                          "request/body": "{\n \"Targets\": @{body('Remove_NumberOfTextBlocks_from_Payload')}\n}"
                        },
                        "host": {
                          "apiId": "/providers/Microsoft.PowerApps/apis/shared_webcontents",
                          "operationId": "InvokeHttp",
                          "connectionName": "shared_webcontents"
                        }
                      }
                    },
                    "Project_Products_processed": {
                      "runAfter": {
                        "Create_Calculation_Project_Products": [
                          "Succeeded"
                        ]
                      },
                      "type": "Compose",
                      "inputs": "@setProperty(\r\n  variables('varProjectProduct_Parameters'),\r\n  'ProjectProductsProcessed',\r\n  length(body('Create_Calculation_Project_Products')?['Ids'])\r\n)"
                    },
                    "Update_Project_Products_processed": {
                      "runAfter": {
                        "Project_Products_processed": [
                          "Succeeded"
                        ]
                      },
                      "type": "SetVariable",
                      "inputs": {
                        "name": "varProjectProduct_Parameters",
                        "value": "@outputs('Project_Products_processed')"
                      }
                    },
                    "Append_Calculation_Project_Products_to_Log_[Success]": {
                      "runAfter": {
                        "Update_Project_Products_processed": [
                          "Succeeded"
                        ]
                      },
                      "type": "AppendToStringVariable",
                      "inputs": {
                        "name": "varLog",
                        "value": "[INF] - [@{utcNow()}] - @{length(body('Create_Calculation_Project_Products')?['Ids'])} of @{length(outputs('Get_Calculation_Project_Products')?['body/value'])} Project Products successfully added to Calculation. @{decodeUriComponent('%0A')}"
                      }
                    },
                    "Apply_to_each_selected_Calculation_Project_Product": {
                      "foreach": "@body('Select_Calculation_Project_Products')",
                      "actions": {
                        "No_Text_Blocks_found": {
                          "actions": {
                            "Append_Project_Product_without_Text_Block_to_Payload": {
                              "type": "AppendToArrayVariable",
                              "inputs": {
                                "name": "varProjectProductPayload",
                                "value": "@items('Apply_to_each_selected_Calculation_Project_Product')"
                              }
                            }
                          },
                          "else": {
                            "actions": {
                              "Remove_empty_attribute": {
                                "type": "Select",
                                "inputs": {
                                  "from": "@items('Apply_to_each_selected_Calculation_Project_Product')?['hso_textblock_hso_projectproduct']",
                                  "select": "@removeProperty(\r\n item(),\r\n ''\r\n)"
                                }
                              },
                              "Remove_Text_Blocks": {
                                "runAfter": {
                                  "Remove_empty_attribute": [
                                    "Succeeded"
                                  ]
                                },
                                "type": "Compose",
                                "inputs": "@removeProperty(\r\n  items('Apply_to_each_selected_Calculation_Project_Product'),\r\n  'hso_textblock_hso_projectproduct'\r\n)"
                              },
                              "Add_formatted_Text_Blocks": {
                                "runAfter": {
                                  "Remove_Text_Blocks": [
                                    "Succeeded"
                                  ]
                                },
                                "type": "Compose",
                                "inputs": "@addProperty(\r\n  outputs('Remove_Text_Blocks'),\r\n  'hso_textblock_hso_projectproduct',\r\n  body('Remove_empty_attribute')\r\n)"
                              },
                              "Append_Project_Product_with_Text_Blocks_to_Payload": {
                                "runAfter": {
                                  "Add_formatted_Text_Blocks": [
                                    "Succeeded"
                                  ]
                                },
                                "type": "AppendToArrayVariable",
                                "inputs": {
                                  "name": "varProjectProductPayload",
                                  "value": "@outputs('Add_formatted_Text_Blocks')"
                                }
                              }
                            }
                          },
                          "expression": {
                            "and": [
                              {
                                "equals": [
                                  "@items('Apply_to_each_selected_Calculation_Project_Product')?['NumberOfTextBlocks']",
                                  0
                                ]
                              }
                            ]
                          },
                          "type": "If"
                        }
                      },
                      "runAfter": {
                        "Select_Calculation_Project_Products": [
                          "Succeeded"
                        ]
                      },
                      "type": "Foreach",
                      "runtimeConfiguration": {
                        "concurrency": {
                          "repetitions": 50
                        }
                      }
                    },
                    "Select_Calculation_Project_Products": {
                      "metadata": {
                        "operationMetadataId": "301d0a3f-86ea-479e-80dc-cb5e436066b0"
                      },
                      "type": "Select",
                      "inputs": {
                        "from": "@outputs('Get_Calculation_Project_Products')?['body/value']",
                        "select": {
                          "hso_name": "@replace(\r\n replace(\r\n  item()?['hso_name'], \r\n  '/', \r\n  ' '\r\n ), \r\n '\\', \r\n ' '\r\n)",
                          "hso_calculationid@odata.bind": "/hso_calculations(@{triggerBody()?['text']})",
                          "hso_description": "@item()?['hso_description']",
                          "hso_costprice": "@item()?['hso_costprice']",
                          "hso_uomid@odata.bind": "/uoms(@{item()?['_hso_uomid_value']})",
                          "hso_metallabelid@odata.bind": "@If(empty(item()?['_hso_metallabelid_value']), '', concat('hso_metallabels(', item()?['_hso_metallabelid_value'], ')'))",
                          "hso_metalbase": "@item()?['hso_metalbase']",
                          "hso_metalnumber": "@item()?['hso_metalnumber']",
                          "hso_metallabelid_2@odata.bind": "@If(empty(item()?['_hso_metallabelid_2_value']), '', concat('hso_metallabels(', item()?['_hso_metallabelid_2_value'], ')'))",
                          "hso_metalbase_2": "@item()?['hso_metalbase_2']",
                          "hso_metalnumber_2": "@item()?['hso_metalnumber_2']",
                          "hso_metallabelid_3@odata.bind": "@If(empty(item()?['_hso_metallabelid_3_value']), '', concat('hso_metallabels(', item()?['_hso_metallabelid_3_value'], ')'))",
                          "hso_metalbase_3": "@item()?['hso_metalbase_3']",
                          "hso_metalnumber_3": "@item()?['hso_metalnumber_3']",
                          "hso_basepricewithoutmetalsurcharge": "@item()?['hso_basepricewithoutmetalsurcharge']",
                          "hso_surchargegroup_baseid@odata.bind": "@If(empty(item()?['_hso_surchargegroup_baseid_value']), '', concat('hso_surchargegroup_bases(', item()?['_hso_surchargegroup_baseid_value'], ')'))",
                          "hso_manufacturer_id@odata.bind": "@If(empty(item()?['_hso_manufacturer_id_value']), '', concat('hso_manufacturers(', item()?['_hso_manufacturer_id_value'], ')'))",
                          "hso_productnumber_manufacturer": "@item()?['hso_productnumber_manufacturer']",
                          "hso_typenumber_manufacturer": "@item()?['hso_typenumber_manufacturer']",
                          "hso_suppliercatalogreference": "@item()?['hso_suppliercatalogreference']",
                          "hso_productnumber_supplier": "@item()?['hso_productnumber_supplier']",
                          "hso_isfromtemplate": "@false",
                          "hso_manufacturer_name": "@item()?['hso_manufacturer_name']",
                          "hso_europeanarticlenumber": "@item()?['hso_europeanarticlenumber']",
                          "@{variables('varOdataType')}": "#Microsoft.Dynamics.CRM.hso_projectproduct",
                          "hso_isbillofmaterials": "@item()?['hso_isbillofmaterials']",
                          "hso_projecttype": "@item()?['hso_projecttype']",
