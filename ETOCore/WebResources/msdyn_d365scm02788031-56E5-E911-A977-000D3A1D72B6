function composeRequestEntity(isATPRequest, companyId, productId = null, siteId = null, warehouseId = null, orderQty = null, refNum = null, lineNum = null) {
    var reqName = Xrm.Utility.getResourceString("msdyn_d365scm_resource", isATPRequest ? "Lookup_ATP_Information" : "Lookup_Inventory_On_Hand");
    var requestEntity = {
        msdyn_name : reqName,
        msdyn_isatpcalculation : isATPRequest,
        msdyn_requestid : ClientUtility.Guid.newGuid(),
        "msdyn_company@odata.bind" : "/cdm_companies(" + companyId + ")"
    };

    if (productId) { requestEntity["msdyn_product@odata.bind"] = "/products(" + productId + ")"; }
    if (siteId) { requestEntity["msdyn_inventorysite@odata.bind"] = "/msdyn_operationalsites(" + siteId + ")"; }
    if (warehouseId) { requestEntity["msdyn_inventorywarehouse@odata.bind"] = "/msdyn_warehouses(" + warehouseId + ")"; }
    if (orderQty) { requestEntity["msdyn_orderquantity"] = orderQty; }
    if (refNum) { requestEntity["msdyn_referencenumber"] = refNum; }
    if (lineNum) { requestEntity["msdyn_linecreationsequencenumber"] = lineNum; }

    return requestEntity;
}

function createRequestAndOpenForm(requestEntity, formGuid, loadMsg, showCmdBar = false) {
    var requestEntityName = "msdyn_inventoryonhandrequest";

    Xrm.Utility.showProgressIndicator(loadMsg);
    setTimeout(function () {
        Xrm.WebApi.createRecord(requestEntityName, requestEntity).then(
            (result) => {
                var entityFormOptions = {
                    entityName : requestEntityName,
                    entityId : result.id,
                    formId : formGuid,
                    openInNewWindow : true,
                    windowPosition : 1,
                    height : 900,
                    width : 1000,
                    cmdbar : showCmdBar,
                    navbar : "off"
                };
                Xrm.Navigation.openForm(entityFormOptions).then(
                    (success) => { console.log(success); },
                    (error) => { console.log(error); }
                );
                disableLoading();
            },
            (error) => {
                console.log(error.message); 
                disableLoading();
            }
        );
    }, 500);
}

function createOnHandRequest(formContext) {
    var companyId = getCompanyId(formContext);
    if (companyId) {
        var formGuid = "1c7fe0b6-7be2-4f3e-ba5d-72d22813957c";
        var loadMsg = Xrm.Utility.getResourceString("msdyn_d365scm_resource", "Initialize_On_Hand_Request");
        var onHandRequest = composeRequestEntity(false, companyId, getProductId(formContext));
        createRequestAndOpenForm(onHandRequest, formGuid, loadMsg);
    }
}

function getOrderDetailEntity(formContext) {
    var orderDetailEntity;

    var orderDetailsGrid = formContext.getControl("salesorderdetailsGrid");
    if (!orderDetailsGrid) {
        orderDetailsGrid = formContext.getControl("quotedetailsGrid");
    }

    if (orderDetailsGrid) {
        var selectedRows = orderDetailsGrid.getGrid().getSelectedRows();
        if (selectedRows.getLength() == 1) {
            orderDetailEntity = selectedRows.getByIndex(0).getData().getEntity();
        }
    }

    if (ClientUtility.DataUtil.isNullOrUndefined(orderDetailEntity) 
        && (formContext.data.entity.getEntityName() == "salesorderdetail"
            || formContext.data.entity.getEntityName() == "quotedetail")) {
        orderDetailEntity = formContext.data.entity;
    }

    return orderDetailEntity;
}

function createATPRequest(formContext) {
    var orderDetailEntity = getOrderDetailEntity(formContext);
    if (!ClientUtility.DataUtil.isNullOrUndefined(orderDetailEntity)) {
        var isQuoteDetail = orderDetailEntity.getEntityName() == "quotedetail";
        var headerIdFieldName = isQuoteDetail ? "quoteid" : "salesorderid";
        var siteFieldName = isQuoteDetail ? "msdyn_shippingsite" : "msdyn_ShippingSite";
        var warehouseFieldName = isQuoteDetail ? "msdyn_shippingwarehouse" : "msdyn_ShippingWarehouse";
        var queryFields = [
            {fieldNameInSourceEntity : "productid", isFieldLookupInSourceEntity : true},
            {fieldNameInSourceEntity : siteFieldName, isFieldLookupInSourceEntity : true},
            {fieldNameInSourceEntity : warehouseFieldName, isFieldLookupInSourceEntity : true},
            {fieldNameInSourceEntity : "quantity", isFieldLookupInSourceEntity : false},
            {fieldNameInSourceEntity : headerIdFieldName, isFieldLookupInSourceEntity : true},
            {fieldNameInSourceEntity : "sequencenumber", isFieldLookupInSourceEntity : false}
        ];
        var queryFilter = buildODataRetrieveRecordQuery(queryFields);
        Xrm.WebApi.online.retrieveRecord(orderDetailEntity.getEntityName(), extractEntityId(orderDetailEntity.getId()), queryFilter)
            .then((result) => {
                var headerEntity = result[headerIdFieldName];
                if (headerEntity && headerEntity["_msdyn_company_value"]) {
                    var companyId = headerEntity["_msdyn_company_value"];
                    var productId = result["productid"] ? result["productid"]["productid"] : null;
                    var siteId = result[siteFieldName] ? result[siteFieldName]["msdyn_operationalsiteid"] : null;
                    var warehouseId = result[warehouseFieldName] ? result[warehouseFieldName]["msdyn_warehouseid"] : null;
                    var orderQty = result["quantity"];
                    var refNum = isQuoteDetail ? null : result[headerIdFieldName]["msdyn_salesordernumber"];
                    var lineNum = isQuoteDetail ? null : result["sequencenumber"];

                    atpRequest = composeRequestEntity(true, companyId, productId, siteId, warehouseId, orderQty, refNum, lineNum);

                    var formGuid = "f12dffde-889c-46ad-8386-ba3c5131f4e5";
                    var loadMsg = Xrm.Utility.getResourceString("msdyn_d365scm_resource", "Initialize_ATP_Request");
                    createRequestAndOpenForm(atpRequest, formGuid, loadMsg, true);
                }
            }, (error) => { console.log(error.message); });
    }
}

function deleteEntityRecord(entityName, id, fnSuccessCallBack = null) {
    Xrm.WebApi.deleteRecord(entityName, id).then(
        (result) => { fnSuccessCallBack && fnSuccessCallBack(); },
        (err) => { console.log(err.message); }
    );
}

function deleteOnHandEntriesAndRequest(requestGuid) {
    var entryEntityName = "msdyn_inventoryonhandentry";
    var entryIdFieldName = "msdyn_inventoryonhandentryid";
    var queryOption = "?$select=" + entryIdFieldName + "&$filter=_msdyn_request_value eq " + requestGuid;
    Xrm.WebApi.retrieveMultipleRecords(entryEntityName, queryOption).then(
        (result) => {
            for (var i = 0; i < result.entities.length; i++) {
                var target = result.entities[i];
                deleteEntityRecord(entryEntityName, target[entryIdFieldName],
                    (result.entities.length == i + 1) ? () => { deleteRequestRecord(requestGuid); } : null);
            }

            result.entities.length == 0 && deleteRequestRecord(requestGuid);
        },
        (error) => { console.log(error.message); }
    );
}

// Delete 30 minutes ago InventoryOnHandRequests.
function deleteOutdatedOnHandRecords() {
    var requestEntityName = "msdyn_inventoryonhandrequest";
    var requestIdFieldName = "msdyn_inventoryonhandrequestid";
    var requestModifiedOn = (new Date(Date.now() - 30 * 60 * 1000)).toISOString();
    var queryOption = "?$select=" + requestIdFieldName + "&$filter=modifiedon le " + requestModifiedOn;
    Xrm.WebApi.retrieveMultipleRecords(requestEntityName, queryOption).then(
        (result) => {
            for (var i = 0; i < result.entities.length; i++) {
                deleteOnHandEntriesAndRequest(result.entities[i][requestIdFieldName]);
            }
        },
        (error) => { console.log(error.message); }
    );
}

function deleteEntriesInGrid(formContext, entriesGrid, deleteRequest = false) {
    if (entriesGrid) {
        var requestGuid = extractEntityId(formContext.data.entity.getId());
        var rows = entriesGrid.getGrid().getRows();
        var count = rows.getLength();
        for (let rowIndex = 0; rowIndex < count; rowIndex++) {
            var lastRec = (count == rowIndex + 1);
            var row = rows.getByIndex(rowIndex);
            var gridEntity = row.getData().getEntity();
            deleteEntityRecord(gridEntity.getEntityName(), extractEntityId(gridEntity.getId()),
                (deleteRequest && lastRec) ? () => { deleteRequestRecord(requestGuid); } : (lastRec ? () => { entriesGrid.refresh(); } : null));
        }

        deleteRequest && (count == 0) && deleteRequestRecord(requestGuid);
    }
}

function deleteOnHandEntriesInGrid(formContext, deleteRequest = false) {
