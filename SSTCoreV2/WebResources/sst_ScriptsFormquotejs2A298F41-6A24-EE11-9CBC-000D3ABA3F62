        let filterheader = `<filter type="and"><condition attribute="sst_language_opt" operator="eq" value="${language}" /><condition attribute="sst_type_opt" operator="eq" value="${Schulz.QuoteForm.QUOTE_TYPES.ARTIKEL}" /><filter type="or"><condition attribute="sst_company_id" operator="eq" uitype="msdyn_company" value="${companyId}" /><condition attribute="sst_company_id" operator="null" /></filter></filter>`;
        let filterfooter = `<filter type="and"><condition attribute="sst_language_opt" operator="eq" value="${language}" /><condition attribute="sst_type_opt" operator="eq" value="${Schulz.QuoteForm.QUOTE_TYPES.PROJEKT}" /><filter type="or"><condition attribute="sst_company_id" operator="eq" uitype="msdyn_company" value="${companyId}" /><condition attribute="sst_company_id" operator="null" /></filter></filter>`;
