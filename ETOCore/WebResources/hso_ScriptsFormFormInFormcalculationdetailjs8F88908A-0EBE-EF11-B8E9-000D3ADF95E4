if (typeof (ETO) === "undefined") { ETO = {}; };
if (typeof (ETO.CalculationPositionForm) === "undefined") { ETO.CalculationPositionForm = {}; }

ETO.CalculationPositionForm.formOnLoad = async (executionContext) => {
    var formContext = executionContext.getFormContext();
    if (formContext.getAttribute("hso_calculationdetail_parentid").getValue() != null) {
        // Get Parent Calculation Position 
        let ParentCalculationPosition_ID = formContext.getAttribute("hso_calculationdetail_parentid").getValue()[0].id;
        if (ParentCalculationPosition_ID) {
            try {
                ParentCalculationPosition_Record = await Xrm.WebApi.retrieveRecord("hso_calculationdetail", ParentCalculationPosition_ID, "?$select=hso_name,hso_linenumber,hso_level,hso_sortinglinenumber,hso_positionquantity,hso_positionelementtype");
                // Restrict Options to set Calculation Position Element Type
                ETO.CalculationPositionForm.filterElementTypeOptions(formContext);
            } catch (error) {
                console.warn("Error when retrieving Parent Calculation Position to restrict available Element Types");
                handleError(error, "formOnLoad");
            }
        };
    } else {
        // Restrict Options to set Calculation Position Element Type
        ETO.CalculationPositionForm.filterElementTypeOptions(formContext);
    };
    // Register onChange Events for Main Forms
    ETO.CalculationPositionForm.registerEvents_MainForm(executionContext, formContext);
    // Open several Side Panels (Surcharge Groups, Metal Prices, Search & Replace, Price Details)
    // Pricing Details and Search & Replace Side Panes are handled within Calculation Form 
    //ETO.CalculationPositionForm.openSidePanel(executionContext, "ShowPricingDetails");
    // Show / Hide fields for Main Forms
    ETO.CalculationPositionForm.setFieldVisibility_MainFormInForm(executionContext);
};

// Register onChange Events for Main Forms
ETO.CalculationPositionForm.registerEvents_MainForm = (executionContext, formContext) => {
    // onChange Event Handler for Elementtype
    formContext.getAttribute("hso_positionelementtype")?.addOnChange(function () { ETO.CalculationPositionForm.onChangeElementType_MainForm(executionContext) });
    // onChange Event Handler for Product or Service selection
    formContext.getAttribute("hso_productid")?.addOnChange(ETO.CalculationPositionForm.onChangeProduct);
    formContext.getAttribute("hso_projectproductid")?.addOnChange(ETO.CalculationPositionForm.onChangeProjectProduct);
    formContext.getAttribute("hso_projecthourid")?.addOnChange(ETO.CalculationPositionForm.onChangeProjectHour);
    formContext.getAttribute("hso_productionhourid")?.addOnChange(ETO.CalculationPositionForm.onChangeProductionHour);
    formContext.getAttribute("hso_projectexpenseid")?.addOnChange(ETO.CalculationPositionForm.onChangeProjectExpense);
    formContext.getAttribute("hso_externalserviceid")?.addOnChange(ETO.CalculationPositionForm.onChangeExternalService);
    // onChange Event Handler for changing ProcessingStatus (Open Custom Page)
    formContext.getAttribute("hso_processingstatus")?.addOnChange(ETO.CalculationPositionForm.openCustomPage);
    // onChange Event Handler for modifying the Quantity
    formContext.getAttribute("hso_quantity")?.addOnChange(ETO.CalculationPositionForm.onChangeQuantity);
    // onChange Event Handler for modifying the Duration in Minutes
    formContext.getAttribute("hso_durationinminutes")?.addOnChange(ETO.CalculationPositionForm.onChangeDurationInMinutes);
    formContext.getAttribute("hso_isbillofmaterial")?.addOnChange(ETO.CalculationPositionForm.onChangeBillOfMaterial);
};

