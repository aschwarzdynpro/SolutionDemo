                      },
                      "metadata": {
                        "operationMetadataId": "ea0dcf28-4a78-46f3-b02b-752e6f407aa6"
                      },
                      "type": "AppendToArrayVariable",
                      "inputs": {
                        "name": "arrDefaultOrderSettings",
                        "value": {
                          "ItemNumber": "@{triggerBody()['text']}",
                          "dataAreaId": "@{items('Apply_to_each_company')?['dataAreaId']}",
                          "settings": "@triggerBody()['text_4']"
                        }
                      }
                    }
                  },
                  "runAfter": {},
                  "metadata": {
                    "operationMetadataId": "8798c87b-ea4b-4b4a-a1e9-63906a7b9e03"
