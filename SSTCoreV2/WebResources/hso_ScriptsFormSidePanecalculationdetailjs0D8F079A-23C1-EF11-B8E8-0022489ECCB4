// Filter available Calculation Type options
// Function called by other function 'formOnLoad' from within this library
Schulz.CalculationPositionForm.filterCalculationTypeOptions = (formContext) => {
    // Get required information from selected position
    let ElementType = formContext.getAttribute('hso_positionelementtype').getValue();
    let CalculationType = formContext.getAttribute('hso_calculationtype').getValue();
    let ProjectType = formContext.getAttribute('hso_projecttype').getValue();
    let PositionLevel = formContext.getAttribute('hso_level').getValue();
    // Get Option Set Values for Calculation Type
    let CalculationTypeOptions = formContext.getControl("hso_calculationtype").getOptions();
    if (CalculationType != 100000002) {
        // switch between Project Types to set available Option Set Values
        switch (ProjectType) {
            case 100000000: // Project Type 'Aufwand'
                // Clear choices for Calculation Type
                formContext.getControl("hso_calculationtype").clearOptions();
                // add choices that should be available for selection
                let optionUseDefaultPrice = CalculationTypeOptions[1]; // Standardpreis verwenden
                formContext.getControl("hso_calculationtype").addOption(optionUseDefaultPrice);
                break;
            default: // Project Type 'Aufmaß' or 'Festpreis'
                if (PositionLevel == 1) {
                    // Clear choices for Calculation Type
                    formContext.getControl("hso_calculationtype").clearOptions();
                    // add choices that should be available for selection
                    let optionUseDefaultPrice = CalculationTypeOptions[1]; // Standardpreis verwenden
                    let optionOverwriteDefaultPrice = CalculationTypeOptions[2]; // Standardpreis überschreiben
                    formContext.getControl("hso_calculationtype").addOption(optionUseDefaultPrice);
                    formContext.getControl("hso_calculationtype").addOption(optionOverwriteDefaultPrice);
                } else if (PositionLevel != 1) {
                    if (formContext.getAttribute("hso_calculationdetail_parentid").getValue() != null) {
                        // get the current Calculation
                        let Calculation = formContext.getAttribute("hso_calculationid").getValue()[0].id;
                        // format Calculation GUID
                        Calculation = Calculation.replace(/[{}]/g, "");
                        // Get Parent Calculationposition Line Number Level
                        let PositionLineNumber = formContext.getAttribute("hso_linenumber").getValue();
                        let ParentLineNumberLevel = parseInt(PositionLineNumber);
                        // get Calculation Type of Parent Position 
                        Schulz.CalculationPositionForm.retrieveTopLevelCalculationType(formContext, Calculation, ParentLineNumberLevel).then(function (Retrieved_TopLevelNode_CalculationType) {
                            if (Retrieved_TopLevelNode_CalculationType == 100000001) { //Parent Position Calculation Type 'Overwrite Default Price'
                                if (ElementType == 100000006 || ElementType == 100000009) {// Position Element Type 'Node' or 'BOM'
                                    disableField(formContext, 'hso_calculationtype');
                                    /*// Clear choices for Calculation Type
                                    formContext.getControl("hso_calculationtype").clearOptions();
                                    // add choices that should be available for selection
                                    let optionAutomaticCalculationDefaultPrice = CalculationTypeOptions[3]; // Automatische Berechnung
                                    formContext.getControl("hso_calculationtype").addOption(optionAutomaticCalculationDefaultPrice);*/
                                };
                            } else {
                                if (ElementType == 100000006 || ElementType == 100000009) {// Position Element Type 'Node' or 'BOM'
                                    // Clear choices for Calculation Type
                                    formContext.getControl("hso_calculationtype").clearOptions();
                                    // add choices that should be available for selection
                                    let optionUseDefaultPrice = CalculationTypeOptions[1]; // Standardpreis verwenden
                                    let optionOverwriteDefaultPrice = CalculationTypeOptions[2]; // Standardpreis überschreiben
                                    formContext.getControl("hso_calculationtype").addOption(optionUseDefaultPrice);
                                    formContext.getControl("hso_calculationtype").addOption(optionOverwriteDefaultPrice);
                                };
                            };
                        }).catch(function (error) {
                            alert(error.message)
                        })
                    }
                }
        }

    } else { 
        disableField(formContext, 'hso_calculationtype');
    };

};


// Set Default Duration in Minutes for Calculation Position
// Function called by other function 'Set Default Quantity'/ 'On Change Quantity' from within this library
// Function called by other function 'Calculate Position Quantity' / 'Retrieve Parent Calculation Position'from within this library
Schulz.CalculationPositionForm.setDurationInMinutes = (formContext) => {
    // get the form context
    // var formContext = executionContext.getFormContext();
    // get selected Position Element Type
    let ElementType = formContext.getAttribute("hso_positionelementtype").getValue();
    // get Quantity (if already set)
    let Quantity = formContext.getAttribute("hso_quantity").getValue();
    // get Parent Position Quantity
    let ParentCalculationPosition_PositionQuantity = formContext.getAttribute("hso_parentquantity").getValue();
    // calculate Duration in Minutes only for Position Element Types 'Production Hour'/ 'Project Hour' / 'External Service'
    if (ElementType == 100000003 || ElementType == 100000004 || ElementType == 100000008) {
        // calculate Duration in Minutes 
        let calculatedDurationInMinutes = Quantity * 60;
        calculatedDurationInMinutes = Number(calculatedDurationInMinutes.toFixed(2));
        // calculate Position Duration in Minutes with Position Quantity
        let calculatedDurationInMinutesPosition = calculatedDurationInMinutes * ParentCalculationPosition_PositionQuantity;
        calculatedDurationInMinutesPosition = Number(calculatedDurationInMinutesPosition.toFixed(2));
        // set Duration in Minutes
        formContext.getAttribute("hso_durationinminutes").setValue(calculatedDurationInMinutes);
        formContext.getAttribute("hso_durationinminutes_positionquantity").setValue(calculatedDurationInMinutesPosition);

    } else { // reset Position Duration in Minutes for other Element Types
        formContext.getAttribute("hso_durationinminutes").setValue(null);
        formContext.getAttribute("hso_durationinminutes_positionquantity").setValue(null);
    };
};

// The function allows manual adjustment of the price for items with a metal price. If the "Base price without surcharges" is changed, the price is recalculated.
// Re-Calculate Cost Price per Unit with changed Base Price without Metal Surcharge
// Function triggered in the Calculation Position form onChange event handler for field hso_product_basepricewithoutmetalsurcharge
Schulz.CalculationPositionForm.onChangeBasePriceWithoutMetalSurcharge = (executionContext) => {
    // get the form context
    var formContext = executionContext.getFormContext();
    // get changed Base Price without Metal Surcharge
    let SelectedProduct_BasePriceWithoutMetalSurcharge = formContext.getAttribute("hso_product_basepricewithoutmetalsurcharge").getValue()
    // get Element Type
    let ElementType = formContext.getAttribute("hso_positionelementtype").getValue();
    // get the Position Quantity
    let Quantity = formContext.getAttribute("hso_positionquantity").getValue();
    // Position Element Type - 'Product' or 'Project Product' 
    if (ElementType == 100000000 || ElementType == 100000002) {// only check for Products and Project Products
        // get Metallabelid 
        let SelectedProduct_MetalLabel = formContext.getAttribute("hso_product_metallabelid").getValue();
        let SelectedProduct_MetalLabel2 = formContext.getAttribute("hso_product_metallabelid_2").getValue();
        let SelectedProduct_MetalLabel3 = formContext.getAttribute("hso_product_metallabelid_3").getValue();
        if (SelectedProduct_MetalLabel != null) { product_metalsurchargeperunit = formContext.getAttribute("hso_product_metalsurchargeperunit").getValue(); } else { product_metalsurchargeperunit = 0 };
        if (SelectedProduct_MetalLabel2 != null) { product_metalsurchargeperunit_2 = formContext.getAttribute("hso_product_metalsurchargeperunit_2").getValue(); } else { product_metalsurchargeperunit_2 = 0 };
        if (SelectedProduct_MetalLabel3 != null) { product_metalsurchargeperunit_3 = formContext.getAttribute("hso_product_metalsurchargeperunit_3").getValue(); } else { product_metalsurchargeperunit_3 = 0 };
        let CalculatedCostPricePerUnit = SelectedProduct_BasePriceWithoutMetalSurcharge + (product_metalsurchargeperunit + product_metalsurchargeperunit_2 + product_metalsurchargeperunit_3);
        // set Cost Price per Unit with Calculated Cost Price per Unit based on Metal Price
        formContext.getAttribute("hso_costpriceperunit").setValue(CalculatedCostPricePerUnit);
        Schulz.CalculationPositionForm.calculateCostPrice(formContext, Quantity, "onChangeBasePriceWithoutMetalSurcharge");
    }
};

// Re-Calculate Cost Price
// Function triggered in the Calculation Position form onChange event handler for field hso_costpriceperunit
Schulz.CalculationPositionForm.onChangeCostPricePerUnit = (executionContext) => {
    console.log("onChangeCostPricePerUnit triggered...");
    // get the form context
    var formContext = executionContext.getFormContext();
    // get the Cost Price per unit
    let CalculatedCostPricePerUnit = formContext.getAttribute("hso_costpriceperunit").getValue()
    // get the Element Type
    let ElementType = formContext.getAttribute("hso_positionelementtype").getValue();
    // get the Position Quantity
    let Quantity = formContext.getAttribute("hso_positionquantity").getValue();
    if (ElementType == 100000000 || ElementType == 100000002) {
        // get Metallabels
        let SelectedProduct_MetalLabel = formContext.getAttribute("hso_product_metallabelid").getValue();
        let SelectedProduct_MetalLabel2 = formContext.getAttribute("hso_product_metallabelid_2").getValue();
        let SelectedProduct_MetalLabel3 = formContext.getAttribute("hso_product_metallabelid_3").getValue();
        // if without Metallabels
        if (SelectedProduct_MetalLabel == null && SelectedProduct_MetalLabel2 == null && SelectedProduct_MetalLabel3 == null) {
            Schulz.CalculationPositionForm.calculateCostPrice(formContext, Quantity, "onChangeCostPricePerUnit");
        } else { // if with Metallabels
            if (SelectedProduct_MetalLabel != null) { product_metalsurchargeperunit = formContext.getAttribute("hso_product_metalsurchargeperunit").getValue(); } else { product_metalsurchargeperunit = 0 };
            if (SelectedProduct_MetalLabel2 != null) { product_metalsurchargeperunit_2 = formContext.getAttribute("hso_product_metalsurchargeperunit_2").getValue(); } else { product_metalsurchargeperunit_2 = 0 };
            if (SelectedProduct_MetalLabel3 != null) { product_metalsurchargeperunit_3 = formContext.getAttribute("hso_product_metalsurchargeperunit_3").getValue(); } else { product_metalsurchargeperunit_3 = 0 };
            let SelectedProduct_BasePriceWithoutMetalSurcharge = CalculatedCostPricePerUnit - (product_metalsurchargeperunit + product_metalsurchargeperunit_2 + product_metalsurchargeperunit_3);
            formContext.getAttribute("hso_product_basepricewithoutmetalsurcharge").setValue(SelectedProduct_BasePriceWithoutMetalSurcharge);
            Schulz.CalculationPositionForm.calculateCostPrice(formContext, Quantity, "onChangeCostPricePerUnit");
        };
    } else { // Another Element Types
        Schulz.CalculationPositionForm.calculateCostPrice(formContext, Quantity, "onChangeCostPricePerUnit");
    };
};

