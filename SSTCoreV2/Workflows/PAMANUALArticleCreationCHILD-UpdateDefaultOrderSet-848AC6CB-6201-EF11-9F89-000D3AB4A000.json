                      "metadata": {
                        "operationMetadataId": "8fffd90e-d9c5-4d1c-ae3e-3cd1df3efbfc"
                      },
                      "type": "AppendToStringVariable",
                      "inputs": {
                        "name": "strResponseMsg",
                        "value": "@{items('Apply_to_each_company')?['dataAreaId']}: @{coalesce(body('Update_Product_default_order_setting')?['error']?['innererror']?['message'], 'Something went wrong...')}\n"
                      }
                    },
                    "Append_DefaultOrderSettings": {
                      "runAfter": {
                        "Update_Product_default_order_setting": [
                          "Succeeded"
