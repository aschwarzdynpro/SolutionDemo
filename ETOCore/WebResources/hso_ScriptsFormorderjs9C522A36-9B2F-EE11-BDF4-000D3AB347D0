if (typeof (ETO) === "undefined") { ETO = {}; };
if (typeof (ETO.OrderForm) === "undefined") { ETO.OrderForm = {}; }

ETO.OrderForm.onLoad = (executionContext) => {
    let formContext = executionContext.getFormContext();   
    ETO.OrderForm.debitorCheck(executionContext);
    ETO.OrderForm.filterTextblocks(executionContext);
    ETO.OrderForm.fillERPRoleFields(executionContext);
    ETO.OrderForm.registerEvents(formContext);
    ETO.OrderForm.checkPositionsMandatoryFields(formContext);
    
    ETO.OrderForm.isOrderReleased(executionContext);

    if (formContext.ui.getFormType() === 1) {
        ETO.OrderForm.getAddressFromCustomer(executionContext);
    }
};

ETO.OrderForm.isOrderReleased = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let orderReleasedValue = formContext.getAttribute("hso_orderreleased_bol").getValue();
    let releaseMessageId = "releaseMessageID";

    if (!orderReleasedValue)
    {
        formContext.ui.setFormNotification("Order for purchase not yet released. To release it, click 'Release order'.", "INFO", releaseMessageId);
    }
};

ETO.OrderForm.getAddressFromCustomer = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let customer = formContext.getAttribute("customerid").getValue();
    if (customer) {
        let customerId = customer[0].id;
        let customerType = customer[0].entityType;

        Xrm.WebApi.retrieveRecord(customerType, customerId, "?$select=address1_line1,address1_line2,address1_city,address1_stateorprovince,address1_postalcode&$expand=hso_address1country_ref($select=hso_name_txt,hso_countryid)")
            .then(result => {
                formContext.getAttribute("shipto_line1").setValue(result["address1_line1"]);
                formContext.getAttribute("shipto_line2").setValue(result["address1_line2"]);
                formContext.getAttribute("shipto_city").setValue(result["address1_city"]);
                formContext.getAttribute("shipto_postalcode").setValue(result["address1_postalcode"]);
                let country = new Object();
                country.id = result["hso_address1country_ref"]["hso_countryid"];
                country.entityType = "hso_country";
                country.name = result["hso_address1country_ref"]["hso_name_txt"];
                formContext.getAttribute("hso_country_id").setValue([country]);
            }, error => {
                console.log(error.message); // TODO: implement better error approach.
            });
    }
};

ETO.OrderForm.registerEvents = (formContext) => {   

    formContext.getAttribute("msdyn_company")?.addOnChange(ETO.OrderForm.debitorCheck);
    formContext.getAttribute("customerid")?.addOnChange(ETO.OrderForm.debitorCheck);
    formContext.getAttribute("customerid")?.addOnChange(ETO.OrderForm.getAddressFromCustomer);
    formContext.getAttribute("hso_debitor_id")?.addOnChange(ETO.OrderForm.fillERPRoleFields);
    formContext.getAttribute("hso_footertextblock_id")?.addOnChange(ETO.OrderForm.setTextblockFooter);
    formContext.getAttribute("hso_headertextblock_id")?.addOnChange(ETO.OrderForm.setTextblockHeader);
};

