// Set Quote Currency for new Calculation
// Function called by formOnLoad  -  but only for Quick Create Forms
ETO.QuoteForm.retrieveActiveCalculation = (formContext, ActiveCalculationGUID) => {
    return new Promise(function (resolve, reject) {
        // Search for Quote currency
        Xrm.WebApi.retrieveRecord("hso_calculation", ActiveCalculationGUID, "?$select=hso_name,hso_createproject,hso_projectstatus").then(
            function success(result) {
                if (result != null) {
                    let CreateProject = result.hso_createproject;
                    let ProjectStatus = result.hso_projectstatus;

                    // show Form Notification for Project Status
                    if (CreateProject == true && ProjectStatus == 100000001) {// Processing Status Project = In Progress
                        formContext.ui.setFormNotification("A project and any sub-projects are created in FinOps for the selected calculation. You will be notified as soon as processing is complete.", "INFO", "CreateFinOps_InformationNotification");
                    } else if (ProjectStatus == 100000000) {// Processing Status Project = Waiting
                        formContext.ui.setFormNotification("The project creation process can only be started once all project products have been assigned to an article master. Please wait until the corresponding approvals for the article request have been granted and the corresponding project products have been completed. The project creation process can then be started manually.", "INFO", "CreateFinOps_WaitingNotification");
                    } else if (ProjectStatus == 100000003) {// Processing Status Project = Error
                        formContext.ui.setFormNotification("An error has occurred while creating the FinOps project and any sub-projects for the selected calculation. Further information can be found in the processing log. In the event that there is a structural problem, please contact an administrator.", "ERROR", "CreateFinOps_ErrorNotification");
                    };
                    resolve(result.hso_projectstatus);
                }
            },
            function error(error) {
                reject(error);
            });
    })
};
