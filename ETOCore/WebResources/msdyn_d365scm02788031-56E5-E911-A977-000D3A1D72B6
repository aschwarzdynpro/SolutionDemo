function buildODataRetrieveRecordQuery(targetFieldInfoArr) {
    if (targetFieldInfoArr.length > 0) {
        let fieldsSelect = targetFieldInfoArr.map((ele) => ele.fieldNameInSourceEntity).join(",");
        let fieldsExpand = targetFieldInfoArr.filter((ele) => ele.isFieldLookupInSourceEntity).map((ele) => ele.fieldNameInSourceEntity).join(",");

        return "?$top=1&"
                + (fieldsExpand.length > 0 ? "$expand=" + fieldsExpand + "&" : "")
                + "$select=" + fieldsSelect;
    }
    else {
        return "";
    }
}

function buildODataRetrieveRecordQueryWithFilter(targetFieldInfoArr, filterPairs) {
    var queryFilter = buildODataRetrieveRecordQuery(targetFieldInfoArr);
    if (queryFilter.length > 0) {
        let filterSeg = filterPairs.map((ele) => (ele.key + " eq " + ele.value)).join(" and ");

        return (filterSeg.length > 0) ? (queryFilter + "&$filter=" + filterSeg) : queryFilter;
    }
    else {
        return "";
    }
}

function buildODataRetrieveRecordIdNameWithFilter(sourceIdNameFilterInfo) {
    if (sourceIdNameFilterInfo.filterPairs && sourceIdNameFilterInfo.idFieldName && sourceIdNameFilterInfo.nameFieldName) {
        let selectSeg = "?$top=1&$select=" + sourceIdNameFilterInfo.idFieldName + "," + sourceIdNameFilterInfo.nameFieldName;
        let filterSeg = sourceIdNameFilterInfo.filterPairs.map((ele) => (ele.key + " eq " + ele.value)).join(" and ");

        return selectSeg + "&$filter=" + filterSeg;
    }
    else {
        return "";
    }
}

function autoFillTargetFieldsOnSourceIdNameFilter(formContext, sourceIdNameFilterInfo, targetFieldName) {
    var targetFieldAttr = formContext.getAttribute(targetFieldName);
    if (targetFieldAttr) {
        var filter = buildODataRetrieveRecordIdNameWithFilter(sourceIdNameFilterInfo);
        Xrm.WebApi.online.retrieveMultipleRecords(sourceIdNameFilterInfo.entityName, filter)
            .then((result) => {
                var value = result["entities"];
                if (value && value.length > 0) {
                    targetFieldAttr.setValue([{ entityType: sourceIdNameFilterInfo.entityName, 
                                                id: "{" + value[0][sourceIdNameFilterInfo.idFieldName] + "}", 
                                                name: value[0][sourceIdNameFilterInfo.nameFieldName] }]);
                }
                else {
                    targetFieldAttr.setValue(null);
                }
            }, (result) => { targetFieldAttr.setValue(null); });
    }
}

function willSkipClearTarget(targetFieldInfo){
    return (targetFieldInfo && targetFieldInfo.skipClearOnRetriveFail && targetFieldInfo.skipClearOnRetriveFail == 1);
}

function autoFillTargetFieldsNull(formContext, targetFieldInfoArr) {
    for (var i = 0; i < targetFieldInfoArr.length; i++) {
        if (!willSkipClearTarget(targetFieldInfoArr[i]))
            setFieldValue(formContext, targetFieldInfoArr[i].fieldName, null);
    }
}

function autoFillTargetFieldsOnSourceRecord(formContext, sourceRecord, targetFieldInfoArr) {
    for (var i = 0; i < targetFieldInfoArr.length; i++) {
        var targetAttr = formContext.data.entity.attributes.get(targetFieldInfoArr[i].fieldName);
        if (targetAttr) {
            var resultValue = sourceRecord[targetFieldInfoArr[i].fieldNameInSourceEntity];
            if (resultValue) {
                var targetAttrValue = targetFieldInfoArr[i].isFieldLookupInSourceEntity
                                        ? [{id: "{" + resultValue[targetFieldInfoArr[i].idFieldNameForCtrl] + "}",
                                            name: resultValue[targetFieldInfoArr[i].nameFieldNameForCtrl],
                                            entityType: targetFieldInfoArr[i].entityTypeForCtrl}]
                                        : resultValue;
                targetAttr.setValue(targetAttrValue);
                targetAttr.fireOnChange();
            }
            else {
                if (targetFieldInfoArr[i].autoFillCallbackWhenRetrivedRecordEmptyValue) {
                    targetFieldInfoArr[i].autoFillCallbackWhenRetrivedRecordEmptyValue();
                }
                else if (!willSkipClearTarget(targetFieldInfoArr[i])) {
                    targetAttr.setValue(null);
                }
            }
        }
    }
}

// fill target field with the first attribute which has the required field
function autoFillTargetFieldsOnSourceRecordWithFirstFittingValue(formContext, sourceRecord, targetFieldInfoArr) {
    for (var i = 0; i < targetFieldInfoArr.length; i++) {
        var targetAttr = formContext.data.entity.attributes.get(targetFieldInfoArr[i].fieldName);
        if (targetAttr) {
            var resultValue = sourceRecord[targetFieldInfoArr[i].fieldNameInSourceEntity];
            if (resultValue) {
				// if the field should only be set if the entity has a specific property that is not null, skip
				if (targetFieldInfoArr[i].requiredKey && !resultValue[targetFieldInfoArr[i].requiredKey]) {
					continue;
				}
                var targetAttrValue = targetFieldInfoArr[i].isFieldLookupInSourceEntity
                                        ? [{id: "{" + resultValue[targetFieldInfoArr[i].idFieldNameForCtrl] + "}",
                                            name: resultValue[targetFieldInfoArr[i].nameFieldNameForCtrl],
                                            entityType: targetFieldInfoArr[i].entityTypeForCtrl}]
                                        : resultValue;
                targetAttr.setValue(targetAttrValue);
                targetAttr.fireOnChange();
				return true;
            }
        }
    }
    return false;
}

function autoFillTargetFieldsOnSourceQueryFilter(formContext, sourceQueryFilterInfo, targetFieldInfoArr) {
    if (sourceQueryFilterInfo.filterPairs.length > 0) {
        var queryFilter = buildODataRetrieveRecordQueryWithFilter(targetFieldInfoArr, sourceQueryFilterInfo.filterPairs);
        if (queryFilter) {
            Xrm.WebApi.online.retrieveMultipleRecords(sourceQueryFilterInfo.entityName, queryFilter)
                .then((result) => {
                    var value = result["entities"];
                    if (value && value.length > 0) {
                        autoFillTargetFieldsOnSourceRecord(formContext, value[0], targetFieldInfoArr);
                    }
                    else {
                        autoFillTargetFieldsNull(formContext, targetFieldInfoArr);
                    }
                }, (result) => { autoFillTargetFieldsNull(formContext, targetFieldInfoArr); });
        }
    }
}

function autoFillTargetFieldsOnSourceQueryKey(formContext, sourceQueryKeyInfo, targetFieldInfoArr) {
    if (sourceQueryKeyInfo.entityId) {
        var queryFilter = buildODataRetrieveRecordQuery(targetFieldInfoArr);
        if (queryFilter) {
            Xrm.WebApi.online.retrieveRecord(sourceQueryKeyInfo.entityName, sourceQueryKeyInfo.entityId, queryFilter)
                .then((result) => {
                    autoFillTargetFieldsOnSourceRecord(formContext, result, targetFieldInfoArr);
                }, (result) => { autoFillTargetFieldsNull(formContext, targetFieldInfoArr); });
        }
    }
}

function onChangeFieldAutoFillTargetFieldsOnKey(formContext, sourceFieldInfo, targetFieldInfoArr) {
    var sourceAttr = formContext.data.entity.attributes.get(sourceFieldInfo.fieldName);
    if (sourceAttr) {
        var sourceAttrValue = sourceAttr.getValue();
        if (sourceAttrValue) {
            var sourceQueryKeyInfo = {
                entityName : sourceFieldInfo.entityName,
                entityId : sourceAttrValue[0].id
            };

