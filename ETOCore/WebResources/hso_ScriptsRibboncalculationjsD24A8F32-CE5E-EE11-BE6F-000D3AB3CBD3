ETO.CalculationRibbon.callCustomAPICalculation = (PrimaryControl, FirstPrimaryItemId, OperationName, OperationType) => {
    console.log("Operation: " + OperationName + " (" + OperationType + ")");
    // Operation Types
    // 0 - RenumberCalculation
    // 1 - CalculateUnitPriceRatio

    // Confirm action with the user
    let confirmTitle = "";
    let confirmMessage = "";
    let progessIndicatorMessage = "";
    switch (OperationType) {
        case 0:
            confirmTitle = "Execute re-numbering";
            confirmMessage = "All calculation positions are re-numbered.";
            progessIndicatorMessage = "Re-numbering in progress";
            break;
        case 1:
            confirmTitle = "Calculate EP-shares";
            confirmMessage = "For all required calculation positions the EP-shares are calculated.";
            progessIndicatorMessage = "Calculating EP-shares in progress";
            break;
    };
    var confirmStrings = { text: confirmMessage, title: confirmTitle };
    var confirmOptions = { height: 200, width: 450 };
    Xrm.Navigation.openConfirmDialog(confirmStrings, confirmOptions).then(
        function (success) {
            if (success.confirmed) {
                // Show Progress Indicator
                Xrm.Utility.showProgressIndicator(progessIndicatorMessage);

                // Prepare the payload
                let CalculationGUID = FirstPrimaryItemId.replace(/[{}]/g, "");
                const payload = {
                    OperationType: OperationType,
                    Records: [CalculationGUID]
                };
                const payloadString = JSON.stringify(payload);
                console.log("Payload to send:", payloadString);

                // Create the API request
                let hso_CalculationAPIRequest = new ETO.CalculationRibbon.hso_CalculationAPI(payloadString);
                // Call the Custom API
                Xrm.WebApi.online.execute(hso_CalculationAPIRequest).then(
                    function (result) {
                        result.json().then(
                            function (response) {
                                // Custom logic after successful API call
                                console.log("Custom API successfully called with operation: " + OperationName);
                                console.log("Response from API:", response);
                                Xrm.Utility.closeProgressIndicator();
                            }
                        );
                    },
                    function (error) {
                        console.error("Error calling the Custom API:", error);
                        Xrm.Utility.closeProgressIndicator();
                        Xrm.Navigation.openErrorDialog({
                            details: error.message,
                            message: 'An error occurred while calling the hso_CalculationAPI Custom API.'
                        });
                    }
                );
            }
        });
};

