        "Revision_Link": {
          "runAfter": {
            "Create_HTML_table_approve": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "cd748fa5-b188-45fa-8171-c9861f5d7985"
          },
          "type": "Compose",
          "inputs": "<a href=\"@{variables('varFODeepLink')}\">Web</a>"
