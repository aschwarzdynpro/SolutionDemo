Schulz.CalculationRibbon.fixErrors = async (formContext) => {
    // Check if processing is running
    const processingRunning = formContext.getAttribute("hso_processingrunning")?.getValue();

    if (processingRunning === true) {
        Xrm.Navigation.openAlertDialog({
            text: "Für die Kalkulationsversion wird gerade eine Berechnung im Hintergrund durchgeführt. Bitte warten Sie bis dieser Vorgang abgeschlossen ist.",
            title: "Hinweis"
        });
        return;
    }

    Xrm.Utility.showProgressIndicator( "Starte Fehlerkorrektur..." );

    try {
        const calculationId = formContext.data.entity.getId().replace(/[{}]/g, "");
              
        const validationLogs = await Xrm.WebApi.retrieveMultipleRecords(
            "hso_processinglog",
            `?$select=hso_processinglogid&$filter=hso_name eq 'Validierung' and _hso_calculationid_value eq ${calculationId}&$top=1&$orderby=createdon desc`
        );
        
        if (!validationLogs.entities.length) {
            Xrm.Navigation.openAlertDialog({
                text: "Kein Verarbeitungsprotokoll für vergangene Validierungen gefunden!",
                title: "Fehler"
            });
            return;
        }
        
        const processingLogId = validationLogs.entities[0].hso_processinglogid;

        const paneConfig = {
            title: "Fehlerkorrektur",
            paneId: "hso_calculation.CalculationCorrection",
            canClose: false,
            // imageSrc: "WebResources/...",
            width: 400
        };

        let pane = Xrm.App.sidePanes.getPane("hso_calculation.CalculationCorrection");
        
        if (pane) {
            pane.select();
        }
        else {
            pane = await Xrm.App.sidePanes.createPane(paneConfig);
        }

        const targetReference = formContext.data.entity.getEntityReference();
        const recordStatus = formContext.getAttribute("statuscode")?.getValue();

        await pane.navigate({
            pageType: "control",
            controlName: "hso_HSO.CalculationCorrection",
            data: JSON.stringify({
                targetReferenceLogicalName: targetReference != null ? targetReference.entityType : undefined,
                targetReferenceId: targetReference != null ? targetReference.id.replace("{", "").replace("}", "") : undefined,
                processingLogId: processingLogId,
                scenario: recordStatus === 100000004 ? "activation" : "validation"
            })
        });
    } catch (error) {
        console.error("Activation error:", error);
        Xrm.Navigation.openAlertDialog({
            text: "Ein Fehler ist beim Aktivieren der Kalkulationsversion aufgetreten. Bitte starten Sie den Vorgang erneut. Tritt der Fehler erneut auf, wenden Sie sich bitte an einen Administrator.",
            title: "Fehler"
        });
    } finally {
