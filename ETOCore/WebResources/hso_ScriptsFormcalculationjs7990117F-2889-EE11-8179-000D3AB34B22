if (typeof (ETO) === "undefined") { ETO = {}; };
if (typeof (ETO.CalculationForm) === "undefined") { ETO.CalculationForm = {}; }

ETO.CalculationForm.formOnLoad = (executionContext, formType, showCalculationParameters) => {
        let formContext = executionContext.getFormContext();
        // Get Quote
        let Quote = formContext.getAttribute("hso_quoteid").getValue();
        if (Quote && Quote.length > 0) {
                var QuoteGUID = Quote[0].id;
        } else {
                console.warn("Quote is not set or invalid.");
        };
        // Get Quote Currency
        if (formType == "IsQuickCreateForm") {
                // Set Default Currency of new Calculation to "Euro"
                ETO.CalculationForm.retrieveDefaultCurrency(formContext).then(function (RetrievedCurrencyName) {
                }).catch(function (error) {
                        alert(error.message);
                });
                // Set Quote Currency of new Calculation to Currency from Quote
                ETO.CalculationForm.retrieveQuote(formContext, QuoteGUID).then(function (RetrievedQuoteCurrencyName) {
                }).catch(function (error) {
                        alert(error.message);
                });
        } else {
                // get the current calculation
                let CalculationGUID = formContext.data.entity.getId();
                // format Calculation GUID
                CalculationGUID_formatted = CalculationGUID.replace(/[{}]/g, "");
                // Register onChange Events for Main Forms
                ETO.CalculationForm.registerEvents_MainForm(executionContext, formContext);
                // Restrict options to set Calculation Type
                ETO.CalculationForm.filterCalculationTypeOptions(formContext, CalculationGUID_formatted);
                // Display a notification with information regarding the project creation process in FinOps
                ETO.CalculationForm.displayFormNotification(formContext);
                // Open Side Panels
                ETO.CalculationForm.openSidePanel(formContext, showCalculationParameters, CalculationGUID_formatted);
                // Check Calculation Positions with Product Lifecycle Warning
                ETO.CalculationForm.retrieveCalculationPositionsWithProductLifecycleWarning(formContext, CalculationGUID).then(function (NumberOfCalculationPositionsWithProductLifecycleWarning) {
                        if (NumberOfCalculationPositionsWithProductLifecycleWarning > 1) {// Processing Status Project = In Progress
                                formContext.ui.setFormNotification("ATTENTION: The calculation contains products with an expiring product life cycle status.", "INFO", "ProductLifecycleWarning_InformationNotification");
                        }
                }).catch(function (error) {
                        alert(error.message);
                });

                // Check Project Products with Supplier Not Available for Calculation 
                ETO.CalculationForm.retrieveProjectProductswithSupplierNotAvailable(formContext, CalculationGUID).then(function (NumberOfCalculationPositionsWithProjectProductswithSupplierNotAvailable) {
                        if (NumberOfCalculationPositionsWithProjectProductswithSupplierNotAvailable >= 1) {// Processing Status Project = In Progress
                                formContext.ui.setFormNotification("ATTENTION: The calculation contains project products that are no longer available from the respective supplier.", "INFO", "ProjectProductswithSupplierNotAvailable_InformationNotification");
                        }
                }).catch(function (error) {
                        alert(error.message);
                });

                // Get Navigation Calculation Position
                let navigationCalculationPosition = formContext.getAttribute("hso_navigationcalculationposition").getValue();
                if (navigationCalculationPosition && navigationCalculationPosition.length > 0) {
                        let NavigationCalculationPosition_ID = navigationCalculationPosition[0].id;

                        // Open Calculation Position Pricing Details and Search & Replace Side Panels
                        ETO.CalculationForm.openCalculationPositionSidePanel(formContext, NavigationCalculationPosition_ID);
                } else {
                        console.warn("Navigation Calculation Position is not set or invalid.");
                };
        }
};

// Register onChange Events for Main Forms
ETO.CalculationForm.registerEvents_MainForm = (executionContext, formContext) => {
        // onChange Event Handler for Elementtype
        formContext.getAttribute("hso_navigationcalculationposition")?.addOnChange(ETO.CalculationForm.onChangeNavigationPosition);
};

// Function triggered in the Calculation Position form onChange event handler for field hso_productid
ETO.CalculationForm.onChangeNavigationPosition = (executionContext) => {
        // get the form context
        var formContext = executionContext.getFormContext();

        // Get Navigation Calculation Position
        let navigationCalculationPosition = formContext.getAttribute("hso_navigationcalculationposition").getValue();
        if (navigationCalculationPosition && navigationCalculationPosition.length > 0) {
                let NavigationCalculationPosition_ID = navigationCalculationPosition[0].id;

                // Open Calculation Position Pricing Details and Search & Replace Side Panels
                ETO.CalculationForm.openCalculationPositionSidePanel(formContext, NavigationCalculationPosition_ID);
        } else {
                console.warn("Navigation Calculation Position is not set or invalid.");
        }
};

ETO.CalculationForm.formOnSave = (executionContext) => {
        var formContext = executionContext.getFormContext();
        // Retrieve required fields
        var Company = formContext.getAttribute("hso_companyid").getValue();
        var Quote = formContext.getAttribute("hso_quoteid").getValue();
        var Department = formContext.getAttribute("hso_departmentid").getValue();
        var Currency = formContext.getAttribute("transactioncurrencyid").getValue();
        var QuoteCurrency = formContext.getAttribute("hso_transactioncurrencyid_quote").getValue();
        var Language = formContext.getAttribute("hso_language").getValue();
        // Validate Company
        if (Company == null || Company === "") {
                formContext.ui.setFormNotification("Please select a company for the quote. The company is mandatory for creating a calculation.", "ERROR", "1");
                executionContext.getEventArgs().preventDefault(); // Prevents save
        };
        // Validate Quote
        if (Quote == null || Quote === "") {
                formContext.ui.setFormNotification("A new calculation must be assigned to a quote. Please repeat the process.", "ERROR", "1");
                executionContext.getEventArgs().preventDefault(); // Prevents save
        };
        // Validate Department
        if (Department == null || Department === "") {
                formContext.ui.setFormNotification("Please select a department for the quote. The department is mandatory for creating a calculation.", "ERROR", "1");
                executionContext.getEventArgs().preventDefault(); // Prevents save
        };
        // Validate Currency
        if (Currency == null || Currency === "") {
                formContext.ui.setFormNotification("The standard currency for a calculation is EURO. Please repeat the process.", "ERROR", "1");
                executionContext.getEventArgs().preventDefault(); // Prevents save
        };
        // Validate Quote Currency
        if (QuoteCurrency == null || QuoteCurrency === "") {
                formContext.ui.setFormNotification("Please select a currency for the quote. The quote currency is required to create a calculation.", "ERROR", "1");
                executionContext.getEventArgs().preventDefault(); // Prevents save
        };
        // Validate Language
        if (Language == null || Language === "") {
                formContext.ui.setFormNotification("Please select a language for the quote. The language is mandatory for creating a calculation.", "ERROR", "1");
                executionContext.getEventArgs().preventDefault(); // Prevents save
        };
};

// Filter available Calculation Type options
// Function called by other function 'formOnLoad' from within this library
ETO.CalculationForm.filterCalculationTypeOptions = (formContext, Calculation) => {
        // Get Option Set Values for Calculation Type
        let CalculationTypeOptions = formContext.getControl("hso_calculationtype").getOptions();
        let optionUseDefaultPrice = CalculationTypeOptions[1]; // Standardpreis verwenden
        let optionOverwriteDefaultPrice = CalculationTypeOptions[2]; // Standardpreis überschreiben
        // Clear choices for Calculation Type
        formContext.getControl("hso_calculationtype").clearOptions();
        //Add choices that should be available for selection
        formContext.getControl("hso_calculationtype").addOption(optionUseDefaultPrice);
        // Check Top-Level-Nodes for Projecttype "Effort"
        ETO.CalculationForm.retrieveLevel1CalculationPositions(formContext, Calculation).then(function (NumberOfTopLevelCalculationPositions) {
                console.log("Number of Top-Level-Nodes with Projecttype 'Effort' retrieved = " + NumberOfTopLevelCalculationPositions);
                if (NumberOfTopLevelCalculationPositions == 0) {
                        // allow possibility to overwrite the Default prices by triggering the Top-Down-Calculation
                        console.log("Allow Top-Down-Calculation because no Top-Level-Nodes with Projecttype 'Effort' found");
                        formContext.getControl("hso_calculationtype").addOption(optionOverwriteDefaultPrice);
                } else {
                        console.log("Top-Down-Calculation not allowed because no Top-Level-Nodes with Projecttype 'Effort' found");
                        formContext.ui.setFormNotification("The calculation type of the entire calculation cannot be changed to 'Overwrite standard price' as the project type 'Effort' is used. Please use the level 1 nodes, which are not assigned to the project type 'Effort', to specify a top-down calculation.", "INFO", "TopDownCalculationNotAllowed_InformationNotification");

                }
        }).catch(function (error) {
                alert(error.message);
        });
};

