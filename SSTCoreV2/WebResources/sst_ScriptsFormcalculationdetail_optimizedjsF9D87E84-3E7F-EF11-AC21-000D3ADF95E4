// Set Notification
// Function triggered in the Calculation Position form onChange event handler for field hso_subproject
Schulz.CalculationPositionForm.displayFormNotification_SubProject = (executionContext) => {
    var formContext = executionContext.getFormContext();
    // get the current calculation
    let Calculation = formContext.getAttribute("hso_calculationid").getValue()[0].id;
    // create Sub-Project?
    let SubProject = formContext.getAttribute("hso_subproject").getValue();
    // Set Default Text
    let confirmStrings = { text: "Hiermit wird das Hauptprojekt mit dem Projekttyp 'Aufwand' erstellt.", title: "Projekttyp der Kalkulationsversion überschreiben", confirmButtonLabel: "Ja", cancelButtonLabel: "Abbrechen" };
    // get the Surchargegroup Base from the selected Product
    Schulz.CalculationPositionForm.retrieveCalculation(executionContext, Calculation).then(function (CalculationProjectType) {
        if (CalculationProjectType != 100000000 && SubProject == true) {
            Xrm.Navigation.openConfirmDialog(confirmStrings, null).then(
                function (success) {
                    if (success.confirmed)
                        // Display Notification
                        formContext.ui.setFormNotification("Der Projekttyp der Kalkulationsversion wird im Hintergrund auf 'Aufwand' gesetzt.", "INFO", "UpdateCalculationProjectType_InformationNotification");
                    else
                        // Reset Sub-Project
                        formContext.getAttribute("hso_subproject").setValue(false);
                });
        }
    }).catch(function (error) {
        alert(error.message);
    });
};

