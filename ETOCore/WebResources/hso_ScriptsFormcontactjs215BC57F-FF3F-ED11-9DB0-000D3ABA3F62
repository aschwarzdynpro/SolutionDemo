if (typeof (ETO) === "undefined") { ETO = {}; };
if (typeof (ETO.ContactForm) === "undefined") { ETO.ContactForm = {}; };

ETO.ContactForm.onLoad = (executionContext) => {
    let formContext = executionContext.getFormContext();
    ETO.ContactForm.registerEvents(formContext);
    ETO.ContactForm.registerEventsMainForm(formContext);

    ETO.ContactForm.restirictCustomerLookup(executionContext);
    ETO.ContactForm.useAccountAddressHandler(executionContext);
    ETO.ContactForm.hideUseAccountAddress(executionContext);
    ETO.ContactForm.setDebitorDefaults(executionContext);
    ETO.ContactForm.setDebitorRequiredFields(executionContext);
    ETO.ContactForm.lockUnlockErpRelevantFields(executionContext);
    ETO.ContactForm.deliveryAdressLocked(executionContext);
    ETO.ContactForm.lockSyncFields(executionContext);
};
ETO.ContactForm.onSave = (executionContext) => {
    ETO.ContactForm.deliveryAdressLocked(executionContext);
}

ETO.ContactForm.onLoadQuick = (executionContext) => {
    let formContext = executionContext.getFormContext();
    ETO.ContactForm.registerEvents(formContext);

    ETO.ContactForm.restirictCustomerLookup(executionContext);
    ETO.ContactForm.useAccountAddressHandler(executionContext);
    ETO.ContactForm.hideUseAccountAddress(executionContext);
};

ETO.ContactForm.registerEvents = (formContext) => {
    formContext.getAttribute("hso_useaccountaddress_bol")?.addOnChange(ETO.ContactForm.useAccountAddressHandler);
    formContext.getAttribute("telephone1")?.addOnChange(ETO.Common.phoneNumberValidator);
    formContext.getAttribute("mobilephone")?.addOnChange(ETO.Common.phoneNumberValidator);
    formContext.getAttribute("lastname").addOnChange(ETO.ContactForm.defaultAddressname);
    formContext.getAttribute("hso_useaccountaddress_bol")?.addOnChange(ETO.ContactForm.defaultAddressname);
};
ETO.ContactForm.registerEventsMainForm = (formContext) => {
    formContext.getAttribute("hso_privatcompany_bol")?.addOnChange(ETO.ContactForm.hideUseAccountAddress);
    formContext.getAttribute("msdyn_company")?.addOnChange(ETO.ContactForm.setDebitorGroups);
    formContext.getAttribute("hso_accountprocessstage_opt")?.addOnChange(ETO.ContactForm.setDebitorDefaults);
    formContext.getAttribute("hso_differentdeliveradress_bool")?.addOnChange(ETO.ContactForm.deliveryAdressLocked);
    formContext.getAttribute("hso_lockcontactform_opt").addOnChange(ETO.ContactForm.lockSyncFields);

    formContext.data.process.addOnStageChange(ETO.ContactForm.onStageChange);
    formContext.data.process.addOnPreStageChange(ETO.ContactForm.onPreStageChange);
};

ETO.ContactForm.onStageChange = (executionContext) => {
    let formContext = executionContext.getFormContext();

    formContext.ui.refreshRibbon();
};

ETO.ContactForm.onPreStageChange = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let eventArgs = executionContext.getEventArgs();

    let activeStage = Xrm.Page.data.process.getActiveStage();
    let direction = eventArgs.getDirection();

    if (activeStage.getId() == "7120b1c0-dbdf-4f4f-b915-f3258621e6e7" && direction == "Previous") { // Debitor
        let isSellable = formContext.getAttribute("msdyn_sellable");

        if (isSellable.getIsDirty()) {
            let companyAttribute = formContext.getAttribute("msdyn_company");
            let customerGroupAttribute = formContext.getAttribute("msdyn_customergroupid");
            let salesTaxGroup = formContext.getAttribute("msdyn_salestaxgroup");

            isSellable?.setValue(false);
            companyAttribute?.setValue(null);
            customerGroupAttribute?.setValue(null);
            salesTaxGroup?.setValue(null);

            ETO.ContactForm.setDebitorRequiredFields(executionContext);
            ETO.ContactForm.lockUnlockErpRelevantFields(executionContext);
        }
    }
};
