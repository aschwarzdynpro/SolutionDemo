ETO.ContactForm.lockSyncFields = (executionContext) => {
    let formContext = executionContext.getFormContext();

    let lockcontactform = formContext.getAttribute("hso_lockcontactform_opt")?.getValue();


    if (lockcontactform) {
        ETO.ContactForm.contactformFields.forEach(field => {
            let attribute = formContext.getAttribute(field);

            ETO.ContactForm.controlDisabled(attribute, lockcontactform);
        });
    }
};
ETO.ContactForm.setDebitorDefaults = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let processStageValue = formContext.getAttribute("hso_accountprocessstage_opt")?.getValue();

    if (processStageValue == 867520002) { //3 - Debitor

        let isSellable = formContext.getAttribute("msdyn_sellable");
        let companyAttribute = formContext.getAttribute("msdyn_company");

        if (!isSellable?.getValue()) {
            isSellable.setValue(true); //Kunde
            ETO.ContactForm.setDebitorRequiredFields(executionContext);
            ETO.ContactForm.lockUnlockErpRelevantFields(executionContext);
        }

        if (!companyAttribute?.getValue()) {
            let userId = Xrm.Utility.getGlobalContext().userSettings?.userId;
            userId = userId.substring(1, userId.length - 1);

            Xrm.WebApi.retrieveRecord("systemuser", userId, "?$select=cdm_Company&$expand=cdm_Company($select=cdm_companyid,cdm_name)")
                .then(result => {
                    if (result?.cdm_Company?.cdm_companyid && result?.cdm_Company?.cdm_name) {
                        companyAttribute?.setValue([{
                            entityType: "cdm_company",
                            id: result.cdm_Company.cdm_companyid,
                            name: result.cdm_Company.cdm_name
                        }]);
                    }
                    ETO.ContactForm.setDebitorGroups(executionContext);
                }, error => {
                    console.log(error.message); // TODO: implement better error approach.
                });
        }
    }
};

ETO.ContactForm.setDebitorGroups = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let processStageValue = formContext.getAttribute("hso_accountprocessstage_opt")?.getValue();

    if (processStageValue == 867520002) { //3 - Debitor


        let companyAttribute = formContext.getAttribute("msdyn_company");
        let customerGroupAttribute = formContext.getAttribute("msdyn_customergroupid");
        let salestaxgroupAttribute = formContext.getAttribute("msdyn_salestaxgroup");
        let paymenttermAttribute = formContext.getAttribute("msdyn_paymentterms");

        if (companyAttribute?.getValue()) {
            var company = formContext.getAttribute("msdyn_company").getValue()[0].id;
            var companyid = company.replace('{', '').replace('}', '');
        }

        if (!customerGroupAttribute?.getValue() && companyAttribute?.getValue()) {
            // TODO: set default for customer group (needs to be specified with FO)
            Xrm.WebApi.retrieveMultipleRecords("msdyn_customergroup", "?$select=msdyn_groupid,msdyn_customergroupid, _msdyn_company_value&$filter=msdyn_groupid eq 'Inland' and _msdyn_company_value eq '" + companyid + "'")
                .then(results => {
                    if (results.entities && results.entities.length > 0) {
                        var customergroup = results.entities[0];
                        const custgroupObject = {
                            id: customergroup["msdyn_customergroupid"],
                            entityType: "msdyn_customergroup",
                            name: customergroup["msdyn_groupid"]
                        }
                        formContext.getAttribute("msdyn_customergroupid").setValue([custgroupObject]);
                    }
                }, error => {
                    console.log(error.message); // TODO: implement better error approach.
                }
                );

        }

        if (!salestaxgroupAttribute?.getValue() && companyAttribute?.getValue()) {
            Xrm.WebApi.retrieveMultipleRecords("msdyn_taxgroup", "?$select=msdyn_taxgroupid,msdyn_name, _msdyn_company_value&$filter=hso_default_bit eq true and _msdyn_company_value eq '" + companyid + "'")
                .then(results => {
                    if (results.entities && results.entities.length > 0) {
                        var salestaxgroup = results.entities[0];
                        const staxgroupObject = {
                            id: salestaxgroup["msdyn_taxgroupid"],
                            entityType: "msdyn_taxgroup",
                            name: salestaxgroup["msdyn_name"]
                        }
                        formContext.getAttribute("msdyn_salestaxgroup").setValue([staxgroupObject]);
                    }
                }, error => {
                    console.log(error.message); // TODO: implement better error approach.
                }
                );
        }

        if (!paymenttermAttribute?.getValue() && companyAttribute?.getValue()) {
            Xrm.WebApi.retrieveMultipleRecords("msdyn_paymentterm", "?$select=msdyn_paymenttermid,msdyn_name, _msdyn_company_value&$filter=msdyn_name eq '14T_Netto' and _msdyn_company_value eq '" + companyid + "'")
                .then(results => {
                    if (results.entities && results.entities.length > 0) {
                        var paymentterms = results.entities[0];
                        const ptermObject = {
                            id: paymentterms["msdyn_paymenttermid"],
                            entityType: "msdyn_paymentterm",
                            name: paymentterms["msdyn_name"]
                        }
                        formContext.getAttribute("msdyn_paymentterms").setValue([ptermObject]);
                    }
                }, error => {
                    console.log(error.message); // TODO: implement better error approach.
                }
                );
        }
    }
};

ETO.ContactForm.setDebitorRequiredFields = (executionContext) => {
    let formContext = executionContext.getFormContext();

    let isSellable = formContext.getAttribute("msdyn_sellable").getValue();

    let customerGroupAttribute = formContext.getAttribute("msdyn_customergroupid");
    let companyAttribute = formContext.getAttribute("msdyn_company");
    let salesTaxGroup = formContext.getAttribute("msdyn_salestaxgroup");
    let customertypecode = formContext.getAttribute("customertypecode");

    if (isSellable) { // Kunde
        ETO.ContactForm.controlDisabled(customerGroupAttribute, false);
        ETO.ContactForm.controlDisabled(companyAttribute, false);
        ETO.ContactForm.controlDisabled(salesTaxGroup, false);
        ETO.ContactForm.controlDisabled(customertypecode, false);

        customerGroupAttribute?.setRequiredLevel("required");
        companyAttribute?.setRequiredLevel("required");
    } else {
        ETO.ContactForm.controlDisabled(customerGroupAttribute, true);
        ETO.ContactForm.controlDisabled(companyAttribute, true);
        ETO.ContactForm.controlDisabled(salesTaxGroup, true);
        ETO.ContactForm.controlDisabled(customertypecode, true);

        customerGroupAttribute?.setRequiredLevel("none");
        companyAttribute?.setRequiredLevel("none");
    }
}
ETO.ContactForm.controlDisabled = (attribute, disabled) => {
    attribute?.controls.forEach(control => {
        control.setDisabled(disabled);
    });
};
ETO.ContactForm.hideUseAccountAddress = (executionContext) => {
    let formContext = executionContext.getFormContext();

    let accountValue = formContext.getAttribute("parentcustomerid")?.getValue();
    let privateCompanyValue = formContext.getAttribute("hso_privatcompany_bol")?.getValue();

    let useAccountAddressAttribute = formContext.getAttribute("hso_useaccountaddress_bol");

    if (!accountValue && privateCompanyValue == true) {
        ETO.ContactForm.controlVisibilty(useAccountAddressAttribute, false);
        useAccountAddressAttribute?.setValue(false);
        useAccountAddressAttribute?.fireOnChange();
    } else {
        ETO.ContactForm.controlVisibilty(useAccountAddressAttribute, true);
    }
};

ETO.ContactForm.restirictCustomerLookup = (executionContext) => {
    let formContext = executionContext.getFormContext();

    formContext.getAttribute("parentcustomerid")?.controls.forEach(control => {
        control.setEntityTypes(["account"]);
    })
};

ETO.ContactForm.useAccountAddressHandler = (executionContext) => {
    let formContext = executionContext.getFormContext();

    let useAccountAddressValue = formContext.getAttribute("hso_useaccountaddress_bol")?.getValue();

    let quickViewControl = Xrm.Page.ui.quickForms.get("quickview_accountaddress");

    let address2difdefliveryAttribute = formContext.getAttribute("hso_differentdeliveradress_bool");
    let address2nameAttribute = formContext.getAttribute("address2_name");
    let address2Line1Attribute = formContext.getAttribute("address2_line1");
    let address2Line2Attribute = formContext.getAttribute("address2_line2");
    let address2PostalcodeAttribute = formContext.getAttribute("address2_postalcode");
    let address2CityAttribute = formContext.getAttribute("address2_city");
    let address2CountryAttribute = formContext.getAttribute("hso_address2_country_id");

    if (useAccountAddressValue == true) {
        ETO.ContactForm.controlVisibilty(address2difdefliveryAttribute, false);
        ETO.ContactForm.controlVisibilty(address2nameAttribute, false);
        ETO.ContactForm.controlVisibilty(address2Line1Attribute, false);
        ETO.ContactForm.controlVisibilty(address2Line2Attribute, false);
        ETO.ContactForm.controlVisibilty(address2PostalcodeAttribute, false);
        ETO.ContactForm.controlVisibilty(address2CityAttribute, false);
        ETO.ContactForm.controlVisibilty(address2CountryAttribute, false);

        address2difdefliveryAttribute?.setValue(false);
        address2nameAttribute?.setValue(null);
        address2Line1Attribute?.setValue(null);
        address2Line2Attribute?.setValue(null);
        address2PostalcodeAttribute?.setValue(null);
        address2CityAttribute?.setValue(null);
        address2CountryAttribute?.setValue(null);

        if (formContext.context.getQueryStringParameters().pageType != "quickcreate") {
            quickViewControl?.setVisible(true);
            Xrm.Page.ui.tabs.get("SUMMARY_TAB").sections.get("section_deliveryaddress").setVisible(false);
        }

    } else {
        ETO.ContactForm.controlVisibilty(address2difdefliveryAttribute, true);
        ETO.ContactForm.controlVisibilty(address2nameAttribute, true);
        ETO.ContactForm.controlVisibilty(address2Line1Attribute, true);
        ETO.ContactForm.controlVisibilty(address2Line2Attribute, true);
        ETO.ContactForm.controlVisibilty(address2PostalcodeAttribute, true);
        ETO.ContactForm.controlVisibilty(address2CityAttribute, true);
        ETO.ContactForm.controlVisibilty(address2CountryAttribute, true);

        if (formContext.context.getQueryStringParameters().pageType != "quickcreate") {
            quickViewControl?.setVisible(false);
            Xrm.Page.ui.tabs.get("SUMMARY_TAB").sections.get("section_deliveryaddress").setVisible(true);
        }
    }
};

ETO.ContactForm.controlVisibilty = (attribute, visibilty) => {
    attribute?.controls.forEach(control => {
        control.setVisible(visibilty);
    });
};


