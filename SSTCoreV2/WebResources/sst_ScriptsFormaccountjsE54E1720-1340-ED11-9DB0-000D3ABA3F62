Schulz.AccountForm.lockUnlockErpRelevantFields = (executionContext) => {
    let formContext = executionContext.getFormContext();

    let customerTypeCodeValue = formContext.getAttribute("customertypecode")?.getValue();

    Schulz.AccountForm.erpRelevantFields.forEach(field => {
        let attribute = formContext.getAttribute(field);

        Schulz.AccountForm.controlDisabled(attribute, customerTypeCodeValue == 3);
    });
};

Schulz.AccountForm.lockSyncFields = (executionContext) => {
    let formContext = executionContext.getFormContext();

    let lockaccountform = formContext.getAttribute("sst_lockaccountform_opt")?.getValue();


    if (lockaccountform) {
        Schulz.AccountForm.accountformFields.forEach(field => {
            let attribute = formContext.getAttribute(field);

            Schulz.AccountForm.controlDisabled(attribute, lockaccountform);
        });
    }
};

Schulz.AccountForm.setDebitorDefaults = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let processStageValue = formContext.getAttribute("sst_accountprocessstage_opt")?.getValue();

    if (processStageValue == 867520002) { //3 - Debitor

        let customerTypeCodeAttribute = formContext.getAttribute("customertypecode");
        let companyAttribute = formContext.getAttribute("msdyn_company");

        //if (!customerTypeCodeAttribute?.getValue()) {
            customerTypeCodeAttribute.setValue(3); //Kunde
            Schulz.AccountForm.setDebitorRequiredFields(executionContext);
            Schulz.AccountForm.lockUnlockErpRelevantFields(executionContext);
        //}

        if (!companyAttribute?.getValue()) {
            let userId = Xrm.Utility.getGlobalContext().userSettings?.userId;
            userId = userId.substring(1, userId.length - 1);

            Xrm.WebApi.retrieveRecord("systemuser", userId, "?$select=cdm_Company&$expand=cdm_Company($select=cdm_companyid,cdm_name)")
                .then(result => {
                    if (result?.cdm_Company?.cdm_companyid && result?.cdm_Company?.cdm_name) {
                        companyAttribute?.setValue([{
                            entityType: "cdm_company",
                            id: result.cdm_Company.cdm_companyid,
                            name: result.cdm_Company.cdm_name
                        }]);
                    }
                    Schulz.AccountForm.setDebitorGroups(executionContext);
                }, error => {
                    console.log(error.message); // TODO: implement better error approach.
                });
        }
    }
};

Schulz.AccountForm.setDebitorGroups = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let processStageValue = formContext.getAttribute("sst_accountprocessstage_opt")?.getValue();

    if (processStageValue == 867520002) { //3 - Debitor


        let companyAttribute = formContext.getAttribute("msdyn_company");
        let customerGroupAttribute = formContext.getAttribute("msdyn_customergroupid");
        let salestaxgroupAttribute = formContext.getAttribute("msdyn_salestaxgroup");
        let paymenttermAttribute = formContext.getAttribute("msdyn_paymentterm");

        if (companyAttribute?.getValue()) {
            var company = formContext.getAttribute("msdyn_company").getValue()[0].id;
            var companyid = company.replace('{', '').replace('}', '');
        }

        if (!customerGroupAttribute?.getValue() && companyAttribute?.getValue()) {
            // TODO: set default for customer group (needs to be specified with FO)
            Xrm.WebApi.retrieveMultipleRecords("msdyn_customergroup", "?$select=msdyn_groupid,msdyn_customergroupid, _msdyn_company_value&$filter=msdyn_groupid eq 'Inland' and _msdyn_company_value eq '" + companyid + "'")
                .then(results => {
                    if (results.entities && results.entities.length > 0) {
                        var customergroup = results.entities[0];
                        const custgroupObject = {
                            id: customergroup["msdyn_customergroupid"],
                            entityType: "msdyn_customergroup",
                            name: customergroup["msdyn_groupid"]
                        }
                        formContext.getAttribute("msdyn_customergroupid").setValue([custgroupObject]);
                    }
                }, error => {
                    console.log(error.message); // TODO: implement better error approach.
                }
                );

        }

        if (!salestaxgroupAttribute?.getValue() && companyAttribute?.getValue()) {
            Xrm.WebApi.retrieveMultipleRecords("msdyn_taxgroup", "?$select=msdyn_taxgroupid,msdyn_name, _msdyn_company_value&$filter=sst_default_bit eq true and _msdyn_company_value eq '" + companyid + "'")
                .then(results => {
                    if (results.entities && results.entities.length > 0) {
                        var salestaxgroup = results.entities[0];
                        const staxgroupObject = {
                            id: salestaxgroup["msdyn_taxgroupid"],
                            entityType: "msdyn_taxgroup",
                            name: salestaxgroup["msdyn_name"]
                        }
                        formContext.getAttribute("msdyn_salestaxgroup").setValue([staxgroupObject]);
                    }
                }, error => {
                    console.log(error.message); // TODO: implement better error approach.
                }
                );
        }

        if (!paymenttermAttribute?.getValue() && companyAttribute?.getValue()) {
            Xrm.WebApi.retrieveMultipleRecords("msdyn_paymentterm", "?$select=msdyn_paymenttermid,msdyn_name, _msdyn_company_value&$filter=msdyn_name eq '14T_Netto' and _msdyn_company_value eq '" + companyid + "'")
                .then(results => {
                    if (results.entities && results.entities.length > 0) {
                        var paymentterms = results.entities[0];
                        const ptermObject = {
                            id: paymentterms["msdyn_paymenttermid"],
                            entityType: "msdyn_paymentterm",
                            name: paymentterms["msdyn_name"]
                        }
                        formContext.getAttribute("msdyn_paymentterm").setValue([ptermObject]);
                    }
                }, error => {
                    console.log(error.message); // TODO: implement better error approach.
                }
                );
        }
    }
};

Schulz.AccountForm.setDebitorRequiredFields = (executionContext) => {
    let formContext = executionContext.getFormContext();

    let customerTypeCodeValue = formContext.getAttribute("customertypecode")?.getValue();

    let customerGroupAttribute = formContext.getAttribute("msdyn_customergroupid");
    let companyAttribute = formContext.getAttribute("msdyn_company");
    let salesTaxGroup = formContext.getAttribute("msdyn_salestaxgroup");

    if (customerTypeCodeValue == 3) { // Kunde
        Schulz.AccountForm.controlDisabled(customerGroupAttribute, false);
        Schulz.AccountForm.controlDisabled(companyAttribute, false);
        Schulz.AccountForm.controlDisabled(salesTaxGroup, false);

        customerGroupAttribute?.setRequiredLevel("required");
        companyAttribute?.setRequiredLevel("required")
    } else {
        Schulz.AccountForm.controlDisabled(customerGroupAttribute, true);
        Schulz.AccountForm.controlDisabled(companyAttribute, true);
        Schulz.AccountForm.controlDisabled(salesTaxGroup, true);

        customerGroupAttribute?.setRequiredLevel("none");
        companyAttribute?.setRequiredLevel("none")
    }
};

Schulz.AccountForm.lockCustomerTypeCode = (executionContext) => {
    let formContext = executionContext.getFormContext();

    let customerTypeCodeAttribute = formContext.getAttribute("customertypecode");

    Schulz.AccountForm.controlDisabled(customerTypeCodeAttribute, true);
};

Schulz.AccountForm.controlDisabled = (attribute, disabled) => {
    attribute?.controls.forEach(control => {
        control.setDisabled(disabled);
    });
};

