// **************************** Utilities ****************************

function ReadOnly(executionContext) {
    var controls = executionContext.getFormContext().ui.controls.get();
    for (var i in controls) {
        var control = controls[i];
        if (control.getDisabled &&
            control.setDisabled &&
            !control.getDisabled()) {
            control.setDisabled(true);
        }
    }
}

function disableLoading() {
    if (window.top.document.readyState === "complete") {
        Xrm.Utility.closeProgressIndicator();
    }
}

function setFieldValue(formContext, fieldName, fieldValue) {
    let fieldAttr = formContext.getAttribute(fieldName)
    if (fieldAttr) {
        fieldAttr.setValue(fieldValue);
    }
}

function lockControl(formContext, fieldName) {
    let control = formContext.getControl(fieldName)
    if (control &&
        control.getDisabled &&
        control.setDisabled &&
        !control.getDisabled()) {
        control.setDisabled(true)
    }
}

function unlockControl(formContext,fieldName) {
    var control = formContext.getControl(fieldName)
    if (control &&
        control.getDisabled &&
        control.setDisabled &&
        control.getDisabled()) {
        control.setDisabled(false)
    }
}

function getEntityFieldValue(entity, fieldName, isLookupField = false, fetchName = false) {
    var entityField = entity.attributes.getByName(fieldName);
    if (entityField) {
        var entityFieldValue = entityField.getValue();
        return isLookupField ? (fetchName ? entityFieldValue[0].name : entityFieldValue[0].id) : entityFieldValue;
    }
    return null;
}


function extractEntityId(entityId) {
    return entityId.replace(/{|}/g, '');
}

function isItemBasedOrderType(primaryControl){
    let formContext = primaryControl;
    var orderType = formContext.getAttribute("msdyn_ordertype");
    if (!ClientUtility.DataUtil.isNullOrUndefined(orderType)) {
