    if (formContext.getAttribute("hso_product_metalsurchargeperunit_2").getValue() != null && formContext.getAttribute("hso_product_metalsurchargeperunit_2").getValue() != 0) {
        showField(formContext, 'hso_product_metalsurchargeperunit_2');
