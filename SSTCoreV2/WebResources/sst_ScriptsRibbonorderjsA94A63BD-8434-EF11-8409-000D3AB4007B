if (typeof (Schulz) === "undefined") { Schulz = {}; };

Schulz.OrderCommands = {
    
    printOrder: function(formContext) {
        
        var uniqueMessageId = "orderprintmessage";

        var confirmStrings = { text:"Soll der Auftrag gedruckt werden?", title:"Auftragsdruck" };
        var confirmOptions = { height: 200, width: 250 };
        Xrm.Navigation.openConfirmDialog(confirmStrings, confirmOptions).then(
        function (success) {    
            if (success.confirmed)
            {
                formContext.getAttribute("sst_lastprintdate_dat").setValue(new Date());
                formContext.data.save();
                
                var notification = 
                {
                    type: 1,
                    level: 4, // information
                    message: "Auftragsdruck wurde gestartet."
                }
                Xrm.App.addGlobalNotification(notification);
            }
        });  
    },

    approveOrder: function(formContext) {
        
        var uniqueMessageId = "orderapprovemessage";
        Xrm.Utility.showProgressIndicator("Positionen werden geprüft...");

        var salesOrderId = formContext.data.entity.getId();
        Xrm.WebApi.retrieveMultipleRecords("salesorderdetail", "?$select=_msdyn_shippingsite_value,_msdyn_shippingwarehouse_value&$filter=_salesorderid_value eq '"+salesOrderId+"' and (_msdyn_shippingwarehouse_value eq null or _msdyn_shippingsite_value eq null)").then(
            function success(result) {
                Xrm.Utility.closeProgressIndicator();

                if (result.entities.length > 0)
                {
                    var alertStrings = { confirmButtonLabel: "Ok", text: "Versandlagerort und Lieferort ist nicht für alle Positionen gesetzt.", title: "⛔ Unvollständige Daten ⛔" };
                    var alertOptions = { height: 120, width: 260 };
                    Xrm.Navigation.openAlertDialog(alertStrings, alertOptions);
                }
                else
                {
                    var confirmStrings = { text:"Soll der Auftrag freigegeben werden? ACHTUNG: Dieser Schritt ist irreversibel.", title:"Auftragsfreigabe" };
                    var confirmOptions = { height: 200, width: 250 };
                    Xrm.Navigation.openConfirmDialog(confirmStrings, confirmOptions).then(
                    function (success) {    
                        if (success.confirmed)
                        {
                            formContext.getAttribute("sst_orderreleased_bol").setValue(true);
                            formContext.data.save();
                            
                            var notification = 
                            {
                                type: 1,
                                level: 4, // information
                                message: "Auftrag wurde freigegeben."
                            }
                            Xrm.App.addGlobalNotification(notification);
                        }
                    });  
                }
            },
            function (error) {
                console.log(error.message);
            }
        );
    }
};