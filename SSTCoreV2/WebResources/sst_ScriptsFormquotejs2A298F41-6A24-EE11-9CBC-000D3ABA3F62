Schulz.QuoteForm.setLocationIDtoDeliveryadress = (executionContext) => {
    const formContext = executionContext.getFormContext();

    // Skip if alternative delivery is selected
    const altAddress = formContext.getAttribute("sst_alternativdelivery_opt").getValue();
    if (altAddress) return;

    // Get customer information
    const customerLookup = formContext.getAttribute("customerid").getValue();
    if (!customerLookup) return;

    const customerType = customerLookup[0].entityType;
    const customerId = Schulz.QuoteForm.extractId(customerLookup);
    if (!customerId) return;

    // Process based on customer type
    switch (customerType) {
        case 'account':
            Schulz.QuoteForm.processAccountLocationId(formContext, customerId);
            break;
        case 'contact':
            Schulz.QuoteForm.processContactLocationId(formContext, customerId);
            break;
    }
};

// Helper function to process account location IDs
Schulz.QuoteForm.processAccountLocationId = (formContext, accountId) => {
    const query = `?$select=accountid,sst_adresse1_locationid,sst_adresse2_locationid&$top=1&$filter=accountid eq '${accountId}'`;

    Xrm.WebApi.retrieveMultipleRecords("account", query)
        .then(result => {
            if (result.entities?.length > 0) {
                const account = result.entities[0];
                Schulz.QuoteForm.setLocationIds(formContext, account.sst_adresse1_locationid, account.sst_adresse2_locationid);
            }
        })
        .catch(error => {
            console.error("Error retrieving account location:", error);
        });
};

// Helper function to process contact location IDs
Schulz.QuoteForm.processContactLocationId = (formContext, contactId) => {
    const query = `?$select=contactid,sst_adress1locationid_txt,sst_adress2locationid_txt&$top=1&$filter=contactid eq '${contactId}'`;

    Xrm.WebApi.retrieveMultipleRecords("contact", query)
        .then(result => {
            if (result.entities?.length > 0) {
                const contact = result.entities[0];
                Schulz.QuoteForm.setLocationIds(formContext, contact.sst_adress1locationid_txt, contact.sst_adress2locationid_txt);
            }
        })
        .catch(error => {
            console.error("Error retrieving contact location:", error);
        });
};

// Helper function to set location IDs with fallback logic
Schulz.QuoteForm.setLocationIds = (formContext, address1Id, address2Id) => {
    const invoiceAttribute = formContext.getAttribute("sst_invoiceadresslocationid_txt");
    const deliveryAttribute = formContext.getAttribute("msdyn_deliveryaddresslocationid");

    // Set invoice address location ID (prefer address2, fallback to address1)
    const currentInvoiceId = invoiceAttribute.getValue();
    if (currentInvoiceId !== address2Id) {
        invoiceAttribute.setValue(address2Id);
    } else if (currentInvoiceId === null && address2Id === null && address1Id !== null) {
        invoiceAttribute.setValue(address1Id);
    }

    // Set delivery address location ID (prefer address1, fallback to address2)
    const currentDeliveryId = deliveryAttribute.getValue();
    if (currentDeliveryId !== address1Id) {
        deliveryAttribute.setValue(address1Id);
    } else if (currentDeliveryId === null && address2Id !== null && address1Id === null) {
        deliveryAttribute.setValue(address2Id);
    }
};

Schulz.QuoteForm.useAlternateAddress = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let altadress = formContext.getAttribute("sst_alternativdelivery_opt").getValue();
    let status = formContext.getAttribute("statecode").getValue();
    if (altadress) {
        if (status === Schulz.QuoteForm.STATE_CODES.DRAFT) { // Draft and Alternate Address selected
            formContext.getAttribute("sst_address_delivery_ref").setRequiredLevel("required");
            formContext.getControl("sst_address_delivery_ref").setVisible(true);

                    Schulz.QuoteForm.deliveryAdressfields.forEach(field => {
            let attribute = formContext.getAttribute(field);
            Schulz.QuoteForm.controlVisible(attribute, false);
        });
        }
        else { // Not Draft and Alternate Address selected
            formContext.getAttribute("sst_address_delivery_ref").setRequiredLevel("none");
            formContext.getAttribute("sst_address_delivery_ref").setValue(null);
            formContext.getControl("sst_address_delivery_ref").setVisible(false);

                    Schulz.QuoteForm.deliveryAdressfields.forEach(field => {
            let attribute = formContext.getAttribute(field);
            Schulz.QuoteForm.controlVisible(attribute, true);
        });
        }
    }
    else { // No Alternate Address selected
        formContext.getAttribute("sst_address_delivery_ref").setRequiredLevel("none");
        formContext.getControl("sst_address_delivery_ref").setVisible(false);
    };
}

