Schulz.CalculationPositionForm.formOnLoad = (executionContext, formType, showPricingSidePanel, showNavigationSidePanel, refreshSurchargeGroupSidePanel, refreshMetalpriceSidePanel, refreshSalespriceSidePanel) => {
    var formContext = executionContext.getFormContext();
    console.log("Form Type: " + formType);
    switch (formType) {
        case "IsQuickCreateForm":
            // Register onChange Events for Quick Create Form
            Schulz.CalculationPositionForm.registerEvents_QuickCreateForm(executionContext, formContext, formType);
            // Show / Hide fields for Quick Create Form 
            //Schulz.CalculationPositionForm.hideFields_QuickCreate(executionContext);
            Schulz.CalculationPositionForm.setFieldVisibility_QuickCreateForm(executionContext, "DoNotHideFields");
            // Restrict Options to set Calculation Position Element Type
            Schulz.CalculationPositionForm.filterElementTypeOptions(formContext, formType);
            // Set the Line Number for the new Position
            Schulz.CalculationPositionForm.setLineNumber(executionContext);
            // TEST Clear Alternativ Position
            clearField(formContext, 'hso_calculationdetail_alternativeid');
            break;
        case "IsMainForm-in-Form":
            // Register onChange Events for Main Forms
            Schulz.CalculationPositionForm.registerEvents_MainForm(executionContext, formContext, formType);
            // Open several Side Panels (Surcharge Groups, Metal Prices, Search & Replace, Price Details)
            Schulz.CalculationPositionForm.openSidePanel(executionContext, showPricingSidePanel, showNavigationSidePanel, refreshSurchargeGroupSidePanel, refreshMetalpriceSidePanel, refreshSalespriceSidePanel);
            // Show / Hide fields for Main Forms
            Schulz.CalculationPositionForm.setFieldVisibility_MainFormInForm(executionContext);
            // Restrict options to set Calculation Position Element Type
            Schulz.CalculationPositionForm.filterElementTypeOptions(formContext);
            break;
        case "IsMainForm":
            // Register onChange Events for Main Forms
            Schulz.CalculationPositionForm.registerEvents_MainForm(executionContext, formContext, formType);
            // Open several Side Panels (Surcharge Groups, Metal Prices, Search & Replace, Price Details)
            Schulz.CalculationPositionForm.openSidePanel(executionContext, showPricingSidePanel, showNavigationSidePanel, refreshSurchargeGroupSidePanel, refreshMetalpriceSidePanel, refreshSalespriceSidePanel);
            // Show / Hide fields for Main Forms
            Schulz.CalculationPositionForm.setFieldVisibility_MainForm(executionContext);
            // Restrict options to set Calculation Type
            Schulz.CalculationPositionForm.filterCalculationTypeOptions(formContext);
            // Restrict options to set Calculation Position Element Type
            Schulz.CalculationPositionForm.filterElementTypeOptions(formContext);
            // trigger function to show/hide, enabled/disabled Sales/Quote Price Fields for Main Form 
            //Schulz.CalculationPositionForm.setVisibilityCalculationSalesPrice(formContext);
            break;
        case "IsSidePanel":
            // Register onChange Events for Main Forms
            Schulz.CalculationPositionForm.registerEvents_SidePanelForm(executionContext, formContext);
            // Show / Hide Fields for Side Panel Forms
            Schulz.CalculationPositionForm.setFieldVisibility_SidePanel(formContext);
            // Show / Hide Metal Fields
            Schulz.CalculationPositionForm.setFieldVisibility_Metallabels(formContext);
            // Restrict options to set Calculation Type
            Schulz.CalculationPositionForm.filterCalculationTypeOptions(formContext);
            break;
    }
};

Schulz.CalculationPositionForm.formOnSave = (executionContext) => {
    var formContext = executionContext.getFormContext();
    // get Quantity, retrieved Parent Quantity and calculated Position Quantity
    let Quantity = formContext.getAttribute("hso_quantity").getValue();
    let ParentCalculationPosition_PositionQuantity = formContext.getAttribute("hso_parentquantity").getValue();
    let PositionQuantity = formContext.getAttribute("hso_positionquantity").getValue();
    // re-calculate Position Quantity
    let calculatedPositionQuantity = Quantity * ParentCalculationPosition_PositionQuantity;
    calculatedPositionQuantity = Number(calculatedPositionQuantity.toFixed(5));
    // check whether the current Position Quantity is equal to the re-calculated Position Quantity
    if (PositionQuantity != calculatedPositionQuantity) {
        console.log("Current Position Quantity not equal to calculated Position Quantity! Set Position Quantity to calculated value.");
        formContext.getAttribute("hso_positionquantity").setValue(calculatedPositionQuantity);
        // proceed with the calculation of the Position Duration in Minutes
        Schulz.CalculationPositionForm.setDurationInMinutes(formContext);
        // proceed with the calculation of the Cost Price
        Schulz.CalculationPositionForm.calculateCostPrice(formContext, calculatedPositionQuantity, "formOnSave");
    } else {
        console.log("Current Position Quantity is equal to calculated Position Quantity. No changes required.")
    };
};

// Register onChange Events for Main Forms
Schulz.CalculationPositionForm.registerEvents_MainForm = (executionContext, formContext, formType) => {
    // onChange Event Handler for Elementtype
    formContext.getAttribute("hso_positionelementtype")?.addOnChange(function () { Schulz.CalculationPositionForm.onChangeElementType_MainForm(executionContext, formType) });
    // onChange Event Handler for Product or Service selection
    formContext.getAttribute("hso_productid")?.addOnChange(Schulz.CalculationPositionForm.onChangeProduct);
    formContext.getAttribute("hso_projectproductid")?.addOnChange(Schulz.CalculationPositionForm.onChangeProjectProduct);
