var formContext = "";
var saveForm = "false";

if (typeof (Schulz) === "undefined") { Schulz = {}; };
if (typeof (Schulz.CalculationPositionForm) === "undefined") { Schulz.CalculationPositionForm = {}; }

Schulz.CalculationPositionForm.formOnLoad = (executionContext) => {
    var formContext = executionContext.getFormContext();
    // Register onChange Events for Main Forms
    Schulz.CalculationPositionForm.registerEvents_SidePanelForm(executionContext, formContext);
    // Show / Hide Fields for Side Panel Forms
    Schulz.CalculationPositionForm.setFieldVisibility_SidePanel(formContext);
    // Show / Hide Metal Fields
    Schulz.CalculationPositionForm.setFieldVisibility_Metallabels(formContext);
    // Restrict options to set Calculation Type
    Schulz.CalculationPositionForm.filterCalculationTypeOptions(formContext);
};

// Register onChange Events for Side Panel Form
Schulz.CalculationPositionForm.registerEvents_SidePanelForm = (executionContext, formContext) => {
    // onChange Event Handler for modifying the Cost Price or Base Price per Unit
    formContext.getAttribute("hso_product_basepricewithoutmetalsurcharge")?.addOnChange(Schulz.CalculationPositionForm.onChangeBasePriceWithoutMetalSurcharge);
    //formContext.getAttribute("hso_costpriceperunit")?.addOnChange(Schulz.CalculationPositionForm.OnChangeCalculatedCostPricePerUnit);
    formContext.getAttribute("hso_costpriceperunit")?.addOnChange(Schulz.CalculationPositionForm.onChangeCostPricePerUnit);
    // onChange Event Handler for modifying the Quantity
    formContext.getAttribute("hso_quantity")?.addOnChange(Schulz.CalculationPositionForm.onChangeQuantity);
    // onChange Event Handler for modifying the Price component breakdown
    formContext.getAttribute("hso_pricecomponentbreakdown")?.addOnChange(Schulz.CalculationPositionForm.onChangePriceComponentBreakdown);
};

// initially all Fields that are visible or hidden for Main Form
// Function called by 'formOnLoad' from within this library
Schulz.CalculationPositionForm.setFieldVisibility_SidePanel = (formContext) => {
    let ElementType = formContext.getAttribute('hso_positionelementtype').getValue();
    let Status = formContext.getAttribute('statecode').getValue();
    let GAEBPriceComponent = formContext.getAttribute('hso_pricecomponentbreakdown').getValue();
    let GAEBOrdinalNumber = formContext.getAttribute("hso_gaeb_ordinalnumber").getValue();
