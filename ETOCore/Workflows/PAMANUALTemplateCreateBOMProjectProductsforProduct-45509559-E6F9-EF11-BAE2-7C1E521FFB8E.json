                    "Content-Type": "application/json; charset=utf-8",
                    "MSCRM.BypassCustomPluginExecution": "true",
                    "MSCRM.BypassBusinessLogicExecution": "CustomSync"
                  },
                  "request/body": "{\n \"Targets\": @{body('Select_Template_POsition_BOM_Project_Product')}\n}"
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_webcontents",
                  "operationId": "InvokeHttp",
                  "connectionName": "shared_webcontents"
                }
              },
              "runAfter": {
                "Select_Template_Position_BOM_Project_Product": [
                  "Succeeded"
                ]
