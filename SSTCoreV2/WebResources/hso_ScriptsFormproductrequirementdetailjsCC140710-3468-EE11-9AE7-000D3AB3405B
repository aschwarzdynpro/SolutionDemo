/**
 * Bulk-Handler für den View-Command "Produkt(e) erstellen)"
 * @param {Array} SelectedControlSelectedItemIds - GUIDs der selektierten Datensätze
 * @param {Object} SelectedControl - Grid-Kontext (für Refresh)
 */
hso.ProductRequirementGrid.BulkCreateProducts = async function (SelectedControlSelectedItemIds, SelectedControl) {
    try {
        if (!SelectedControlSelectedItemIds || SelectedControlSelectedItemIds.length === 0) return;

        const gc = Xrm.Utility.getGlobalContext();
        const userId = gc.userSettings.userId.replace(/[{}]/g, "");
        const userName = gc.userSettings.userName;

        const confirmRes = await Xrm.Navigation.openConfirmDialog({
            title: "Produkt(e) erstellen",
            text: `Es werden ${SelectedControlSelectedItemIds.length} Produkt(e) angestoßen.\nFortfahren?`
        });
        if (!confirmRes.confirmed) return;

        Xrm.Utility.showProgressIndicator("Produkterstellung wird vorbereitet ...");

        // TODO: Passe Tabellennamen + Felder an (gleich der Formularvariante)
        const tableName = "hso_productrequirementdetail";
        const selectCols = [
            // Pflicht-/Prüffelder:
            "hso_status",
            "hso_manualmetalsurcharge",
            "hso_metalsurchargepricequantity",
            "hso_metalsurchargetype1","hso_metalquantity1_dec",
            "hso_metalsurchargetype2","hso_metalquantity2_dec",
            "hso_metalsurchargetype3","hso_metalquantity3_dec"
        ].join(",");

        const successes = [];
        const failures = [];

        for (const id of SelectedControlSelectedItemIds) {
            try {
                Xrm.Utility.showProgressIndicator(
                    `Verarbeite ${successes.length + failures.length + 1} / ${SelectedControlSelectedItemIds.length} ...`
                );

                // 1) Aktuelle Daten des Datensatzes laden (nur benötigte Spalten)
                const rec = await Xrm.WebApi.retrieveRecord(tableName, id, `?$select=${selectCols}`); // Web API: retrieveRecord
                // 2) Validierung (Refaktor deiner Logik – ohne Form-UI)
                const missing = [];

                // Pflichtfelder wie in deiner Formularversion:
                for (const f of ArrRequiredFields) {
                    if (!rec[f]) missing.push(f);
                }

                // Metall-Zuschläge wie gehabt
                const manual = rec["hso_manualmetalsurcharge"];
                const qty = rec["hso_metalsurchargepricequantity"];
                if (manual && (!qty || qty === 0)) missing.push("hso_metalsurchargepricequantity");
                for (let ii = 1; ii <= 3; ii++) {
                    const type = rec[`hso_metalsurchargetype${ii}`];
                    const mqty = rec[`hso_metalquantity${ii}_dec`];
                    if (!manual && type && (!mqty || mqty === 0)) missing.push(`hso_metalquantity${ii}_dec`);
                }

                // Kategorie-Prüfung: erzeuge eine ById-Variante deiner bestehenden Funktion
                const categoryOk = await (hso.ProductRequirementDetailForm.CheckProductcategory_ById
                    ? hso.ProductRequirementDetailForm.CheckProductcategory_ById(tableName, id)
                    : true); // Fallback, bis implementiert

                if (missing.length > 0 || !categoryOk) {
                    failures.push({
                        id,
                        reason: missing.length ? `Fehlende Felder: ${missing.join(", ")}` : "Kategorieprüfung fehlgeschlagen"
                    });
                    continue;
                }

                // 3) Status + Ersteller setzen (Lookup über @odata.bind)
                const update = {
                    "hso_status": OptionSetValue, // deinen "Sync"-Wert verwenden (Zahl)
                    "hso_creator_id@odata.bind": `/systemusers(${userId})`
                };

                await Xrm.WebApi.updateRecord(tableName, id, update); // Web API: updateRecord
                successes.push(id);
            } catch (e) {
                failures.push({ id, reason: e.message || String(e) });
            }
        }

        Xrm.Utility.closeProgressIndicator();

        // Ergebnis anzeigen
        const summary =
            `Fertig.\nErfolgreich: ${successes.length}\nFehler: ${failures.length}` +
            (failures.length ? `\n\nDetails:\n- ${failures.map(f => `${f.id}: ${f.reason}`).join("\n- ")}` : "");
        await Xrm.Navigation.openAlertDialog({ title: "Produkt(e) erstellen – Ergebnis", text: summary });

        // Grid refreshen
        try {
            if (SelectedControl && typeof SelectedControl.refresh === "function") {
                SelectedControl.refresh(); // Grid-API: refresh
            }
        } catch (e) {
            console.warn("Grid-Refresh nicht möglich:", e);
        }
    } catch (err) {
        Xrm.Utility.closeProgressIndicator();
        Xrm.Navigation.openErrorDialog({ message: err.message || String(err) });
    }
};