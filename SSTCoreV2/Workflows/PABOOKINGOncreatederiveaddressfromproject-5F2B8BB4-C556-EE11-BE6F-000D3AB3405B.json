{
  "properties": {
    "connectionReferences": {
      "shared_commondataserviceforapps_1": {
        "api": {
          "name": "shared_commondataserviceforapps"
        },
        "connection": {
          "connectionReferenceLogicalName": "sst_CRDataverse"
        },
        "runtimeSource": "embedded"
      }
    },
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "parameters": {
        "$authentication": {
          "defaultValue": {},
          "type": "SecureObject"
        },
        "$connections": {
          "defaultValue": {},
          "type": "Object"
        }
      },
      "triggers": {
        "When_a_bookable_resource_booking_has_been_created": {
          "type": "OpenApiConnectionWebhook",
          "inputs": {
            "parameters": {
              "subscriptionRequest/message": 1,
              "subscriptionRequest/entityname": "msdyn_resourcerequirement",
              "subscriptionRequest/scope": 4,
              "subscriptionRequest/filterexpression": "_msdyn_projectid_value ne null or _sst_projectassembly_ref_value ne null"
            },
            "host": {
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
              "operationId": "SubscribeWebhookTrigger",
              "connectionName": "shared_commondataserviceforapps_1"
            }
          },
          "metadata": {
            "operationMetadataId": "42451828-6aeb-4fe6-8a2c-250d9d9ac640"
          }
        }
      },
      "actions": {
        "If_project_is_set": {
          "type": "If",
          "expression": {
            "or": [
              {
                "not": {
                  "equals": [
                    "@triggerOutputs()?['body/_msdyn_projectid_value']",
                    "@null"
                  ]
                }
              },
              {
                "not": {
                  "equals": [
                    "@triggerOutputs()?['body/_sst_projectassembly_ref_value']",
                    "@null"
                  ]
                }
              }
            ]
          },
          "actions": {
            "Get_the_related_project": {
              "type": "OpenApiConnection",
              "description": "Only address and lat/long",
              "inputs": {
                "parameters": {
                  "entityName": "msdyn_projects",
                  "recordId": "@if(equals(triggerOutputs()?['body/_msdyn_projectid_value'], null), triggerOutputs()?['body/_sst_projectassembly_ref_value'], triggerOutputs()?['body/_msdyn_projectid_value'])",
                  "$select": "sst_latitude_flt,sst_longitude_flt,sst_deliverystreet_txt,sst_city_txt,sst_postalcode_txt,_sst_country_id_value,sst_deliveryname_txt"
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                  "operationId": "GetItem",
                  "connectionName": "shared_commondataserviceforapps_1"
                }
              },
              "metadata": {
                "operationMetadataId": "98677a0e-f722-453a-b48e-a603280b9b20"
              }
            },
            "Copy_address_to_booking": {
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "entityName": "msdyn_resourcerequirements",
                  "recordId": "@triggerOutputs()?['body/msdyn_resourcerequirementid']",
                  "item/msdyn_latitude": "@outputs('Get_the_related_project')?['body/sst_latitude_flt']",
                  "item/msdyn_longitude": "@outputs('Get_the_related_project')?['body/sst_longitude_flt']",
                  "item/sst_address_name_str": "@outputs('Get_the_related_project')?['body/sst_deliveryname_txt']",
                  "item/sst_country_id@odata.bind": "sst_countries(@{outputs('Get_the_related_project')?['body/_sst_country_id_value']})",
                  "item/msdyn_city": "@outputs('Get_the_related_project')?['body/sst_city_txt']",
                  "item/sst_postalcode_txt": "@outputs('Get_the_related_project')?['body/sst_postalcode_txt']",
                  "item/sst_street_txt": "@outputs('Get_the_related_project')?['body/sst_deliverystreet_txt']"
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                  "operationId": "UpdateRecord",
                  "connectionName": "shared_commondataserviceforapps_1"
                }
              },
              "runAfter": {
                "Get_the_related_project": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "28822b78-dc91-4ef9-bf44-ca2856bcd3fe"
              }
            }
          },
          "else": {
            "actions": {}
          },
          "runAfter": {},
          "metadata": {
            "operationMetadataId": "23b85d7e-ee32-445a-889f-86833559097d"
          }
        }
      },
      "outputs": {}
    },
    "templateName": null
  },
  "schemaVersion": "1.0.0.0"
}