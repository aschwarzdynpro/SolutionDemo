// Set Default Duration in Minutes for Calculation Position
// Function called by other function 'Set Default Quantity'/ 'On Change Quantity' from within this library
// Function called by other function 'Calculate Position Quantity' / 'Retrieve Parent Calculation Position'from within this library
Schulz.CalculationPositionForm.setDurationInMinutes = (formContext) => {
    // get the form context
    // var formContext = executionContext.getFormContext();
    // get selected Position Element Type
    let ElementType = formContext.getAttribute("hso_positionelementtype").getValue();
    // get Quantity (if already set)
    let Quantity = formContext.getAttribute("hso_quantity").getValue();
    // get Parent Position Quantity
    let ParentCalculationPosition_PositionQuantity = formContext.getAttribute("hso_parentquantity").getValue();
    // calculate Duration in Minutes only for Position Element Types 'Production Hour'/ 'Project Hour' / 'External Service'
    if (ElementType == 100000003 || ElementType == 100000004 || ElementType == 100000008) {
        // calculate Duration in Minutes 
        let calculatedDurationInMinutes = Quantity * 60;
        calculatedDurationInMinutes = Number(calculatedDurationInMinutes.toFixed(2));
        // calculate Position Duration in Minutes with Position Quantity
        let calculatedDurationInMinutesPosition = calculatedDurationInMinutes * ParentCalculationPosition_PositionQuantity;
        calculatedDurationInMinutesPosition = Number(calculatedDurationInMinutesPosition.toFixed(2));
        // set Duration in Minutes
        formContext.getAttribute("hso_durationinminutes").setValue(calculatedDurationInMinutes);
        formContext.getAttribute("hso_durationinminutes_positionquantity").setValue(calculatedDurationInMinutesPosition);

    } else { // reset Position Duration in Minutes for other Element Types
        formContext.getAttribute("hso_durationinminutes").setValue(null);
        formContext.getAttribute("hso_durationinminutes_positionquantity").setValue(null);
    };
};

// Set Line Number for new Calculation Position
// Function called by other function 'formOnLoad' from within this library
Schulz.CalculationPositionForm.setLineNumber = async (executionContext) => {
    var formContext = executionContext.getFormContext();
    if (formContext.getAttribute("hso_linenumber").getValue() == null) {
        try {
            let Calculation = formContext.getAttribute("hso_calculationid").getValue()[0].id.replace(/[{}]/g, "");
            let Quantity = formContext.getAttribute("hso_quantity").getValue();
            let ParentCalculationPosition = formContext.getAttribute("hso_calculationdetail_parentid").getValue();

            if (ParentCalculationPosition != null) {
                ParentCalculationPosition = ParentCalculationPosition[0].id.replace(/[{}]/g, "");

                // Retrieve Line Number and Level of the Parent
                let ParentCalculationPosition_Result = await Schulz.CalculationPositionForm.retrieveParentCalculationPosition_LineNumber(ParentCalculationPosition);

                let ParentCalculationPosition_Level = ParentCalculationPosition_Result.hso_level;
                let ParentCalculationPositionLineNumber = ParentCalculationPosition_Result.hso_linenumber;
                let ParentCalculationPosition_SortingLineNumber = ParentCalculationPosition_Result.hso_sortinglinenumber;

                // Retrieve Child Count
                let NumberOfParentCalculationPositionChilds = await Schulz.CalculationPositionForm.retrieveParentCalculationPosition_Childs(Calculation, ParentCalculationPosition);

                let calculatedLineNumber_Level = (NumberOfParentCalculationPositionChilds + 1);
                let calculatedLineNumber = ParentCalculationPositionLineNumber.concat(".", (calculatedLineNumber_Level));

                // Loop until a unique calculatedLineNumber is found
                let isUniqueLineNumber = false;
                while (!isUniqueLineNumber) {
                    let NumberOfCalculationPositionsWithCalculatedLineNumber = await Schulz.CalculationPositionForm.retrieveParentCalculationPosition_CheckLineNumber(Calculation, calculatedLineNumber);

                    if (NumberOfCalculationPositionsWithCalculatedLineNumber == 0) {
                        isUniqueLineNumber = true; // Unique number found, exit the loop
                    } else {
                        // If line number already exists, increment and check again
                        calculatedLineNumber_Level++;
                        calculatedLineNumber = ParentCalculationPositionLineNumber.concat(".", (calculatedLineNumber_Level));
                    }
                }

                // Set the calculated line number and level
                formContext.getAttribute("hso_linenumber").setValue(calculatedLineNumber);
                formContext.getAttribute("hso_linenumber_level").setValue(calculatedLineNumber_Level.toString());

                // Update Level
                formContext.getAttribute("hso_level").setValue(Number(ParentCalculationPosition_Level) + 1);
                formContext.getAttribute("hso_calculationdetail_parentid_sortinglinenum").setValue(ParentCalculationPosition_SortingLineNumber);

                // Position Quantity Calculation
                let ParentCalculationPosition_PositionQuantity = await Schulz.CalculationPositionForm.retrieveParentCalculationPosition_Quantity(ParentCalculationPosition);
                let calculatedPositionQuantity = Number((Quantity * ParentCalculationPosition_PositionQuantity).toFixed(5));
                formContext.getAttribute("hso_positionquantity").setValue(calculatedPositionQuantity);
                formContext.getAttribute("hso_parentquantity").setValue(Number(ParentCalculationPosition_PositionQuantity.toFixed(5)));
            } else {
                // No parent position
                let NumberOfCalculationPositions = await Schulz.CalculationPositionForm.retrieveCalculationPositions(Calculation);
                let calculatedLineNumber = String(NumberOfCalculationPositions + 1);
                formContext.getAttribute("hso_linenumber").setValue(calculatedLineNumber);
                formContext.getAttribute("hso_linenumber_level").setValue(calculatedLineNumber.toString());
                formContext.getAttribute("hso_level").setValue(1);
                formContext.getAttribute("hso_positionquantity").setValue(Number(Quantity.toFixed(5)));
            }
        } catch (error) {
            console.error("Error in setLineNumber: ", error);
            alert(error.message);
        }
    }
};
