// Utility function to clean GUID
Schulz.QuoteForm.cleanGuid = (guid) => {
    return guid ? guid.replace(/[{}]/g, '') : null;
};

// Utility function to extract ID from lookup
Schulz.QuoteForm.extractId = (lookupValue) => {
    if (!lookupValue || !lookupValue[0]) return null;
    return Schulz.QuoteForm.cleanGuid(lookupValue[0].id);
};

Schulz.QuoteForm.controlVisible = (attribute, visible) => {
    attribute?.controls.forEach(control => {
        control.setVisible(visible);
    });
};