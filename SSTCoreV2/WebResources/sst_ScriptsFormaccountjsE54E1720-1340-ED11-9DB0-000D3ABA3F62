if (typeof (Schulz) === "undefined") { Schulz = {}; };
if (typeof (Schulz.AccountForm) === "undefined") { Schulz.AccountForm = {}; }

Schulz.AccountForm.onLoad = (executionContext) => {
    let formContext = executionContext.getFormContext();
    Schulz.AccountForm.registerEvents(formContext);

    Schulz.AccountForm.lockCustomerTypeCode(executionContext);
    Schulz.AccountForm.setDebitorDefaults(executionContext);
    Schulz.AccountForm.setDebitorRequiredFields(executionContext);
    Schulz.AccountForm.lockUnlockErpRelevantFields(executionContext);
    Schulz.AccountForm.deliveryAdressLocked(executionContext);
    Schulz.AccountForm.lockSyncFields(executionContext);
};
Schulz.AccountForm.onSave = (executionContext) => {
    Schulz.AccountForm.deliveryAdressLocked(executionContext);
};
Schulz.AccountForm.quickCreate = (executionContext) => {
    let formContext = executionContext.getFormContext();
    formContext.getAttribute("name").addOnChange(Schulz.AccountForm.defaultAddressname);
formContext.getAttribute("telephone1")?.addOnChange(Schulz.Common.phoneNumberValidator);
}

Schulz.AccountForm.quickCreateOnSave = (executionContext) => {
let formContext = executionContext.getFormContext();
    formContext.getAttribute("address1_name").setValue(formContext.getAttribute("address2_name").getValue());
    formContext.getAttribute("address1_line1").setValue(formContext.getAttribute("address2_line1").getValue());
    formContext.getAttribute("address1_line2").setValue(formContext.getAttribute("address2_line2").getValue());
    formContext.getAttribute("address1_postalcode").setValue(formContext.getAttribute("address2_postalcode").getValue());
    formContext.getAttribute("address1_city").setValue(formContext.getAttribute("address2_city").getValue());
    if (formContext.getAttribute("sst_adresse2country_id").getValue() != null) {
        formContext.getAttribute("sst_address1country_ref").setValue(formContext.getAttribute("sst_adresse2country_id").getValue());
    }
}

Schulz.AccountForm.registerEvents = (formContext) => {
    formContext.getAttribute("telephone1")?.addOnChange(Schulz.Common.phoneNumberValidator);
    formContext.getAttribute("fax")?.addOnChange(Schulz.Common.phoneNumberValidator);
    formContext.getAttribute("sst_accountprocessstage_opt")?.addOnChange(Schulz.AccountForm.setDebitorDefaults);
    formContext.getAttribute("msdyn_company")?.addOnChange(Schulz.AccountForm.setDebitorGroups);
    formContext.getAttribute("sst_differentdeliveradress_bool")?.addOnChange(Schulz.AccountForm.deliveryAdressLocked);
    formContext.getAttribute("name").addOnChange(Schulz.AccountForm.defaultAddressname);
    formContext.getAttribute("sst_lockaccountform_opt").addOnChange(Schulz.AccountForm.lockSyncFields);

    formContext.data.process.addOnStageChange(Schulz.AccountForm.onStageChange);
    formContext.data.process.addOnPreStageChange(Schulz.AccountForm.onPreStageChange);

};

Schulz.AccountForm.onStageChange = (executionContext) => {
    let formContext = executionContext.getFormContext();

    formContext.ui.refreshRibbon();
};

Schulz.AccountForm.onPreStageChange = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let eventArgs = executionContext.getEventArgs();

    let activeStage = Xrm.Page.data.process.getActiveStage();
    let direction = eventArgs.getDirection();

    if (activeStage.getId() == "15d2cdd9-33c3-4308-aa8e-45fe65486c50" && direction == "Previous") { // Debitor
        let customerTypeCodeAttribute = formContext.getAttribute("customertypecode");

        if (customerTypeCodeAttribute.getIsDirty()) {
            let companyAttribute = formContext.getAttribute("msdyn_company");
            let customerGroupAttribute = formContext.getAttribute("msdyn_customergroupid");
            let salesTaxGroup = formContext.getAttribute("msdyn_salestaxgroup");

            customerTypeCodeAttribute?.setValue(null);
            companyAttribute?.setValue(null);
            customerGroupAttribute?.setValue(null);
            salesTaxGroup?.setValue(null);

            Schulz.AccountForm.setDebitorRequiredFields(executionContext);
            Schulz.AccountForm.lockUnlockErpRelevantFields(executionContext);
        }
    }
};

