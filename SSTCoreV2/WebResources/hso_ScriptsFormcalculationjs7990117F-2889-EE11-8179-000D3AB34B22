// Fetch selected Parent Project to display additional information
// Function called by other function 'displayFormNotification' from within this library
Schulz.CalculationForm.retrieveParentProject = (SelectedParentProject) => {
        return new Promise(function (resolve, reject) {
                // Get Parent Project 
                Xrm.WebApi.retrieveRecord("msdyn_project", SelectedParentProject, "?$select=sst_projectnumber").then(
                        function success(result) {
                                resolve(result.sst_projectnumber);
                        },
                        function error(error) {
                                reject(error);
                        });
        })
};

// Set default Currency "Euro" for new Calculation
// Function called by formOnLoad  -  but only for Quick Create Forms
Schulz.CalculationForm.retrieveDefaultCurrency = (formContext) => {
        return new Promise(function (resolve, reject) {
                // Search for default currency "Euro"
                Xrm.WebApi.retrieveMultipleRecords("transactioncurrency", "?$select=transactioncurrencyid,isocurrencycode,currencyname&$filter=isocurrencycode eq 'EUR'").then(
                        function success(result) {
                                for (var i = 0; i < result.entities.length; i++) {
                                }
                                if (result != null) {
                                        // set default Currency for new Calculation
                                        formContext.getAttribute("transactioncurrencyid").setValue(null);
                                        formContext.getAttribute("transactioncurrencyid").setValue([{ id: result.entities[0].transactioncurrencyid, name: result.entities[0].currencyname, entityType: "transactioncurrency" }]);
                                        resolve(result.entities[0].currencyname);
                                }
                        },
                        function error(error) {
                                reject(error);
                        });
        })
};

// Set Quote Currency for new Calculation
// Function called by formOnLoad  -  but only for Quick Create Forms
Schulz.CalculationForm.retrieveQuote = (formContext, Quote) => {
        return new Promise(function (resolve, reject) {
                // Search for Quote currency
                Xrm.WebApi.retrieveRecord("quote", Quote, "?$select=quoteid,transactioncurrencyid&$expand=transactioncurrencyid($select=transactioncurrencyid,isocurrencycode,currencyname)").then(
                        function success(result) {
                                if (result != null) {
                                        // set Currency for new Calculation based on Quote Currency
                                        formContext.getAttribute("hso_transactioncurrencyid_quote").setValue([{ id: result.transactioncurrencyid.transactioncurrencyid, name: result.transactioncurrencyid.currencyname, entityType: "transactioncurrency" }]);
                                        resolve(result.transactioncurrencyid.currencyname);
                                }
                        },
                        function error(error) {
                                reject(error);
                        });
        })
};

// Fetch Level 1 Calculation Positions to decide whether calculation method "Top-Down" is allowed or not 
// Function called by other function "filterCalculationTypeOptions" from within this library
Schulz.CalculationForm.retrieveLevel1CalculationPositions = (formContext, Calculation) => {
        return new Promise(function (resolve, reject) {
                // Search for fitting Calculation Surcharge Group
                Xrm.WebApi.retrieveMultipleRecords("hso_calculationdetail", "?$select=hso_name,hso_linenumber,hso_projecttype&$filter=_hso_calculationid_value eq '" + Calculation + "' and hso_level eq 1 and hso_projecttype eq 100000000").then(
                        function success(result) {
                                for (var i = 0; i < result.entities.length; i++) {
                                }
                                if (result != null) {
                                        console.log("Number of Top-Level-Nodes with Projecttype 'Effort': " + result.entities.length);
                                        resolve(result.entities.length);
                                }
                        },
                        function error(error) {
