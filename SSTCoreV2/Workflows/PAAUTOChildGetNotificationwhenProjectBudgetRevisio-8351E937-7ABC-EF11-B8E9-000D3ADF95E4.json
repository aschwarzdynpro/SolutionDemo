            ]
          },
          "metadata": {
            "operationMetadataId": "3cc50f0b-521c-4c2c-bb76-d6d8444aaed7"
          },
          "type": "OpenApiConnection",
          "inputs": {
            "host": {
              "connectionName": "shared_dynamicsax",
              "operationId": "GetItems",
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_dynamicsax"
            },
            "parameters": {
              "dataset": "@parameters('EnvVar | Unified Operations Instance (hso_EnvVarUnifiedOperationsInstance)')",
              "table": "WorkflowWorkItems",
              "$filter": "Id eq @{body('Parse_JSON')?['WorkflowWorkItemInstanceId']} and Type eq Microsoft.Dynamics.DataEntities.WorkflowWorkItemType'Return'",
              "cross-company": true
