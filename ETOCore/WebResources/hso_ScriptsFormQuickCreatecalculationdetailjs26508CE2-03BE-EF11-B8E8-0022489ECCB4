// Filter available Element Type options
// Function called by other function 'formOnLoad' from within this library 
ETO.CalculationPositionForm.filterElementTypeOptions = (formContext) => {
    const attr = formContext.getAttribute("hso_positionelementtype");
    if (!attr) return;

    // Werte aus dem Optionset entfernen
    const valuesToRemove = [100000001, 100000005, 100000009, 100000010];

    // Falls aktueller Wert entfernt wird, Feld leeren
    const currentValue = attr.getValue();
    if (currentValue !== null && valuesToRemove.includes(currentValue)) {
        attr.setValue(null);
        if (typeof attr.fireOnChange === "function") attr.fireOnChange();
    }

    // Aus allen gebundenen Controls entfernen (falls mehrere vorhanden sind)
    attr.controls.forEach(control => {
        valuesToRemove.forEach(val => {
            try { control.removeOption(val); } catch (e) { /* bereits entfernt */ }
        });
    });
};

