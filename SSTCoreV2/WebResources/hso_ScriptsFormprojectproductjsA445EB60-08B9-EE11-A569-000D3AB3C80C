// Function called by other function formOnLoad from within this library
// initially Tab's and Field to enable/disable 
Schulz.ProjectProductForm.setFieldMode = (executionContext) => {
        // get the form context
        var formContext = executionContext.getFormContext();
        // Check Calculation
        if (formContext.getAttribute("hso_calculationid").getValue() != null) { // If Calculation is not Null
                // get Calculation
                let Calculation = formContext.getAttribute("hso_calculationid").getValue()[0].id;
                // format Calculation GUID
                Calculation = Calculation.replace(/[{}]/g, "");
                console.log("Calculation : " + Calculation);
                // Get Calculation Status
                Schulz.ProjectProductForm.retrieveCalculation(executionContext, Calculation).then(function (CalculationStatus) {
                        console.log("Calculation_ActiveVersion : " + CalculationStatus);
                        if (CalculationStatus == 1) { // Satus is Inactiv
                                disableTab(formContext, 'metallabel_tab');
                                disableTab(formContext, 'general_tab');
                                enableField(formContext, 'hso_productid');
                        };
                }).catch(function (error) {
                        alert(error.message);
                });
        };
};

// Fetch Statecode that has been selected for a Calculation 
// Function called by other function 'setFieldMode'
Schulz.ProjectProductForm.retrieveCalculation = function (executionContext, Calculation) {
        return new Promise(function (resolve, reject) {
                // Get Statecode for Calculation 
                Xrm.WebApi.retrieveRecord("hso_calculation", Calculation, "?$select=statecode").then(
                        function success(result) {
                                CalculationStatus = result.statecode;
                                resolve(result.statecode);
                        },
                        function error(error) {
                                reject(error);
                        });
        })
};

//Fetch Company ID
Schulz.ProjectProductForm.FetchCompanyID = function (executionContext) {
        var formContext = executionContext.getFormContext();
        var ProductTemplate = formContext.getAttribute("hso_templateid").getValue();
        var ProductCalculation = formContext.getAttribute("hso_calculationid").getValue();
        // Check Calculation or Template ID for fetch Company ID
        if (ProductCalculation != null) {
                let ProductCalculationID = formContext.getAttribute("hso_calculationid").getValue()[0].id;
                ProductCalculationID = ProductCalculationID.replace(/[{}]/g, "");
                Schulz.ProjectProductForm.retrieveCalculationCompany(executionContext, ProductCalculationID).then(function (ProductCompanyID) {
                }).catch(function (error) {
                        alert(error.message);
                });

        } else if (ProductTemplate != null) {
                let ProductTemplateID = formContext.getAttribute("hso_templateid").getValue()[0].id;
                ProductTemplateID = ProductTemplateID.replace(/[{}]/g, "");
                Schulz.ProjectProductForm.retrieveTemplateCompany(executionContext, ProductTemplateID).then(function (ProductCompanyID) {
                }).catch(function (error) {
                        alert(error.message);
                });
        } else { ProductCompanyID = null };
};

//Filter LookUp Field Product
function filterProduct(executionContext) {
        var formContext = executionContext.getFormContext();
        if (ProductCompanyID != null) {
                var ProductFilter = "<filter type='and'><condition attribute='msdyn_companyid' operator='eq' value='" + ProductCompanyID + "'/></filter>";
                console.log("Product Company ID Calculation: " + ProductCompanyID);
                console.log("Product Filter: " + ProductFilter);
                formContext.getControl("hso_productid").addCustomFilter(ProductFilter);
        };
};


// Fetch Company ID that has been selected for a Calculation 
// Function called by other function 'FetchCompanyID'
Schulz.ProjectProductForm.retrieveCalculationCompany = function (executionContext, ProductCalculationID) {
        return new Promise(function (resolve, reject) {
                // Get Statecode for Calculation 
                Xrm.WebApi.retrieveRecord("hso_calculation", ProductCalculationID, "?$select=hso_companyid&$expand=hso_companyid($select=cdm_companyid)").then(
                        function success(result) {
                                ProductCompanyID = result.hso_companyid.cdm_companyid;
                                ProductCompanyID = ProductCompanyID.replace(/[{}]/g, "");
                                resolve(ProductCompanyID);
                        },
                        function error(error) {
                                reject(error);
                        });
        })
};

// Fetch Company ID that has been selected for a Template 
// Function called by other function 'setFieldMode'
Schulz.ProjectProductForm.retrieveTemplateCompany = function (executionContext, ProductTemplateID) {
        return new Promise(function (resolve, reject) {
                // Get Statecode for Calculation 
                Xrm.WebApi.retrieveRecord("hso_template", ProductTemplateID, "?$select=hso_companyid&$expand=hso_companyid($select=cdm_companyid)").then(
                        function success(result) {
                                ProductCompanyID = result.hso_companyid.cdm_companyid;
                                ProductCompanyID = ProductCompanyID.replace(/[{}]/g, "");
                                resolve(ProductCompanyID);
                        },
                        function error(error) {
                                reject(error);
                        });
        })
};

// Generic function to disabled Fileds in Tab
// Function called by other functions from within this library
function disableTab(formContext, tab) {
        formContext.ui.tabs.get(tab).sections.forEach(function (section) {
                section.controls.forEach(function (control) {
                        control.setDisabled(true);
                })
        });
};

// Generic function to disabled Fileds in Tab
