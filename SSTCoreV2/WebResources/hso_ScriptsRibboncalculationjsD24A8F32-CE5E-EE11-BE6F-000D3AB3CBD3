Schulz.CalculationRibbon.showActivationButton = (formContext) => {
    const activeVersion = formContext.getAttribute("hso_activeversion")?.getValue();
    const processingRunning = formContext.getAttribute("hso_processingrunning")?.getValue();
    const calcStatus = formContext.getAttribute("hso_bottomupcalculation_status")?.getValue();

    return activeVersion
        && processingRunning
        && calcStatus === Schulz.CalculationRibbon.Metadata.BottomUpStatus.Calculated;
}

Schulz.CalculationRibbon.activate = async (formContext) => {
    // Check if processing is running
    const processingRunning = formContext.getAttribute("hso_processingrunning")?.getValue();

    if (processingRunning === true) {
        Xrm.Navigation.openAlertDialog({
            text: "Für die Kalkulationsversion wird gerade eine Berechnung im Hintergrund durchgeführt. Bitte warten Sie bis dieser Vorgang abgeschlossen ist.",
            title: "Hinweis"
        });
        return;
    }

    // Check calculation status
    const calcStatus = formContext.getAttribute("hso_bottomupcalculation_status")?.getValue();
    if (calcStatus !== Schulz.CalculationRibbon.Metadata.BottomUpStatus.Calculated) {
        Xrm.Navigation.openAlertDialog({
            text: "Die Kalkulationsversion kann erst aktiviert werden, wenn die Berechnung auf dem aktuellen Stand ist. Bitte führen Sie eine manuelle Bottom-Up Berechnung durch.",
            title: "Hinweis"
        });
        return;
    }

    // Confirm dialog
    const confirmResult = await Xrm.Navigation.openConfirmDialog({
        text: "Die ausgewählte Kalkulationsversion wird aktiviert und für weitere Bearbeitungen gesperrt.",
        title: "Kalkulationsversion aktivieren",
        confirmButtonLabel: "Ja",
        cancelButtonLabel: "Nein"
    });
    if (!confirmResult.confirmed) return;

    Xrm.Utility.showProgressIndicator( "Starte Aktivierung..." );

    try {
        const calculationId = formContext.data.entity.getId().replace(/[{}]/g, "");
        const quoteId = formContext.getAttribute("hso_quoteid")?.getValue()?.[0]?.id?.replace(/[{}]/g, "");

        const createLogResponse = await Xrm.WebApi.createRecord(
            "hso_processinglog",
            {
                "hso_calculationid@odata.bind": `/hso_calculations(${calculationId})`,
                hso_name: "Validierung"
            }
        );

        // Fetch all other active calculations for the same quote
        const otherActiveCalcs = await Xrm.WebApi.retrieveMultipleRecords(
            "hso_calculation",
            `?$select=hso_calculationid&$filter=hso_activeversion eq true and _hso_quoteid_value eq ${quoteId} and hso_calculationid ne ${calculationId}`
        );

        // Deactivate all other active calculations
        const deactivatePromises = otherActiveCalcs.entities.map(calc =>
            Xrm.WebApi.updateRecord(
                "hso_calculation",
                calc.hso_calculationid,
                {
                    hso_activeversion: false
                }
            )
        );
        await Promise.all(deactivatePromises);

        // Mark selected calculation as active and update status
        await Xrm.WebApi.updateRecord(
            "hso_calculation",
            calculationId,
            {
                hso_activeversion: true,
                statecode: 1,
                statuscode: Schulz.CalculationRibbon.Metadata.StatusCode.ActivationPending
            }
        );

        // Update quote with active calculation
        await Xrm.WebApi.updateRecord(
            "quote",
            quoteId,
            {
                "hso_activecalculation_id@odata.bind": `/hso_calculations(${calculationId})`
            }
        );

        const request = {
            entity: {
                entityType: "hso_calculation",
                id: calculationId
            },
            hso_ValidationApiPayload: JSON.stringify({ ProcessingLogId: createLogResponse.id, ActivateOnSuccess: true }),
            getMetadata: function () {
                return {
                    boundParameter: "entity",
                    parameterTypes: {
                        "entity": {
                            typeName: "Microsoft.Dynamics.CRM.hso_calculation",
                            structuralProperty: 5
                        },
                        "hso_ValidationApiPayload": {
                            typeName: "Edm.String",
                            structuralProperty: 1
                        }
                    },
                    operationType: 0,
                    operationName: "hso_ActionPQCInvokeValidation"
                };
            }
        };

        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        const response = await Xrm.WebApi.execute(request);

        if (!response.ok) {
            Xrm.Navigation.openAlertDialog({
                text: "Das Starten der Validierung ist fehlgeschlagen.",
                title: "Hinweis"
            });
            return;
        }

        formContext.data.refresh(true);

        var paneConfig = {
            title: "Aktivierungsstatus Kalkulationsversion",
            paneId: "hso_calculation.CalculationActivationStatus",
            canClose: false,
            // imageSrc: "WebResources/...",
            width: 400
        };

        let pane = Xrm.App.sidePanes.getPane("hso_calculation.CalculationActivationStatus");

        if (pane) {
            pane.select();
        }
        else {
            pane = await Xrm.App.sidePanes.createPane(paneConfig);
        }

        const targetReference = formContext.data.entity.getEntityReference();

        await pane.navigate({
            pageType: "control",
            controlName: "hso_HSO.CalculationActivationStatus",
            data: JSON.stringify({
                targetReferenceLogicalName: targetReference != null ? targetReference.entityType : undefined,
                targetReferenceId: targetReference != null ? targetReference.id.replace("{", "").replace("}", "") : undefined,
                processingLogId: createLogResponse.id,
                scenario: "activation"
            })
        });
    } catch (error) {
        console.error("Activation error:", error);
        Xrm.Navigation.openAlertDialog({
            text: "Ein Fehler ist beim Aktivieren der Kalkulationsversion aufgetreten. Bitte starten Sie den Vorgang erneut. Tritt der Fehler erneut auf, wenden Sie sich bitte an einen Administrator.",
            title: "Fehler"
        });
    } finally {
        Xrm.Utility.closeProgressIndicator();
    }
};

