Schulz.QuoteForm.notifyUserIfProjectQuoteIsWon = (formContext) => {
    if (formContext.getAttribute("statecode").getValue() === Schulz.QuoteForm.STATE_CODES.WON && formContext.getAttribute("sst_angebotstyp_opt").getValue() === Schulz.QuoteForm.QUOTE_TYPES.PROJEKT) {// only for Project Quote that is won
        if (formContext.getAttribute("hso_activecalculation_id").getValue() != null) {
            // get active Calculation
            let ActiveCalculationGUID = formContext.getAttribute("hso_activecalculation_id").getValue()[0].id;
            // display Form Notification depending on the Status of the Project Creation process
            Schulz.QuoteForm.retrieveActiveCalculation(formContext, ActiveCalculationGUID).then(function (RetrievedProjectStatus) {
                console.log("Active Calculation Project Status: " + RetrievedProjectStatus);
            }).catch(function (error) {
                alert(error.message);
            });
        }
    }
};

// Set Quote Currency for new Calculation
// Function called by formOnLoad  -  but only for Quick Create Forms
Schulz.QuoteForm.retrieveActiveCalculation = (formContext, ActiveCalculationGUID) => {
    return new Promise(function (resolve, reject) {
        // Search for Quote currency
        Xrm.WebApi.retrieveRecord("hso_calculation", ActiveCalculationGUID, "?$select=hso_name,hso_createproject,hso_projectstatus").then(
            function success(result) {
                if (result != null) {
                    let CreateProject = result.hso_createproject;
                    let ProjectStatus = result.hso_projectstatus;

                    // show Form Notification for Project Status
                    if (CreateProject == true && ProjectStatus == 100000001) {// Processing Status Project = In Progress
                        formContext.ui.setFormNotification("Für die ausgewählte Kalkulationsversion wird in FinOps ein Projekt sowie ggfs. Unterprojekte erstellt. Sie werden benachrichtigt, sobald die Verarbeitung abgeschlossen ist.", "INFO", "CreateFinOps_InformationNotification");
                    } else if (ProjectStatus == 100000000) {// Processing Status Project = Waiting
                        formContext.ui.setFormNotification("Der Prozess der Projekterstellung kann erst gestartet werden sobald alle Projektartikel einem Artikelstamm zugeordnet sind. Bitte warten Sie bis die entsprechenden Freigaben für die Artikel-Anfrage erteilt und die entsprechenden Projektartikel vervollständigt wurden. Anschließend kann der Projekterstellungsprozess manuell gestartet werden.", "INFO", "CreateFinOps_WaitingNotification");
                    } else if (ProjectStatus == 100000003) {// Processing Status Project = Error
                        formContext.ui.setFormNotification("Beim Erstellen des FinOps Projekts sowie ggfs. Unterprojekten für die ausgewählte Kalkulationsversion ist ein Fehler aufgetreten. Weitere Informationen können dem Verarbeitungsprotokoll entnommen werden. Für den Fall, dass ein strukturelles Problem vorliegt, wenden Sie sich bitte an einen Administrator.", "ERROR", "CreateFinOps_ErrorNotification");
                    };
                    resolve(result.hso_projectstatus);
                }
            },
            function error(error) {
                reject(error);
            });
    })
};

