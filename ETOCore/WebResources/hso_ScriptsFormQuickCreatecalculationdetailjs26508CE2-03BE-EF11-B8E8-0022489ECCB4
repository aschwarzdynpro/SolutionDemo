ETO.CalculationPositionForm.retrieveParentCalculationPosition_CheckLineNumber = function (param_Calculation, param_CalculatedLineNumber) {
    return new Promise(function (resolve, reject) {
        // Search for Calculation Position with calculated Line Number
        Xrm.WebApi.retrieveMultipleRecords("hso_calculationdetail", "?$select=hso_calculationdetailid,hso_name,hso_linenumber&$filter=_hso_calculationid_value eq '" + param_Calculation + "' and hso_linenumber eq '" + param_CalculatedLineNumber + "'").then(
            function success(result) {
                // Validate result
                if (result && result.entities) {
                    resolve(result.entities.length); // Resolve with the count of matching entities
                } else {
                    // Handle unexpected result structure
                    const errorMessage = "Unexpected null or invalid result while checking Line Number for Calculation: " + param_Calculation + ", Line Number: " + param_CalculatedLineNumber;
                    console.error(errorMessage, result);
                    reject(new Error(errorMessage));
                }
            },
            function error(error) {
                // Provide a more detailed error message
                const errorMessage = "Error occurred while checking Line Number for Calculation: " + param_Calculation + ", Line Number: " + param_CalculatedLineNumber;
                console.error(errorMessage, error);
                reject(new Error(errorMessage + ". Original error: " + error.message));
            }
        );
    })
};

