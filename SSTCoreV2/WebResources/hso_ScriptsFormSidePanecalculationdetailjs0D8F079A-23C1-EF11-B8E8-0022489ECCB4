    if (formContext.getAttribute("hso_gaeb_ordinalnumber").getValue() != null) {
        showField(formContext, 'header_hso_gaeb_ordinalnumber');
    } else { hideField(formContext, 'header_hso_gaeb_ordinalnumber'); };
    if (formContext.getAttribute("hso_surchargegroup_calculationid").getValue() != null) {
        showField(formContext, 'header_hso_surchargegroup_calculationid');
    } else { hideField(formContext, 'header_hso_surchargegroup_calculationid'); };
    if (formContext.getAttribute("hso_calculationsalespriceid").getValue() != null) {
        showField(formContext, 'header_hso_calculationsalespriceid');
    } else { hideField(formContext, 'header_hso_calculationsalespriceid'); };
    if (formContext.getAttribute("hso_calculationdetail_parentid").getValue() != null) {
        showField(formContext, 'header_hso_calculationdetail_parentid');
    } else { hideField(formContext, 'header_hso_calculationdetail_parentid'); };
