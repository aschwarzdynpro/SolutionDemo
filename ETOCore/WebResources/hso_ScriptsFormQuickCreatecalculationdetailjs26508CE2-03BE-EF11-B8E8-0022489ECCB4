ETO.CalculationPositionForm.formOnLoad = async (executionContext) => {
    var formContext = executionContext.getFormContext();
    // Get Parent Calculation Position 
    let ParentCalculationPosition_ID = formContext.getAttribute("hso_calculationdetail_parentid").getValue()[0].id;
    if (ParentCalculationPosition_ID) {
        try {
            ParentCalculationPosition_Record = await Xrm.WebApi.retrieveRecord("hso_calculationdetail", ParentCalculationPosition_ID, "?$select=hso_name,hso_linenumber,hso_level,hso_sortinglinenumber,hso_positionquantity,hso_positionelementtype");
            console.log("ParentCalculationPosition_Record received...");
            console.log(ParentCalculationPosition_Record);
            // Restrict Options to set Calculation Position Element Type
            ETO.CalculationPositionForm.filterElementTypeOptions(formContext);
            // Set the Line Number for the new Position
            ETO.CalculationPositionForm.setLineNumber(executionContext);
        } catch (error) {
            handleError(error, "formOnLoad");
        }
    };
    // Register onChange Events for Quick Create Form
    ETO.CalculationPositionForm.registerEvents_QuickCreateForm(executionContext, formContext);
    // Show / Hide fields for Quick Create Form 
    // ETO.CalculationPositionForm.hideFields_QuickCreate(executionContext);
    ETO.CalculationPositionForm.setFieldVisibility_QuickCreateForm(executionContext, "DoNotHideFields");

    // TEST Clear Alternativ Position
    clearField(formContext, 'hso_calculationdetail_alternativeid');
};

ETO.CalculationPositionForm.formOnSave = (executionContext) => {
    var formContext = executionContext.getFormContext();
    // get Quantity, retrieved Parent Quantity and calculated Position Quantity
    let Quantity = formContext.getAttribute("hso_quantity").getValue();
    let ParentCalculationPosition_PositionQuantity = formContext.getAttribute("hso_parentquantity").getValue();
    let PositionQuantity = formContext.getAttribute("hso_positionquantity").getValue();
    // re-calculate Position Quantity
    let calculatedPositionQuantity = Quantity * ParentCalculationPosition_PositionQuantity;
    calculatedPositionQuantity = Number(calculatedPositionQuantity.toFixed(5));
    // check whether the current Position Quantity is equal to the re-calculated Position Quantity
    if (PositionQuantity != calculatedPositionQuantity) {
        console.log("Current Position Quantity not equal to calculated Position Quantity! Set Position Quantity to calculated value.");
        formContext.getAttribute("hso_positionquantity").setValue(calculatedPositionQuantity);
        // proceed with the calculation of the Position Duration in Minutes
        ETO.CalculationPositionForm.setDurationInMinutes(formContext);
    } else {
        console.log("Current Position Quantity is equal to calculated Position Quantity. No changes required.")
    };
};

// Register onChange Events for Quick Create Form
ETO.CalculationPositionForm.registerEvents_QuickCreateForm = (executionContext, formContext) => {
    // onChange Event Handler for Elementtype
    formContext.getAttribute("hso_positionelementtype")?.addOnChange(ETO.CalculationPositionForm.onChangeElementType_QuickCreateForm);
    // onChange Event Handler for Product or Service selection
    formContext.getAttribute("hso_productid")?.addOnChange(ETO.CalculationPositionForm.onChangeProduct);
    formContext.getAttribute("hso_projectproductid")?.addOnChange(ETO.CalculationPositionForm.onChangeProjectProduct);
    formContext.getAttribute("hso_projecthourid")?.addOnChange(ETO.CalculationPositionForm.onChangeProjectHour);
    formContext.getAttribute("hso_productionhourid")?.addOnChange(ETO.CalculationPositionForm.onChangeProductionHour);
    formContext.getAttribute("hso_projectexpenseid")?.addOnChange(ETO.CalculationPositionForm.onChangeProjectExpense);
    formContext.getAttribute("hso_externalserviceid")?.addOnChange(ETO.CalculationPositionForm.onChangeExternalService);
    // onChange Event Handler for modifying the Quantity
    formContext.getAttribute("hso_quantity")?.addOnChange(ETO.CalculationPositionForm.onChangeQuantity);
    // onChange Event Handler for modifying the Duration in Minutes
    formContext.getAttribute("hso_durationinminutes")?.addOnChange(ETO.CalculationPositionForm.onChangeDurationInMinutes);
    formContext.getAttribute("hso_isbillofmaterial")?.addOnChange(ETO.CalculationPositionForm.onChangeBillOfMaterial);
