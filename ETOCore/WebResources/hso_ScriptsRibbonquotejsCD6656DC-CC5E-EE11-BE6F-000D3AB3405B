if (typeof (ETO) === "undefined") { ETO = {}; };
if (typeof (ETO.QuoteRibbon) === "undefined") { ETO.QuoteRibbon = {}; }
// Open Print Settings
ETO.QuoteRibbon.openPrintSettingsCustomPage = (formContext) => {
    // Get Quote GUID and remove {}
    var selectedRecordID = formContext.data.entity.getId().replace(/[{}]/g, "")
    console.log("Quote GUID: " + selectedRecordID);
    // Get Quote Active Calculation
    var Quote_ActiveCalculation = formContext.getAttribute("hso_activecalculation_id").getValue();
    console.log("Quote Active Calculation: " + Quote_ActiveCalculation);
    // Get Quote Type
    var Quote_Type = formContext.getAttribute("hso_quotetype_opt").getValue();
    if (Quote_Type == 867520000) {// Quote Type is Item based Quote
        // Set Toggle "Print Quote" to true
        var confirmStrings = { text: "Should the quote be printed?", title: "Quote printing" };
        var confirmOptions = { height: 200, width: 250 };
        Xrm.Navigation.openConfirmDialog(confirmStrings, confirmOptions).then(
            function (success) {
                if (success.confirmed) {
                    formContext.getAttribute("hso_lastprintdate_dat").setValue(new Date());
                    formContext.data.save();
                    var notification =
                    {
                        type: 1,
                        level: 4, // information
                        message: "Quote printing was started."
                    }
                    Xrm.App.addGlobalNotification(notification);
                }
            });
        console.log("Item based Quote: Start Workflow to print Quote directly");
    } else if (Quote_Type == 867520001) {// Quote Type is Project Quote

        /*if (Quote_ActiveCalculation == null) {// No Active Calculation selected yet
            alert("Um ein Projektangebot zu drucken muss eine Kalkulationsversion als aktive Version markiert werden. Bitte wählen Sie eine aktive Kalkulationsversion und wiederholen Sie diesen Vorgang!");
        } else {// Active Calculation selected }**/

        console.log("Project Quote: Open Page with Print Settings before starting Workflow to print Quote");
console.log("TST");
        // Prepare Custom Page settings
        var pageInput = {
            pageType: "custom",
            name: "hso_quoteprintsettingsoptimiertv2_273fd",  //"hso_quoteprintsettings_ab588",
            entityName: "quote",
            recordId: selectedRecordID
        };
        var navigationOptions = {
            target: 2,
            position: 1,
            width: { value: 90, unit: "%" },
            title: "Quote print settings",
        };
        console.log("Open Custom Page with Quote GUID: " + selectedRecordID);
console.log("TST Anpassung:1 ");
        // Open Custom Page with defined settings
        Xrm.Navigation.navigateTo(pageInput, navigationOptions)
            .then(
                function () {
                    // Called when the dialog closes
                    formContext.data.refresh();
                }
            ).catch(
                function (error) {
                    // Handle error
                }
            );

    }
};