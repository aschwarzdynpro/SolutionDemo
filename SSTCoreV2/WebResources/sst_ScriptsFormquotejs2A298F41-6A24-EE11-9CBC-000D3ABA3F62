// DEBITOR AND ERP ROLE MANAGEMENT
// ========================================

Schulz.QuoteForm.validateCustomerTypeOnChange = async (executionContext) => {
    const formContext = executionContext.getFormContext();

    // Check if debitor is required
    const hasDebitor = formContext.getAttribute("sst_hasdebitor_opt").getValue();
    if (hasDebitor !== true) return;

    // Get customer information
    const customerLookup = formContext.getAttribute("customerid").getValue();
    if (!customerLookup) return;

    const customerType = customerLookup[0].entityType;

    // Only validate if customer is an account
    if (customerType !== 'account') return;

    const customerId = Schulz.QuoteForm.extractId(customerLookup);
    if (!customerId) return;

    try {
        // Retrieve the account's customer type code
        const result = await Xrm.WebApi.retrieveRecord("account", customerId, "?$select=customertypecode");

        // Check if the customer type code is not Debitor (3)
        if (result.customertypecode !== Schulz.QuoteForm.CUSTOMER_TYPE_CODES.DEBITOR) {
            // Show alert dialog
            await Xrm.Navigation.openAlertDialog({
                title: "Ungültiger Kundentyp",
                text: "Änderung auf einen Interessenten nicht möglich. Bitte Interessenten zum Debitor entwickeln oder eine neue Verkaufschance anlegen."
            });

            // Clear the customerid field
            formContext.getAttribute("customerid").setValue(null);
        }
    } catch (error) {
        console.error("Error validating customer type:", error);
    }
};

Schulz.QuoteForm.debitorCheck = (executionContext) => {
    const formContext = executionContext.getFormContext();

    // Get company ID
    const companyLookup = formContext.getAttribute("msdyn_company").getValue();
    const companyId = Schulz.QuoteForm.extractId(companyLookup);

    // Get customer info
    const customerLookup = formContext.getAttribute("customerid").getValue();
    if (!customerLookup) return;

    const customerType = customerLookup[0].entityType;
    const customerId = Schulz.QuoteForm.extractId(customerLookup);

    if (!companyId || !customerId) return;

    // Process based on customer type
    switch (customerType) {
        case 'account':
            Schulz.QuoteForm.processAccountDebitor(formContext, executionContext, customerId, companyId);
            break;
        case 'contact':
            Schulz.QuoteForm.processContactDebitor(formContext, executionContext, customerId, companyId);
            break;
    }
};

// Helper function to process account debitor
Schulz.QuoteForm.processAccountDebitor = (formContext, executionContext, accountId, companyId) => {
    const query = `?$select=_sst_account_ref_value,_sst_company_ref_value,sst_name_str,sst_erproleid,sst_invoicedeliveryonhold_opt,_sst_taxgroup_ref_value&$filter=_sst_account_ref_value eq '${accountId}' and _sst_company_ref_value eq '${companyId}'`;

    Schulz.QuoteForm.processDebitorQuery(formContext, executionContext, "sst_erprole", query);
};

// Helper function to process contact debitor
Schulz.QuoteForm.processContactDebitor = (formContext, executionContext, contactId, companyId) => {
    const query = `?$select=_sst_account_ref_value,_sst_company_ref_value,sst_name_str,sst_erproleid,sst_invoicedeliveryonhold_opt,_sst_taxgroup_ref_value&$filter=_sst_contact_id_value eq '${contactId}' and _sst_company_ref_value eq '${companyId}'`;

    Schulz.QuoteForm.processDebitorQuery(formContext, executionContext, "sst_erprole", query);
};

// Consolidated function to process debitor query results
Schulz.QuoteForm.processDebitorQuery = (formContext, executionContext, entityName, query) => {
    Xrm.WebApi.retrieveMultipleRecords(entityName, query).then(
        (results) => {
            if (results.entities && results.entities.length > 0) {
                Schulz.QuoteForm.handleDebitorFound(formContext, results.entities[0]);
            } else {
                Schulz.QuoteForm.handleDebitorNotFound(formContext);
            }
            Schulz.QuoteForm.fillERPRoleFields(executionContext);
        },
        (error) => {
            console.error("Error retrieving ERP role:", error);
        }
    );
};

// Handle case when debitor is found
Schulz.QuoteForm.handleDebitorFound = (formContext, erpRole) => {
    const erpRoleRef = {
        id: erpRole["sst_erproleid"],
        entityType: "sst_erprole",
        name: erpRole["sst_name_str"]
    };

    // Set debitor if not already set
    if (formContext.getAttribute("sst_debitor_id").getValue() === null) {
        formContext.getAttribute("sst_debitor_id").setValue([erpRoleRef]);
    }

    // Handle debitor approval status
    const isOnHold = erpRole["sst_invoicedeliveryonhold_opt"] === 806380000;
    const hasDebitor = formContext.getAttribute("sst_hasdebitor_opt").getValue();
    const previousHasDebitor = hasDebitor;

    if (isOnHold && !hasDebitor) {
        formContext.getAttribute("sst_hasdebitor_opt").setValue(true);
        formContext.ui.clearFormNotification("MissingDebitorNotification");
    } else if (!hasDebitor) {
        formContext.getAttribute("sst_hasdebitor_opt").setValue(false);
        formContext.ui.setFormNotification("Der Debitor in diesem Mandanten ist noch nicht freigegeben.", "WARNING", "MissingDebitorNotification");
    }

    // Update customer filter if hasDebitor status changed
    const currentHasDebitor = formContext.getAttribute("sst_hasdebitor_opt").getValue();
    if (previousHasDebitor !== currentHasDebitor) {
        const mockExecutionContext = { getFormContext: () => formContext };
        Schulz.QuoteForm.filterCustomerIdLookup(mockExecutionContext);
    }

    Schulz.QuoteForm.fillDefaultSalesTaxPercentage(formContext, erpRole["_sst_taxgroup_ref_value"]);
};

// Handle case when debitor is not found
Schulz.QuoteForm.handleDebitorNotFound = (formContext) => {
    if (formContext.getAttribute("sst_debitor_id").getValue() !== null) {
        formContext.getAttribute("sst_debitor_id").setValue(null);
    }

    const hasDebitorAttribute = formContext.getAttribute("sst_hasdebitor_opt");
    const previousHasDebitor = hasDebitorAttribute.getValue();
    const initialHasDebitor = hasDebitorAttribute.getInitialValue();

    // Only set to false if it was never saved as true
    // If it was previously saved as true, keep it as true
    if (!previousHasDebitor && initialHasDebitor !== true) {
        hasDebitorAttribute.setValue(false);
    }

    // Update customer filter if hasDebitor status changed
    const currentHasDebitor = hasDebitorAttribute.getValue();
    if (previousHasDebitor !== currentHasDebitor) {
        const mockExecutionContext = { getFormContext: () => formContext };
        Schulz.QuoteForm.filterCustomerIdLookup(mockExecutionContext);
    }

    // Only show notification if sst_hasdebitor_opt is false
    if (currentHasDebitor === false) {
        formContext.ui.setFormNotification("In diesem Mandanten gibt es keinen Debitor für diese Firma.", "WARNING", "MissingDebitorNotification");
    }

    Schulz.QuoteForm.clearDefaultSalesTaxPercentage(formContext);
};

Schulz.QuoteForm.fillERPRoleFields = (executionContext) => {
    const formContext = executionContext.getFormContext();

    const debitorLookup = formContext.getAttribute("sst_debitor_id").getValue();
    if (!debitorLookup) return;

    const erpRoleId = Schulz.QuoteForm.extractId(debitorLookup);
    if (!erpRoleId) return;

    // Check if we need to fill payment terms or delivery terms
    const needsPaymentTerms = formContext.getAttribute("msdyn_paymentterms").getValue() === null;
    const needsDeliveryTerms = formContext.getAttribute("sst_termsofdelivery_id").getValue() === null;

    if (!needsPaymentTerms && !needsDeliveryTerms) return;

    const query = `?$select=sst_paymentterms_id,sst_termsofdelivery_id,sst_erproleid&$top=1&$filter=sst_erproleid eq '${erpRoleId}'&$expand=sst_paymentterms_id($select=msdyn_paymenttermid,msdyn_name),sst_termsofdelivery_id($select=msdyn_termscode,msdyn_termsofdeliveryid)`;

    Xrm.WebApi.retrieveMultipleRecords("sst_erprole", query)
        .then(result => {
            if (result.entities?.length > 0) {
                const erpRole = result.entities[0];

                // Set payment terms if needed and available
                if (needsPaymentTerms && erpRole.sst_paymentterms_id) {
                    const paymentTerms = {
                        id: erpRole.sst_paymentterms_id.msdyn_paymenttermid,
                        entityType: "msdyn_paymentterm",
                        name: erpRole.sst_paymentterms_id.msdyn_name
                    };
                    formContext.getAttribute("msdyn_paymentterms").setValue([paymentTerms]);
                }

                // Set delivery terms if needed and available
                if (needsDeliveryTerms && erpRole.sst_termsofdelivery_id) {
                    const deliveryTerms = {
                        id: erpRole.sst_termsofdelivery_id.msdyn_termsofdeliveryid,
                        entityType: "msdyn_termsofdelivery",
                        name: erpRole.sst_termsofdelivery_id.msdyn_termscode
                    };
                    formContext.getAttribute("sst_termsofdelivery_id").setValue([deliveryTerms]);
                }
            }
        })
        .catch(error => {
            console.error("Error filling ERP role fields:", error);
        });
};

Schulz.QuoteForm.fillDefaultSalesTaxPercentage = (formContext, salesTaxGroupRef) => {
    if (salesTaxGroupRef) {
        Xrm.WebApi.retrieveRecord("msdyn_taxgroup", salesTaxGroupRef, "?$select=hso_defaultsalestaxcodepercentage")
            .then(result => {
                formContext.getAttribute("hso_salestaxcodepercentage").setValue(result["hso_defaultsalestaxcodepercentage"]);
            }, error => {
                console.log(error.message);
            });
    }
    else {
        Schulz.QuoteForm.clearDefaultSalesTaxPercentage(formContext);
    }
};

Schulz.QuoteForm.clearDefaultSalesTaxPercentage = (formContext) => {
    formContext.getAttribute("hso_salestaxcodepercentage").setValue(null);
};

