    formContext.getAttribute(fieldName).setRequiredLevel('required');
};

// Generic function to reset a option field (null)
// Function called by other functions from within this library
function clearField(formContext, fieldName) {
    formContext.getAttribute(fieldName).setValue(null);
};

// Generic function to reset a field (false)
// Function called by other functions from within this library
function clearFieldOption(formContext, fieldName) {
    formContext.getAttribute(fieldName).setValue(false);
};

// Generic function to enable a specific field
// Function called by other functions from within this library
function enableField(formContext, fieldName) {
    formContext.getControl(fieldName).setDisabled(false);
};

// Generic function to disable a specific field
// Function called by other functions from within this library
function disableField(formContext, fieldName) {
    formContext.getControl(fieldName).setDisabled(true);
};

// Generic function to hide a specific field 
//(for multiple Fields, e.g. 2 Fields for 'hso_productid')
// Function called by other functions from within this library
function hideMultipleFields(formContext, fieldName) {
    formContext.getAttribute(fieldName).controls.forEach(
        function (control, i) {
            control.setVisible(false);;
        });
};

// Generic function to show a specific field 
//(for multiple Fields, e.g. 2 Fields for 'hso_productid')
// Function called by other functions from within this library
function showMultipleFields(formContext, fieldName) {
    formContext.getAttribute(fieldName).controls.forEach(
        function (control, i) {
            control.setVisible(true);;
        });
};

// Generic function to hide a specific field 
//(for multiple Fields, e.g. 2 Fields for 'hso_productid')
// Function called by other functions from within this library
function disableMultipleFields(formContext, fieldName) {
    formContext.getAttribute(fieldName).controls.forEach(
        function (control, i) {
            control.setDisabled(true);;
        });
