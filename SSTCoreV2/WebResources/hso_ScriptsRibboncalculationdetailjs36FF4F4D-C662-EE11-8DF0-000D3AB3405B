// open the Article Search App from Subgrid of selected Calculation Position
Schulz.CalculationPositionRibbon.openItemSearchApp = (formContext) => {
    console.log("Open Article Search App initiated...");
    console.log("InputParameter: " + formContext);
    //Get Calculation Position GUID and remove {}
    var selectedRecordID = formContext.data.entity.getId().replace(/[{}]/g, "");
    console.log("Calculation Position GUID: " + selectedRecordID);

    Xrm.WebApi.retrieveMultipleRecords("canvasapp", "?$filter=name eq 'hso_vendorcatalogmanagementmaster_1ea70'&$select=uniquecanvasappid")
        .then(results => {
            if (results.entities && results.entities.length > 0) {
                var articleSearchAppRecord = results.entities[0];
                var RetrieveEnvironmentVariableValueRequestResponse = articleSearchAppRecord.uniquecanvasappid;

                console.log("Articlesearch App ID = " + articleSearchAppRecord.uniquecanvasappid);

                var CompanyName = formContext.getAttribute("hso_companyid").getValue()[0].name;
                console.log("Company Name = " + CompanyName);
                var URL = "https://apps.powerapps.com/play/" + RetrieveEnvironmentVariableValueRequestResponse + "?source=iframe&cmp=" + CompanyName + "&EntityId=QC%23" + selectedRecordID
                console.log("URL = " + URL);
                //Creating An Object For Storing Window Height & Width
                var openUrlOptions = {
                    height: 1366,
                    width: 1024
                };
                //Using openURL Client API To Open The Website.
                Xrm.Navigation.openUrl(URL, openUrlOptions);
            }
        }, error => {
            Xrm.Utility.alertDialog(error.message);
        }
        );
};

// call custom API to delete all selected records in bulk
Schulz.CalculationPositionRibbon.callCustomAPIExecuteOperation_BulkDelete = (PrimaryControl, SelectedControlSelectedItemIds, OperationName, OperationType) => {
    console.log("Operation: " + OperationName + " (" + OperationType + ")");
    // Operation Types
    // 0 - SingleDelete
    // 1 - SingleSetDefaultValues
    // 2 - SingleRecalculateNode
    // 3 - BulkDelete
    // 4 - BulkSetDefaultValues
    // 5 - BulkRecalculateNode

    // Confirm action with the user
    var confirmStrings = { text: "Möchten Sie die ausgewählten Kalkulationspositionen löschen? Diese Aktion kann nicht rückgängig gemacht werden.", title: "Kalkulationspositionen löschen bestätigen" };
    var confirmOptions = { height: 200, width: 450 };
    Xrm.Navigation.openConfirmDialog(confirmStrings, confirmOptions).then(
        function (success) {
            if (success.confirmed) {
                // Get Grid context
                let gridContext = PrimaryControl.getControl("subordinentposition_subgrid");
                console.log(gridContext);

                // Show Progress Indicator
                Xrm.Utility.showProgressIndicator("Kalkulationsposition wird gelöscht...");

                // Prepare the payload
                const payload = {
                    OperationType: OperationType,
                    Records: SelectedControlSelectedItemIds
                };

                const payloadString = JSON.stringify(payload);
                console.log("Payload to send:", payloadString);

                // Create the API request
                let hso_CalculationdetailExecuteOperationAPIRequest = new Schulz.CalculationPositionRibbon.hso_CalculationdetailExecuteOperation(payloadString);

                // Call the Custom API
                Xrm.WebApi.online.execute(hso_CalculationdetailExecuteOperationAPIRequest).then(
                    function (result) {
                        result.json().then(function (response) {
                            console.log("Custom API successfully called with operation: " + OperationName);
                            console.log("Response from API:", response);

                            // --- Safe parse of API response property ---
                            let parsedResponse;
                            try {
                                parsedResponse = JSON.parse(response.hso_CalculationdetailApiResponseProperty);
                            } catch (e) {
                                console.error("Failed to parse hso_CalculationdetailApiResponseProperty:", e);
                                Xrm.Utility.closeProgressIndicator();
                                Xrm.Navigation.openErrorDialog({
                                    details: e.message,
                                    message: "Ungültige Antwort vom Server (JSON-Parsing fehlgeschlagen)."
                                });
                                return; // stop further handling
                            }

                            // --- Branch 1: Open dialog on exact success message ---
                            const TargetEnvironment = "AzureFunction";
                            if (parsedResponse.Success === true && parsedResponse.TargetEnvironment === TargetEnvironment) {
                                // Close progress indicator before opening dialog
                                Xrm.Utility.closeProgressIndicator();

                                const pageInput = {
                                    pageType: "custom",
                                    name: "hso_pqcprocessingprogress_e20dc",
                                    entityName: "hso_processinglog",
                                    recordId: parsedResponse.ProcessingLogId
                                };
                                const navigationOptions = {
                                    target: 2,    // Dialog
                                    position: 1,
                                    width: 850,
                                    height: 500,
                                    title: "Verarbeitungsfortschritt"
                                };

                                console.log("Opening custom page:", pageInput.name);
                                console.log("RecordId:", pageInput.recordId);
                                console.log("Navigation options:", navigationOptions);

                                Xrm.Navigation.navigateTo(pageInput, navigationOptions).then(function () {
                                        // Dialog closed by user: refresh data & notifications
                                        PrimaryControl.data.refresh(false).then(() => {
                                            console.log("Form data refreshed (after progress dialog).");
                                            Schulz.CalculationForm.displayFormNotification(PrimaryControl);
                                        });
                                    }).catch(function (error) {
                                        console.error("Navigation error: " + error.message);
                                        // Optional: show an alert on navigation error
                                        Schulz.CalculationPositionRibbon.openAlertDialog({
                                            confirmButtonLabel: "OK",
                                            text: "Die Fortschrittsansicht konnte nicht geöffnet werden: " + error.message,
                                            title: "Navigation fehlgeschlagen"
                                        });
                                    });

                                return; // IMPORTANT: prevent falling through to alert branch
                            } else if (parsedResponse.Success === true) {
                                console.log("Operation succeeded:", parsedResponse.Message);
                                // --- Branch 2: Default success/error alert handling ---
                                const alertStrings = (parsedResponse.Success === true)
                                    ? {
                                        confirmButtonLabel: "OK",
                                        text: parsedResponse.Message ?? "Aktion erfolgreich ausgeführt.",
                                        title: "Kalkulationspositionen löschen"
                                    }
                                    : {
                                        confirmButtonLabel: "OK",
                                        text: parsedResponse.Message ?? "Es ist ein Fehler aufgetreten.",
                                        title: ResultDialogMessage_Error
                                    };

                                // Close progress indicator and show alert
                                Xrm.Utility.closeProgressIndicator();
                                Schulz.CalculationPositionRibbon.openAlertDialog(alertStrings);

                                // Refresh the form after alert closes
                                PrimaryControl.data.refresh(false).then(() => {
                                    console.log("Form data refreshed.");
                                    // Trigger function in Form_Calculation.js to refresh Form Notifications
                                    Schulz.CalculationForm.displayFormNotification(PrimaryControl);
                                });
                            }
                        });
                    },
                    function (error) {
                        console.error("Error calling the Custom API:", error);
                        Xrm.Utility.closeProgressIndicator();
                        Xrm.Navigation.openErrorDialog({
                            details: error.message,
                            message: "An error occurred while calling the hso_CalculationAPI Custom API."
                        });
                    }
                );
            }
        });
};

