        'hso_product_metallabelid',
        'hso_product_metalbase',
        'hso_product_metalnumber',
        'hso_calculationmetalpriceid',
        'hso_product_metalsurchargeperunit',
        'hso_product_metallabelid_2',
        'hso_product_metalbase_2',
        'hso_product_metalnumber_2',
        'hso_calculationmetalpriceid_2',
        'hso_product_metalsurchargeperunit_2',
        'hso_product_metallabelid_3',
        'hso_product_metalbase_3',
