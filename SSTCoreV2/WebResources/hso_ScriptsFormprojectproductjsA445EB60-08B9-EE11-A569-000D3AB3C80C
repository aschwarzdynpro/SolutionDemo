Schulz.ProjectProductForm.formOnLoad = (executionContext, formType) => {
        var formContext = executionContext.getFormContext();
        //Fetch Company ID for product filtering
        Schulz.ProjectProductForm.FetchCompanyID(executionContext);

        console.log("Form Type: " + formType);
        if (formType == "IsQuickCreateForm") {
                // initially all Fields, Section that are visible or hidden for Quick Create Form
                // initially Fields that are required or not required for Quick Create Form
                Schulz.ProjectProductForm.setFieldVisibility_QuickCreateForm(formContext);
                // onChange Event Handler for ProjectProducttype
                formContext.getAttribute("hso_isbillofmaterials")?.addOnChange(Schulz.ProjectProductForm.onChangeProjectProductType_QuickCreateForm);

        } else {
                // initially all Fields, Section that are visible or hidden for Main Form
                // initially Fields that are required or not required for Main Form
                Schulz.ProjectProductForm.setFieldVisibility_MainForm(formContext);
                // initially Tab's and Field to enable/disable 
                Schulz.ProjectProductForm.setFieldMode(executionContext);
                // onChange Event Handler for ProjectProducttype
                formContext.getAttribute("hso_isbillofmaterials")?.addOnChange(Schulz.ProjectProductForm.onChangeProjectProductType_MainForm);
                // onChange Event Handler for ProjectProduct Calculation
                formContext.getAttribute("hso_calculationid")?.addOnChange(Schulz.ProjectProductForm.onChangeCalculation_MainForm);
                // onChange Event Handler for ProjectProduct Template
                formContext.getAttribute("hso_templateid")?.addOnChange(Schulz.ProjectProductForm.onChangeTemplate_MainForm);
        }
};

// initially all Fields, Section that are visible or hidden for Main Form
// initially Fields that are required or not required for Main Form
