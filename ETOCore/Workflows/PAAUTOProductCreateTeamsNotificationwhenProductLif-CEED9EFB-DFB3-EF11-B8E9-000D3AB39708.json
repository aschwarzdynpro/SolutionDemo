{
  "properties": {
    "connectionReferences": {
      "shared_teams_1": {
        "runtimeSource": "embedded",
        "connection": {
          "connectionReferenceLogicalName": "hso_ConRefTeamsArticlesearch"
        },
        "api": {
          "name": "shared_teams"
        }
      },
      "shared_commondataserviceforapps_1": {
        "runtimeSource": "embedded",
        "connection": {
          "connectionReferenceLogicalName": "hso_ConnRefProjectQuoteCalculationDataverse"
        },
        "api": {
          "name": "shared_commondataserviceforapps"
        }
      }
    },
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "parameters": {
        "$connections": {
          "defaultValue": {},
          "type": "Object"
        },
        "$authentication": {
          "defaultValue": {},
          "type": "SecureObject"
        },
        "EnvVar | Dataverse Instance (hso_EnvVarDataverseInstance)": {
          "defaultValue": "operations-d365-ETO-int-11.crm4.dynamics.com",
          "type": "String",
          "metadata": {
            "schemaName": "hso_EnvVarDataverseInstance",
            "description": "The Dataverse Instance to connect to within a Flow when using Web API Calls"
          }
        },
        "EnvVar | Product Lifecycle Alert | Team ID (hso_EnvVarProductLifecycleAlertTeamID)": {
          "defaultValue": "c2f513c7-ee83-4480-add4-0bcedd6d4327",
          "type": "String",
          "metadata": {
            "schemaName": "hso_EnvVarProductLifecycleAlertTeamID",
            "description": "Die Team ID für Team \"T_ERP_Angebotskalkulation\""
          }
        },
        "EnvVar | Product Lifecycle Alert | Teams Channel ID (hso_EnvVarProductLifecycleAlertTeamsChannelID)": {
          "defaultValue": "19:RnSRUBeRXR8nr7pSq5XFPOzZRWAjPuexuRRl_qiqlI41@thread.tacv2",
          "type": "String",
          "metadata": {
            "schemaName": "hso_EnvVarProductLifecycleAlertTeamsChannelID",
            "description": "Die Channel ID für Kanal \"Alert Artikel-Produkte-Vorlagen\""
          }
        }
      },
      "triggers": {
        "When_a_Product_Lifecycle_is_updated": {
          "metadata": {
            "operationMetadataId": "001e165f-bf1b-4ce3-a857-453dee438f9f"
          },
          "type": "OpenApiConnectionWebhook",
          "inputs": {
            "host": {
              "connectionName": "shared_commondataserviceforapps_1",
              "operationId": "SubscribeWebhookTrigger",
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
            },
            "parameters": {
              "subscriptionRequest/message": 3,
              "subscriptionRequest/entityname": "product",
              "subscriptionRequest/scope": 4,
              "subscriptionRequest/filteringattributes": "hso_productlifecyclestateid",
              "subscriptionRequest/filterexpression": "hso_productlifecyclestate_calc ne 'Aktiv'"
            },
            "authentication": "@parameters('$authentication')"
          }
        }
      },
      "actions": {
        "Compose_Product_URL": {
          "runAfter": {},
          "metadata": {
            "operationMetadataId": "977e7486-2ade-40ae-ad15-9255d5343b3d"
          },
          "type": "Compose",
          "inputs": "@concat('https://',parameters('EnvVar | Dataverse Instance (hso_EnvVarDataverseInstance)'),'/main.aspx?pagetype=entityrecord&etn=product&id=',triggerOutputs()?['body/productid'])"
        },
        "Post_Product_Lifecycle_Alert_message_in_channel": {
          "runAfter": {
            "Compose_Product_URL": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "7377abab-7ed2-43f1-ba3d-ab74da49f4d7"
          },
          "type": "OpenApiConnection",
          "inputs": {
            "host": {
              "connectionName": "shared_teams_1",
              "operationId": "PostMessageToConversation",
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_teams"
            },
            "parameters": {
              "poster": "User",
              "location": "Channel",
              "body/recipient/groupId": "@parameters('EnvVar | Product Lifecycle Alert | Team ID (hso_EnvVarProductLifecycleAlertTeamID)')",
              "body/recipient/channelId": "@parameters('EnvVar | Product Lifecycle Alert | Teams Channel ID (hso_EnvVarProductLifecycleAlertTeamsChannelID)')",
              "body/messageBody": "<p>Der Produktlebenszyklus für Artikel \"@{triggerOutputs()?['body/name']}\" (Artikelnummer: @{triggerOutputs()?['body/msdyn_itemnumber']}) wurde geändert.<br>\n<br>\nProdukt <a href=\"@{outputs('Compose_Product_URL')}\">&lt;hier&gt;</a> öffnen<br>\n<br>\nBetroffene Kalkulationspositionen und Vorlagenpositionen sollten bzgl. dem auslaufenden Produktlebenszyklus überprüft und ggfs. angepasst werden.</p>",
              "body/subject": "Produktlebenszyklus Warnung: @{triggerOutputs()?['body/name']} (Artikelnummer: @{triggerOutputs()?['body/msdyn_itemnumber']})"
            },
            "authentication": "@parameters('$authentication')"
          }
        }
      }
    },
    "templateName": ""
  },
  "schemaVersion": "1.0.0.0"
}