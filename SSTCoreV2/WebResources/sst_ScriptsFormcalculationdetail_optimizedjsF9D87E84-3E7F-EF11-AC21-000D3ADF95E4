// initially all Fields that are visible or hidden for Main Form (Form in Form)
// Function called by 'formOnLoad' from within this library
// Function triggered in the Calculation Position form onChange event handler for field hso_positionelementtype
Schulz.CalculationPositionForm.setFieldVisibility_MainFormInForm = (executionContext) => {
    // get the form context
    var formContext = executionContext.getFormContext();
    let Status = formContext.getAttribute('statecode').getValue();
    let ElementType = formContext.getAttribute('hso_positionelementtype').getValue();
    // get Element Type BOM
    let ElementtypeBOM = formContext.getAttribute('hso_isbillofmaterial').getValue();
    // set Project Type to required according to Level
    let Level = formContext.getAttribute("hso_level").getValue();
    if (Level == 1) {
        requiredField(formContext, 'hso_projecttype')
    } else {
        disableField(formContext, 'hso_projecttype');
        noneField(formContext, 'hso_projecttype');
    };
    // set Measurement Product according to Project Type
    let ProjectType = formContext.getAttribute("hso_projecttype").getValue();
    if (ProjectType == 100000001) {
        enableField(formContext, 'hso_measurementproduct');
    } else {
