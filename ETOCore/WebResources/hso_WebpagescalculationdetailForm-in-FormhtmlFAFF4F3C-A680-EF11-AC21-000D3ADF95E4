<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Model-driven Fluent UI Icons with Helper</title>
    <style>
        .ribbon-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background-color: transparent;
            border: none;
            font-family: 'Segoe UI', sans-serif;
            font-size: 14px;
            color: #323130;
            cursor: pointer;
            padding: 6px 12px;
            border-radius: 3px;
            transition: background-color 0.2s, color 0.2s;
        }

        .ribbon-button:hover {
            background-color: #f3f2f1;
            color: #0078d4;
        }

        .ribbon-button img {
            width: 16px;
            height: 16px;
            margin-right: 6px;
        }

        .button-container {
            display: flex;
            justify-content: flex-end;
            gap: 8px;
            padding: 0;
        }
    </style>
</head>

<body>
    <div class="button-container">
        <button class="ribbon-button" title="Save" aria-label="Save" onclick="saveFormComponent()">
            <img id="save-icon" alt="Save Icon">
            <span>Save</span>
        </button>
        <button class="ribbon-button" title="Refresh" aria-label="Refresh" onclick="refreshFormComponent()">
            <img id="refresh-icon" alt="Refresh Icon">
            <span>Refresh</span>
        </button>
        <button class="ribbon-button" title="Search & Replace" aria-label="Search & Replace"
            onclick="handleSearchAndReplace()">
            <img id="searchreplace-icon" alt="Search & Replace Icon">
            <span>Search & Replace</span>
        </button>
    </div>

    <script>
        function getFluentIconUrl(iconName, hash = '') {
            const base = "https://content.powerapps.com/resource/uci-infra-web/resources/images/";
            return `${base}${iconName}${hash ? '.' + hash : ''}.svg`;
        }

        // Set icons dynamically using known hashes
        document.getElementById("save-icon").src = getFluentIconUrl("Save", "c3e8b193ccb83c8b1f680b864b3a3109");
        document.getElementById("refresh-icon").src = getFluentIconUrl("Refresh", "b68f8f8104b01abf8aa068d43e0d1417");
        document.getElementById("searchreplace-icon").src = getFluentIconUrl("Search And Apps", "76b3bd95d762087f6a5b8df91c53c973");

        function saveFormComponent() {
            if (window.parent.Xrm) {
                const formContext = window.parent.Xrm.Page;
                const formComponentControl = formContext.getControl("hso_navigationcalculationposition");
                if (formComponentControl) {
                    formComponentControl.data.entity.save(1);
                } else {
                    console.error("Form component control not found.");
                }
            }
        }

        function refreshFormComponent() {
            if (window.parent.Xrm) {
                const formContext = window.parent.Xrm.Page;
                const formComponentControl = formContext.getControl("hso_navigationcalculationposition");
                if (formComponentControl) {
                    formComponentControl.refresh();
                } else {
                    console.error("Form component control not found.");
                }
            }
        }

        function handleSearchAndReplace() {
            if (typeof window.parent.Xrm !== "undefined" && window.parent.Xrm !== null) {
                const formContext = window.parent.Xrm.Page;
                const formComponentControl = formContext.getControl("hso_navigationcalculationposition");
                if (formComponentControl) {
                    const entity = formComponentControl.data.entity;
                    const positionType = entity.attributes.get("hso_positionelementtype")?.getValue();
                    const recordTitle = entity.attributes.get("hso_name")?.getValue() || "this record";
                    const recordId = entity.getId()?.replace(/[{}]/g, "");

                    if (positionType === 100000006) {
                        const confirmed = confirm(`Do you want to open the Search & Replace side pane for '${recordTitle}'?`);
                        if (!confirmed) return;

                        const paneId = "CalculationSearchAndReplace_SidePanel";
                        const existingPane = window.parent.Xrm.App.sidePanes.getPane(paneId);

                        if (existingPane) {
                            existingPane.navigate({
                                pageType: "custom",
                                name: "hso_calculationpositionsearchreplace_aaddb",
                                recordId: recordId,
                                hidden: false
                            });
                        } else {
                            window.parent.Xrm.App.sidePanes.createPane({
                                title: "Search & Replace",
                                paneId: paneId,
                                imageSrc: "WebResources/hso_searchreplace_icon",
                                hideHeader: false,
                                canClose: true,
                                width: 1200,
                                isSelected: true,
                                hidden: false
                            }).then((pane) => {
                                pane.navigate({
                                    pageType: "custom",
                                    name: "hso_calculationpositionsearchreplace_aaddb",
                                    recordId: recordId,
                                    hidden: false
                                });
                            });
                        }
                    } else {
                        alert("Search & Replace is not allowed for this position element type. Open the search & replace side pane either for the whole calculation version via the ribbon bar or for a specific title.");
                    }
                } else {
                    console.error("Form component control not found.");
                }
            } else {
                console.error("Xrm context is not available. Make sure this page is hosted inside a model-driven app form.");
            }
        }
    </script>
</body>

</html>