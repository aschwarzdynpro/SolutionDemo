ETO.ContactForm.deliveryAdressLocked = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let difadressbool = formContext.getAttribute("hso_differentdeliveradress_bool").getValue();
    let quickViewControl = formContext.getAttribute("hso_useaccountaddress_bol").getValue();
    let customerTypeCodeAttribute = formContext.getAttribute("customertypecode");
    if (customerTypeCodeAttribute?.getValue() != 3) {
        ETO.ContactForm.deliveryAdressfields.forEach(field => {
            let attribute = formContext.getAttribute(field);

            ETO.ContactForm.controlDisabled(attribute, !difadressbool);
        });
        if (!difadressbool && !quickViewControl) {
            formContext.getAttribute("address1_name").setValue(formContext.getAttribute("address2_name").getValue());
            formContext.getAttribute("address1_line1").setValue(formContext.getAttribute("address2_line1").getValue());
            formContext.getAttribute("address1_line2").setValue(formContext.getAttribute("address2_line2").getValue());
            formContext.getAttribute("address1_postalcode").setValue(formContext.getAttribute("address2_postalcode").getValue());
            formContext.getAttribute("address1_city").setValue(formContext.getAttribute("address2_city").getValue());
            if (formContext.getAttribute("hso_address2_country_id").getValue() != null) {
                formContext.getAttribute("hso_address1country_ref").setValue(formContext.getAttribute("hso_address2_country_id").getValue());
            }
        }
    }
};

ETO.ContactForm.defaultAddressname = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let contactname = formContext.getAttribute("firstname").getValue() + " " + formContext.getAttribute("lastname").getValue();
    if (formContext.getAttribute("address2_name").getValue() == null && !formContext.getAttribute("hso_useaccountaddress_bol").getValue()) {
        formContext.getAttribute("address2_name").setValue(contactname);
    }
};