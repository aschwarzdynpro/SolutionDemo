            ]
          },
          "metadata": {
            "operationMetadataId": "13505fef-dc98-4121-a092-2f1cf5c09362"
          },
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "strResponseMsg",
                "type": "string"
              }
            ]
          }
        },
        "Init_strStatus": {
          "runAfter": {
            "Init_strResponseMsg": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "af3cb277-6ee7-4339-8718-401c3a2c4541"
