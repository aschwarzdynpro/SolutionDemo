// Set Default Quantity for new Calculation Position
// Function called by other function 'onChangeElementType_MainForm'/'onChangeElementType_QuickCreateForm' from within this library
Schulz.CalculationPositionForm.setDefaultQuantity = (executionContext) => {
    // get the form context
    var formContext = executionContext.getFormContext();
    // get the current Calculation
    let Calculation = formContext.getAttribute("hso_calculationid").getValue()[0].id;
    // format Calculation GUID
    Calculation = Calculation.replace(/[{}]/g, "");
    // get selected Position Element Type
    let ElementType = formContext.getAttribute("hso_positionelementtype").getValue();
    // get Quantity (if already set)
    let Quantity = formContext.getAttribute("hso_quantity").getValue();

    if (ElementType != null && ElementType != 100000005 && Quantity == null) {
        // Position Element Type not empty or 'Others' and Quantity empty
        // default Quantity to 1
        formContext.getAttribute("hso_quantity").setValue(1);
        Quantity = 1;
    } else {
        formContext.getAttribute("hso_quantity").setValue(0);
        Quantity = 0;
    };
    // get Position Quantity of Parent Calculation Position if Parent is set
    if (formContext.getAttribute("hso_calculationdetail_parentid").getValue() != null) {
        // get the parent calculation position
        let ParentCalculationPosition = formContext.getAttribute("hso_calculationdetail_parentid").getValue()[0].id;

        Schulz.CalculationPositionForm.retrieveParentCalculationPosition_Quantity(ParentCalculationPosition).then(function (ParentCalculationPosition_PositionQuantity) {
            // calculate Position Quantity
            calculatedPositionQuantity = Quantity * ParentCalculationPosition_PositionQuantity;
            calculatedPositionQuantity = Number(calculatedPositionQuantity.toFixed(5));
            // set Position Quantity to calculated value
            formContext.getAttribute("hso_positionquantity").setValue(calculatedPositionQuantity);
            // set Parent Quantity to retrieved value
            ParentCalculationPosition_PositionQuantity = Number(ParentCalculationPosition_PositionQuantity.toFixed(5));
            formContext.getAttribute("hso_parentquantity").setValue(ParentCalculationPosition_PositionQuantity);
        }).catch(function (error) {
            alert(error.message);
        });
    } else {
        // set Position Quantity to (component) quantity
        Quantity = Number(Quantity.toFixed(5));
        formContext.getAttribute("hso_positionquantity").setValue(Quantity);
    };
    // Set Default Duration in Minutes for Calculation Position
    Schulz.CalculationPositionForm.setDurationInMinutes(formContext);
};

