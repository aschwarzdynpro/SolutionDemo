if (typeof (Schulz) === "undefined") { Schulz = {}; };
if (typeof (Schulz.Common) === "undefined") { Schulz.Common = {}; }

Schulz.Common.phoneNumberValidator = (executionContext) => {
    let attribute = executionContext.getEventSource();
    let value = attribute?.getValue();
    if (value !== null)
    {
        value = value.replace(/\s+|-/g, '');
        attribute.setValue(value);
    }

    if((value && /^\+[0-9 ]{5,17}$/.test(value) == true) || value == null || value.length == 0){
        attribute?.controls.forEach(control => {
            control.clearNotification(`phoneNumberValidator-${control.getName()}`);
        });
    } else {
        attribute?.controls.forEach(control => {
            control.setNotification("Ungültige Telefonnummer. Format: +XXXXXXXXXXXXXXX", `phoneNumberValidator-${control.getName()}`);
        });
    }
};

Schulz.Common.disableAllFields = (formContext) => {
    var formControls = formContext.getControl();

    formControls.forEach(control => {
        control.setDisabled(true);
    });
};

Schulz.Common.filterUOM = (executionContext, lookupName) => {
    let formContext = executionContext.getFormContext();
    let uomLookup = formContext.getControl(lookupName);
    uomLookup?.addPreSearch(Schulz.Common.uompreSearch);
};

Schulz.Common.uompreSearch = (executionContext) => {
    let uomLookupControl = executionContext.getEventSource();
    let filter = "<filter type='and'><condition attribute='msdyn_symbol' operator='not-like' value='UOM%' /></filter>";
    uomLookupControl.addCustomFilter(filter);
};

Schulz.Common.showWarningOnCreateOfSalesOrderProduct = (executionContext) => {
    let formContext = executionContext.getFormContext();
    let isCreateForm = formContext.ui.getFormType() === 1;
    if (isCreateForm) {
        formContext.ui.setFormNotification("Berechnung von Einstandspreis und -betrag erfolgt nach dem ersten Speichern.", "INFO", "purchaseprice");
    }
};