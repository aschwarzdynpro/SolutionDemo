    return new Promise(function (resolve, reject) {
        // Get Quote
        Xrm.WebApi.retrieveRecord("quote", SelectedQuote, "?$select=name,_transactioncurrencyid_value,_hso_departmentid_value,_msdyn_company_value,msdyn_language&$expand=transactioncurrencyid($select=currencyname),hso_departmentid($select=hso_name),msdyn_Company($select=cdm_companycode)").then(
            function success(result) {
                Quote_Name = result.name;
                Quote_Currency_GUID = result._transactioncurrencyid_value;
                Quote_Currency_Name = result.transactioncurrencyid.currencyname;
                Quote_Department_GUID = result._hso_departmentid_value;
                Quote_Department_Name = result.hso_departmentid.hso_name;
                Quote_Company_GUID = result._msdyn_company_value;
                Quote_Company_Name = result.msdyn_Company.cdm_companycode;
                Quote_Language = result.msdyn_language;
                resolve(result.name);
            },
            function error(error) {
                reject(error);
            });
    })
};

Schulz.CalculationRibbon.callCustomAPIExecuteOperation = (PrimaryControl, FirstPrimaryItemId, OperationName, OperationType) => {
    // Format Calculation GUID by removing "{" and "}"
    let CalculationGUID = FirstPrimaryItemId.replace(/[{}]/g, "")
    console.log("Operation: " + OperationName + " (" + OperationType + ")");
    // Operation Types
    // 0 - SingleDelete
    // 1 - SingleSetDefaultValues
    // 2 - SingleRecalculateNode
    // 3 - BulkDelete
    // 4 - BulkSetDefaultValues
    // 5 - BulkRecalculateNode

    // Confirm action with the user
    let confirmTitle = "";
    let confirmMessage = "";
    switch (OperationType) {
        case 4:
            confirmTitle = "Standardwerte setzen";
            confirmMessage = "Die Standardwerte werden für alle Kalkulationspositionen gesetzt. Anschließend wird eine komplette Neu-Berechnung der Kalkulationsversion durchgeführt.";
            break;
        case 5:
            confirmTitle = "Neu-Berechnung durchführen";
            confirmMessage = "Für die komplette Kalkulationsversion wird eine Neu-Berechnung durchgeführt.";
            break;
    };
    var confirmStrings = { text: confirmMessage, title: confirmTitle };
    var confirmOptions = { height: 200, width: 450 };
    Xrm.Navigation.openConfirmDialog(confirmStrings, confirmOptions).then(
        function (success) {
            if (success.confirmed) {
                // Search for Top Level Nodes of respective Calculation
                Xrm.WebApi.retrieveMultipleRecords("hso_calculationdetail", "?$select=hso_calculationdetailid,hso_name,hso_linenumber&$filter=_hso_calculationid_value eq '" + CalculationGUID + "' and hso_level eq 1").then(result => {
                    let records = [];
                    if (result && result.entities.length > 0) {
                        for (let i = 0; i < result.entities.length; i++) {
                            records.push(result.entities[i].hso_calculationdetailid);
                            console.log("Record Found: ", result.entities[i]);
                        }
                    } else {
                        console.log("No top-level records found for the calculation.");
                    }

                    // Display Progress Indicator (and block UI)
                    switch (OperationType) {
                        case 4:
                            Xrm.Utility.showProgressIndicator("Standardwerte setzen...");
                            break;
                        case 5:
                            Xrm.Utility.showProgressIndicator("Neu-Berechnung durchführen...");
                            break;
                    }

                    // Prepare the payload
                    const payload = {
                        OperationType: OperationType,
                        Records: records
                    };

                    const payloadString = JSON.stringify(payload);
                    console.log("Payload to send:", payloadString);

                    // Create the API request
                    let request = new Schulz.CalculationRibbon.hso_CalculationdetailExecuteOperation(payloadString);

                    // Call the Custom API
                    Xrm.WebApi.online.execute(request).then(
                        result => {
                            result.json().then(response => {
                                console.log("Custom API successfully called.", response);

                                // Parse JSON safely
                                let parsedResponse = JSON.parse(response.hso_CalculationdetailApiResponseProperty);

                                // Map operation type to readable title
                                const operationTitles = {
                                    0: "Position löschen",
                                    1: "Standardwerte setzen",
                                    2: "Neu-Berechnung durchführen",
                                    3: "Positionen löschen",
                                    4: "Standardwerte setzen",
                                    5: "Neu-Berechnung durchführen"
                                };

                                const alertTitle = operationTitles[OperationType] || "Aktion ausführen";
                                const alertText = parsedResponse.Message || "Keine Nachricht vom Server erhalten.";

                                // Build alert dialog
                                const alertStrings = {
                                    confirmButtonLabel: "OK",
                                    text: alertText,
                                    title: alertTitle
                                };

                                // Pull Processing Log State in 15sec intervalls until completed

                                // Show the alert dialog
                                Schulz.CalculationRibbon.openAlertDialog(alertStrings);
                                // Close Progress Indicator
                                Xrm.Utility.closeProgressIndicator();
                                // Refresh the Form
                                PrimaryControl.data.refresh(false).then(() => {
                                    console.log("Form data refreshed.");
                                    // Trigger function in Form_Calculation.js to refresh Form Notifications
                                    Schulz.CalculationForm.displayFormNotification(PrimaryControl);
                                });
                            },
                                error => {
                                    console.error("Error calling the Custom API:", error);
                                    Xrm.Utility.closeProgressIndicator();
                                    Xrm.Navigation.openErrorDialog({
                                        details: error.message,
                                        message: "An error occurred while calling the hso_CalculationdetailApi Custom API."
                                    });
                                }
                            );

                        },
                        error => {
                            console.error("Error retrieving records: ", error);
                        }
                    );
                })
            };
        });
};

