Schulz.QuoteForm.onLoad = (executionContext) => {
    let formContext = executionContext.getFormContext();

    Schulz.QuoteForm.registerEvents(formContext);
    Schulz.QuoteForm.requiredFieldsCheck(executionContext);
    Schulz.QuoteForm.debitorCheck(executionContext);
    //Schulz.QuoteForm.filterContact(executionContext);
    Schulz.QuoteForm.filterTextblocks(executionContext);
    Schulz.QuoteForm.hideTypespecificElements(executionContext);
    Schulz.QuoteForm.fillERPRoleFields(executionContext);
    Schulz.QuoteForm.setLocationIDtoDeliveryadress(executionContext);
    Schulz.QuoteForm.useAlternateAddress(executionContext);
    Schulz.QuoteForm.filterCustomerIdLookup(executionContext);
    //Schulz.QuoteForm.printPreviewLogicArticelsales(executionContext);
    Schulz.QuoteForm.notifyUserIfQuoteIsActiveAndWriteInProductsExist(executionContext);
    Schulz.QuoteForm.notifyUserIfProjectQuoteIsWon(formContext);
};

Schulz.QuoteForm.onSave = (executionContext) => {
    Schulz.QuoteForm.setTypeReadOnly(executionContext);
};

Schulz.QuoteForm.registerEvents = (formContext) => {
    formContext.getAttribute("msdyn_company")?.addOnChange(Schulz.QuoteForm.debitorCheck);
    formContext.getAttribute("customerid")?.addOnChange(Schulz.QuoteForm.validateCustomerTypeOnChange);
    formContext.getAttribute("customerid")?.addOnChange(Schulz.QuoteForm.debitorCheck);
    formContext.getAttribute("customerid")?.addOnChange(Schulz.QuoteForm.setLocationIDtoDeliveryadress);
    formContext.getAttribute("sst_debitor_id")?.addOnChange(Schulz.QuoteForm.fillERPRoleFields);
    formContext.getAttribute("sst_contactperson_id")?.addOnChange(Schulz.QuoteForm.prefilAccount);
    formContext.getAttribute("sst_footertextblock_id")?.addOnChange(Schulz.QuoteForm.setTextblockFooter);
    formContext.getAttribute("sst_headertextblock_id")?.addOnChange(Schulz.QuoteForm.setTextblockHeader);
    formContext.getAttribute("sst_angebotstyp_opt")?.addOnChange(Schulz.QuoteForm.hideTypespecificElements);
    //formContext.getAttribute("sst_angebotstyp_opt")?.addOnChange(Schulz.QuoteForm.printPreviewLogicArticelsales);
    //formContext.getAttribute("statecode")?.addOnChange(Schulz.QuoteForm.printPreviewLogicArticelsales);
    formContext.getAttribute("sst_alternativdelivery_opt")?.addOnChange(Schulz.QuoteForm.useAlternateAddress);
    formContext.getAttribute("sst_alternativdelivery_opt")?.addOnChange(Schulz.QuoteForm.setLocationIDtoDeliveryadress);
    formContext.getAttribute("msdyn_defaultshippingwarehouse").addOnChange(Schulz.QuoteForm.requiredFieldsCheck);
    formContext.getAttribute("msdyn_defaultshippingsite").addOnChange(Schulz.QuoteForm.requiredFieldsCheck);
    formContext.getAttribute("statecode").addOnChange(Schulz.QuoteForm.notifyUserIfQuoteIsActiveAndWriteInProductsExist);
    formContext.getAttribute("statecode").addOnChange(Schulz.QuoteForm.setPrintTypeToQuoteIfQuoteIsActive);
    formContext.getAttribute("hso_activecalculation_id").addOnChange(Schulz.QuoteForm.setStatusForActiveCalculation);
    formContext.getAttribute("sst_hasdebitor_opt")?.addOnChange(Schulz.QuoteForm.filterCustomerIdLookup);
};

