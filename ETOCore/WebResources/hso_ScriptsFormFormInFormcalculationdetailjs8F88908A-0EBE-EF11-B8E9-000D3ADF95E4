// Set Default Values for Calculation Position - selected Product (ARTIKELSTAMM) for Main Form
// Function triggered in the Calculation Position form onChange event handler for field hso_productid
ETO.CalculationPositionForm.onChangeProduct = (executionContext) => {
    // get the form context
    var formContext = executionContext.getFormContext();
    // get the current calculation and format GUID
    let Calculation = formContext.getAttribute("hso_calculationid").getValue();
    if (Calculation && Calculation.length > 0) {
        let Calculation_ID = Calculation[0].id;
        Calculation_ID = Calculation_ID.replace(/[{}]/g, "");

        if (formContext.getAttribute("hso_productid").getValue() != null) {
            // get the selected Product
            let SelectedProduct = formContext.getAttribute("hso_productid").getValue()[0].id;
            // get the Language (inherited from Parent Position)
            let SelectedProduct_Language = formContext.getAttribute("hso_language").getValue();
            // Fetch selected Product Details to set default values
            ETO.CalculationPositionForm.retrieveProduct(formContext, Calculation, SelectedProduct, SelectedProduct_Language);
        }
    } else {
        console.warn("Calculation is not set or invalid. Can't retrieve Product!");
    };
};

