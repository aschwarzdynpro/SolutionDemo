{
  "properties": {
    "connectionReferences": {
      "shared_commondataserviceforapps": {
        "api": {
          "name": "shared_commondataserviceforapps"
        },
        "connection": {
          "connectionReferenceLogicalName": "hso_ConnRefProjectQuoteCalculationDataverse"
        },
        "runtimeSource": "embedded"
      }
    },
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "parameters": {
        "$authentication": {
          "defaultValue": {},
          "type": "SecureObject"
        },
        "$connections": {
          "defaultValue": {},
          "type": "Object"
        }
      },
      "triggers": {
        "Calculation_Positions_Processing_Status_is_set_to_Open": {
          "type": "OpenApiConnectionWebhook",
          "inputs": {
            "parameters": {
              "subscriptionRequest/message": 3,
              "subscriptionRequest/entityname": "hso_calculationdetail",
              "subscriptionRequest/scope": 4,
              "subscriptionRequest/filteringattributes": "hso_processingstatus",
              "subscriptionRequest/filterexpression": "hso_processingstatus eq false and hso_level gt 1"
            },
            "host": {
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
              "operationId": "SubscribeWebhookTrigger",
              "connectionName": "shared_commondataserviceforapps"
            }
          },
          "metadata": {
            "operationMetadataId": "15f33913-dbbd-4569-9c08-31e7462ed6a1"
          }
        }
      },
      "actions": {
        "Parent_Calculation_Position_not_null": {
          "type": "If",
          "expression": {
            "not": {
              "equals": [
                "@triggerOutputs()?['body/_hso_calculationdetail_parentid_value']",
                "@null"
              ]
            }
          },
          "actions": {
            "Processing_Status_not_open_yet": {
              "type": "If",
              "expression": {
                "equals": [
                  "@outputs('Get_a_Parent_row_Calculation_Positions')?['body/hso_processingstatus']",
                  "@true"
                ]
              },
              "actions": {
                "Update_Calculation_Position": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "parameters": {
                      "entityName": "hso_calculationdetails",
                      "recordId": "@outputs('Get_a_Parent_row_Calculation_Positions')?['body/hso_calculationdetailid']",
                      "item/hso_processingstatus": false
                    },
                    "host": {
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                      "operationId": "UpdateRecord",
                      "connectionName": "shared_commondataserviceforapps"
                    }
                  },
                  "metadata": {
                    "operationMetadataId": "ac51d416-85cb-4887-b375-63e2c678ac37"
                  }
                }
              },
              "else": {
                "actions": {
                  "Terminate_because_Parent_is_already_up_to_date": {
                    "type": "Terminate",
                    "inputs": {
                      "runStatus": "Cancelled"
                    }
                  }
                }
              },
              "runAfter": {
                "Get_a_Parent_row_Calculation_Positions": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "92cfae8d-6d8b-41dc-8485-dcf9d7783e4d"
              }
            },
            "Get_a_Parent_row_Calculation_Positions": {
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "entityName": "hso_calculationdetails",
                  "recordId": "@triggerOutputs()?['body/_hso_calculationdetail_parentid_value']",
                  "$select": "hso_calculationdetailid, hso_processingstatus, hso_calculationdetail_parentid"
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                  "operationId": "GetItem",
                  "connectionName": "shared_commondataserviceforapps"
                }
              },
              "metadata": {
                "operationMetadataId": "824a9360-6e0c-4523-949e-564da687ee07"
              }
            }
          },
          "else": {
            "actions": {
              "Cancel": {
                "type": "Terminate",
                "inputs": {
                  "runStatus": "Cancelled"
                },
                "metadata": {
                  "operationMetadataId": "aad60300-86bf-4ad7-a549-315d8fa3ed3c"
                }
              }
            }
          },
          "runAfter": {},
          "metadata": {
            "operationMetadataId": "50468978-9630-416f-9994-d3d4c9db65f8"
          }
        }
      },
      "description": "Wird für eine Kalkulationsposition der Bearbeitungsstatus auf \"Offen\" gesetzt, wird der Bearbeitungsstatus des übergeordneten Knotenpunkts ebenfalls auf \"Offen\" sind."
    },
    "templateName": null
  },
  "schemaVersion": "1.0.0.0"
}