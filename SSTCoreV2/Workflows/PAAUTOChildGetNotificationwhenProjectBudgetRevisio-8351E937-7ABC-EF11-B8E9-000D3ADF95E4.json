          "metadata": {
            "operationMetadataId": "c03e7196-9df6-4d57-b944-504b6a364201"
          },
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "varApprovalDateTime",
                "type": "string",
                "value": "@replace(body('Parse_JSON')?['SerializedWorkflowDocumentData']?[6],'RequestedDate:','')"
              }
            ]
          }
        },
        "Initialize_varProjectID": {
          "runAfter": {
            "Initialize_varEventTime": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "dcd147e4-bda7-478c-8269-9dc8f6533be7"
          },
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "varProjectID",
                "type": "string",
                "value": "@trim(last(split(body('Parse_JSON')?['WorkflowStepInstruction'],':')))"
              }
            ]
          }
        },
        "Initialize_varComment": {
          "runAfter": {
            "Initialize_varFODeepLink": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "60a47e56-2630-416c-9b47-702bc883e03c"
          },
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "varComment",
                "type": "string",
                "value": "@body('Parse_JSON')?['WorkflowComment']"
              }
            ]
          }
        },
        "Create_HTML_table_approve": {
          "runAfter": {
            "Create_Array_for_Table": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "0fb4c960-e1d4-4a8d-8c5c-00fb12a37ed9"
          },
          "type": "Table",
          "inputs": {
            "from": "@variables('varArrayforTable')",
            "format": "HTML"
          }
        },
        "Initialize_varArrayforTable": {
          "runAfter": {
            "Initialize_varComment": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "f6bd3c4f-7de3-41e0-864c-f3a7d19267b1"
          },
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "varArrayforTable",
                "type": "array",
                "value": []
              }
            ]
          }
        },
        "Create_Array_for_Table": {
          "runAfter": {
            "Initialize_VarApproverName": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "a3c40820-05dd-4743-9c54-98e47a22bd6f"
          },
          "type": "AppendToArrayVariable",
          "inputs": {
            "name": "varArrayforTable",
            "value": {
              "Projekt": "@{variables('varProjectID')}",
              "Überarbeitungskennung": "@{variables('varBudgetRevisionID')}",
              "Datum": "@{variables('varEventTime')}",
              "Kommentar": "@{variables('varComment')}"
            }
          }
        },
        "Teams_Recipient": {
          "runAfter": {
            "Revision_Link": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "69c471d2-82e4-4cfd-8fa0-39203d74deb1"
          },
          "type": "Compose",
          "inputs": "@first(outputs('Get_Approver_Name_and_Email_Address')?['body/value'])?['internalemailaddress']",
          "description": "DO NOT DELETE"
        },
        "Check_if_needs_to_be_approved_or_was_rejected": {
          "actions": {
            "Post_message_to_Approver": {
              "runAfter": {},
              "metadata": {
                "operationMetadataId": "a234c4bd-dba6-4e51-902c-886a5db8334c"
              },
              "type": "OpenApiConnection",
              "inputs": {
                "host": {
                  "connectionName": "shared_teams_1",
                  "operationId": "PostMessageToConversation",
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_teams"
                },
                "parameters": {
                  "poster": "Flow bot",
                  "location": "Chat with Flow bot",
                  "body/recipient": "@outputs('Teams_Recipient')",
                  "body/messageBody": "<p class=\"editor-paragraph\"><b><strong class=\"editor-text-bold\">Budgetüberarbeitung </strong></b><strong>@{variables('varBudgetRevisionID')}</strong><b><strong class=\"editor-text-bold\"> liegt zur Genehmigung vor</strong></b></p><br><p class=\"editor-paragraph\">Hallo @{body('Parse_JSON_budget_revision_data')?['Prüfer']},</p><br><p class=\"editor-paragraph\">es liegt eine neue Budgetüberarbeitung von @{variables('varSubmitter')} zur Genehmigung vor. Hier findest du die Informationen zu der Budgetüberarbeitung:</p><br><p class=\"editor-paragraph\">@{body('Create_HTML_table_approve')}</p><br><br><p class=\"editor-paragraph\">Für weitere Infos: @{outputs('Revision_Link')}</p><br><p class=\"editor-paragraph\"><span style=\"font-size: 10px;\">*Systemgenerierte Nachricht, Fragen und Antworten in diesem Chat werden nicht bearbeitet.</span></p>"
                },
                "authentication": {
                  "type": "Raw",
                  "value": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$ConnectionKey']"
                }
              }
            },
            "Respond_to_Parent_Flow_-_Approval_pending": {
              "runAfter": {
                "Post_message_to_Approver": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "09eab139-9381-454f-b77d-0b6585b855be"
              },
              "type": "Response",
              "kind": "PowerApp",
              "inputs": {
                "statusCode": 200,
                "body": {
                  "result": "Success"
                },
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "title": "Result",
                      "x-ms-dynamically-added": true,
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "runAfter": {
            "Get_rejected_Project_Budget_Revision": [
              "Succeeded"
            ]
          },
          "else": {
            "actions": {
              "Update_created_project_budget_revision_to_reject": {
                "runAfter": {},
                "metadata": {
                  "operationMetadataId": "f4e0f031-2cfe-4d74-aa82-f1bd04b605fb"
                },
                "type": "OpenApiConnection",
                "inputs": {
                  "host": {
                    "connectionName": "shared_commondataserviceforapps_1",
                    "operationId": "UpdateRecord",
                    "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                  },
                  "parameters": {
                    "entityName": "sst_projbudgetrevisions",
                    "recordId": "@outputs('Update_Project_budgte_revision_approval')?['body/sst_projbudgetrevisionid']",
                    "item/sst_revisiondate": "@variables('varEventTime')",
                    "item/sst_uberarbeitungsstatus": 1
                  },
                  "authentication": {
                    "type": "Raw",
                    "value": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$ConnectionKey']"
                  }
                }
              },
              "Create_HTML_table_reject": {
                "runAfter": {
                  "Update_created_project_budget_revision_to_reject": [
                    "Succeeded"
                  ]
                },
                "metadata": {
                  "operationMetadataId": "0fb4c960-e1d4-4a8d-8c5c-00fb12a37ed9"
                },
                "type": "Table",
                "inputs": {
                  "from": "@array(outputs('Update_created_project_budget_revision_to_reject')?['body'])",
                  "format": "HTML",
                  "columns": [
                    {
                      "header": "Projekt",
                      "value": "@outputs('Update_created_project_budget_revision_to_reject')?['body/sst_foprojectid']"
                    },
                    {
                      "header": "Überarbeitungskennung",
                      "value": "@body('Update_created_project_budget_revision_to_reject')?['sst_revisionid']"
                    },
                    {
                      "header": "Anforderungsdatum",
                      "value": "@formatDateTime(convertTimeZone(outputs('Update_created_project_budget_revision_to_reject')?['body/sst_requesteddate'], 'UTC', 'W. Europe Standard Time'),'dd-MM-yyyy, HH:mm:ss')"
                    },
                    {
                      "header": "Ablehnungsdatum",
                      "value": "@formatDateTime(convertTimeZone(variables('varEventTime'), 'UTC', 'W. Europe Standard Time'),'dd-MM-yyyy, HH:mm:ss')"
                    },
                    {
                      "header": "Kommentar",
                      "value": "@body('Update_created_project_budget_revision_to_reject')?['sst_comment']"
                    }
                  ]
                }
              },
              "Get_user_reject": {
                "runAfter": {
                  "Create_HTML_table_reject": [
                    "Succeeded"
                  ]
                },
                "metadata": {
                  "operationMetadataId": "d8fc1232-962e-46d6-99e0-beddb8a03793"
                },
                "type": "OpenApiConnection",
                "inputs": {
                  "host": {
                    "connectionName": "shared_commondataserviceforapps_1",
                    "operationId": "ListRecords",
                    "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                  },
                  "parameters": {
                    "entityName": "systemusers",
                    "$select": "internalemailaddress",
                    "$filter": "internalemailaddress eq '@{body('Parse_JSON')?['WorkflowUserEmail']}'"
                  },
                  "authentication": {
                    "type": "Raw",
                    "value": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$ConnectionKey']"
                  }
                }
              },
              "Post_Message_to_Applicant": {
                "runAfter": {
                  "Get_user_reject": [
                    "Succeeded"
                  ]
                },
                "metadata": {
                  "operationMetadataId": "d943f404-4ff3-43db-b251-d70ab0c51a00"
                },
                "type": "OpenApiConnection",
                "inputs": {
                  "host": {
                    "connectionName": "shared_teams_1",
                    "operationId": "PostMessageToConversation",
                    "apiId": "/providers/Microsoft.PowerApps/apis/shared_teams"
                  },
                  "parameters": {
                    "poster": "Flow bot",
                    "location": "Chat with Flow bot",
                    "body/recipient": "@outputs('Get_user_reject')?['body/value']?[0]['internalemailaddress']",
                    "body/messageBody": "<p class=\"editor-paragraph\"><b><strong class=\"editor-text-bold\">Budgetüberarbeitung </strong></b><strong>@{variables('varBudgetRevisionID')}</strong><b><strong class=\"editor-text-bold\"> wurde abgelehnt</strong></b></p><br><p class=\"editor-paragraph\">Hallo @{outputs('Update_created_project_budget_revision_to_reject')?['body/sst_revisionitemowner']},</p><br><p class=\"editor-paragraph\">die Budgetüberarbeitung wurde von @{outputs('Update_created_project_budget_revision_to_reject')?['body/sst_controler']} abgelehnt. Hier findest du die Informationen zu der Budgetüberarbeitung:</p><br><p class=\"editor-paragraph\">@{body('Create_HTML_table_reject')}</p><br><br><p class=\"editor-paragraph\">Für weitere Infos: @{outputs('Revision_Link')}</p><br><p class=\"editor-paragraph\"><span style=\"font-size: 10px;\">*Systemgenerierte Nachricht, Fragen und Antworten in diesem Chat werden nicht bearbeitet.</span></p>"
                  },
                  "authentication": {
                    "type": "Raw",
                    "value": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$ConnectionKey']"
                  }
                }
              },
              "Resond_to_Parent_Flow-_Rejected": {
                "runAfter": {
                  "Post_Message_to_Applicant": [
                    "Succeeded"
                  ]
                },
                "metadata": {
                  "operationMetadataId": "e2891ffb-4228-41f4-ab8b-bb53519ae08d"
                },
                "type": "Response",
                "kind": "PowerApp",
                "inputs": {
                  "statusCode": 200,
                  "body": {
                    "result": "Success"
                  },
                  "schema": {
                    "type": "object",
                    "properties": {
                      "result": {
                        "title": "Result",
                        "x-ms-dynamically-added": true,
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "expression": {
            "and": [
              {
                "equals": [
                  "@empty(outputs('Get_rejected_Project_Budget_Revision')?['body/value'])",
                  true
                ]
              }
            ]
          },
          "metadata": {
            "operationMetadataId": "d65f2257-c522-455f-b0a9-c10866c9b9a5"
          },
          "type": "If"
        },
        "Get_project_ID": {
          "runAfter": {
            "Teams_Recipient": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "d1a1b0e7-3e9b-4c89-bd6d-dd179b632951"
          },
          "type": "OpenApiConnection",
          "inputs": {
            "host": {
              "connectionName": "shared_commondataserviceforapps_1",
              "operationId": "ListRecords",
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
            },
            "parameters": {
              "entityName": "msdyn_projects",
              "$select": "msdyn_projectid,msdyn_subject, sst_projectnumber",
