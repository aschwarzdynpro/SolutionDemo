                        "headers": {
                          "Content-Type": "application/json"
                        },
                        "body": "@triggerBody()['text_4']",
                        "authentication": {
                          "type": "ActiveDirectoryOAuth",
                          "tenant": "@triggerBody()['text_1']",
                          "audience": "@variables('strInlineFinOpsURL')",
                          "clientId": "@triggerBody()['text_2']",
                          "secret": "@triggerBody()['text_3']"
                        }
                      }
                    },
                    "Append_strResponseMsg_on_innererror": {
                      "runAfter": {
