// (Re-) Calculate Cost of Materials
// Function called by other functions 'calculateCostPrice'/'onChangeOverheadsurchargePercentage' from within this library
ETO.CalculationPositionForm.calculateCostOfMaterials = (formContext) => {
    var Quantity = formContext.getAttribute("hso_positionquantity").getValue();
    var CostPrice = formContext.getAttribute("hso_costprice").getValue();
    var CostPricePerUnit = formContext.getAttribute("hso_costpriceperunit").getValue();
    CostPricePerUnit = Number(CostPricePerUnit.toFixed(2));
    // check if Cost Price and Overhead Surcharge Percentage are set
    if (formContext.getAttribute("hso_costprice").getValue() != null && formContext.getAttribute("hso_costprice").getValue() != 0 && formContext.getAttribute("hso_overheadsurchargepercentage").getValue() != null && formContext.getAttribute("hso_overheadsurchargepercentage").getValue() != 0) {
        let OverheadSurchargePercentage = formContext.getAttribute("hso_overheadsurchargepercentage").getValue();
        // calculate Cost of Materials per Unit
        var calculatedCostOfMaterialsPerUnit = CostPricePerUnit * (1 + OverheadSurchargePercentage / 100);
    } else {
        // set Cost of Materials per Unit to Cost Price per Unit
        var calculatedCostOfMaterialsPerUnit = CostPricePerUnit;
    };
    // Set Cost of Materials per Unit
    calculatedCostOfMaterialsPerUnit = Number(calculatedCostOfMaterialsPerUnit.toFixed(2));
    formContext.getAttribute("hso_costofmaterialsperunit").setValue(calculatedCostOfMaterialsPerUnit);
    // calculate Cost of Materials
    let calculatedCostOfMaterials = calculatedCostOfMaterialsPerUnit * Quantity;
    calculatedCostOfMaterials = Number(calculatedCostOfMaterials.toFixed(2));
    formContext.getAttribute("hso_costofmaterials").setValue(calculatedCostOfMaterials);
    // calculate Overhead Surcharge
    let calculatedOverheadSurcharge = calculatedCostOfMaterials - CostPrice;
    formContext.getAttribute("hso_overheadsurcharge").setValue(calculatedOverheadSurcharge);
    // proceed with the calculation of the Sales Price
    ETO.CalculationPositionForm.calculateSalesPrice(formContext);
};

// (Re-) Calculate Sales Price
// Function called by other functions 'calculateCostOfMaterials'/'onChangeProfitsurchargePercentage' from within this library
ETO.CalculationPositionForm.calculateSalesPrice = (formContext) => {
    var Quantity = formContext.getAttribute("hso_positionquantity").getValue();
    var CostOfMaterials = formContext.getAttribute("hso_costofmaterials").getValue();
    var CostOfMaterialsPerUnit = formContext.getAttribute("hso_costofmaterialsperunit").getValue();
    CostOfMaterialsPerUnit = Number(CostOfMaterialsPerUnit.toFixed(2));
    // check if Cost of Materials and Profit Surcharge Percentage are set
    if (formContext.getAttribute("hso_costofmaterials").getValue() != null && formContext.getAttribute("hso_costofmaterials").getValue() != 0 && formContext.getAttribute("hso_profitsurchargepercentage").getValue() != null && formContext.getAttribute("hso_profitsurchargepercentage").getValue() != 0) {
        let ProfitSurchargePercentage = formContext.getAttribute("hso_profitsurchargepercentage").getValue();
        // calculate Sales Price per Unit
        var calculatedSalesPricePerUnit = CostOfMaterialsPerUnit * (1 + ProfitSurchargePercentage / 100);

    } else {
        // set calculated Sales Price per Unit to Cost of Materials per Unit
        var calculatedSalesPricePerUnit = CostOfMaterialsPerUnit;
    };
    // set Sales Price per Unit to the calculated value
    calculatedSalesPricePerUnit = Number(calculatedSalesPricePerUnit.toFixed(2));
    formContext.getAttribute("hso_salespriceperunit").setValue(calculatedSalesPricePerUnit);
    // calculate Sales Price
    let calculatedSalesPrice = calculatedSalesPricePerUnit * Quantity;
    calculatedSalesPrice = Number(calculatedSalesPrice.toFixed(2));
    formContext.getAttribute("hso_salesprice").setValue(calculatedSalesPrice);
    // calculate Profit Surcharge
    let calculatedProfitSurcharge = calculatedSalesPrice - CostOfMaterials;
    formContext.getAttribute("hso_profitsurcharge").setValue(calculatedProfitSurcharge);
    // calculate Contribution Margin Sales Price Percentage
    let calculatedContributionMarginSalesPricePercentage = calculatedProfitSurcharge / calculatedSalesPrice * 100;
    calculatedContributionMarginSalesPricePercentage = Number(calculatedContributionMarginSalesPricePercentage.toFixed(2));
    formContext.getAttribute("hso_contributionmargintargetsalespricepercent").setValue(calculatedContributionMarginSalesPricePercentage);
    // proceed with the calculation of the Quote Price
    ETO.CalculationPositionForm.calculateQuotePrice(formContext);
};

// (Re-) Calculate Quote Price
// Function called by other functions 'calculateSalesPrice'/'onChangeDiscountPercentage' from within this library
ETO.CalculationPositionForm.calculateQuotePrice = (formContext) => {
    var Quantity = formContext.getAttribute("hso_positionquantity").getValue();
    var SalesPrice = formContext.getAttribute("hso_salesprice").getValue();
    var SalesPricePerUnit = formContext.getAttribute("hso_salespriceperunit").getValue();
    SalesPricePerUnit = Number(SalesPricePerUnit.toFixed(2));
    var DiscountPercentage = formContext.getAttribute("hso_discountpercentage").getValue();
    var CostOfMaterials = formContext.getAttribute("hso_costofmaterials").getValue();
    CostOfMaterials = Number(CostOfMaterials.toFixed(2));
    let ProjectType = formContext.getAttribute("hso_projecttype").getValue();
    if (ProjectType == 100000000) {
        // if Project Type "Aufwand" then the Quoted Price is not calculated but retrieved from the Calculation Sales Price
        // get Quoted Price per Unit
        let QuotePricePerUnit = formContext.getAttribute("hso_quotedpriceperunit").getValue();
        // calculate Quoted Price
        let calculatedQuotePrice = Quantity * QuotePricePerUnit;
        calculatedQuotePrice = Number(calculatedQuotePrice.toFixed(2));
        formContext.getAttribute("hso_quotedprice").setValue(calculatedQuotePrice);
        // calculate Discount
        let calculatedDiscount = calculatedQuotePrice - SalesPrice;
        calculatedDiscount = Number(calculatedDiscount.toFixed(2));
        formContext.getAttribute("hso_discount").setValue(calculatedDiscount);
        // calculate Negotiation Surcharge Percentage
        let calculatedNegotiationSurchargePercentage = calculatedDiscount / SalesPrice * 100;
        calculatedNegotiationSurchargePercentage = Number(calculatedNegotiationSurchargePercentage.toFixed(2));
        formContext.getAttribute("hso_negotiationsurchargepercentage").setValue(calculatedNegotiationSurchargePercentage);
        // calculate Margin and Margin Percentage
        let calculatedMargin = calculatedQuotePrice - CostOfMaterials;
        calculatedMargin = Number(calculatedMargin.toFixed(2));
        formContext.getAttribute("hso_margin").setValue(calculatedMargin);
        if (calculatedMargin < 0) {
            formContext.getAttribute("hso_marginpercentage").setValue(0);
        } else {
            let calculateMarginPercentage = calculatedMargin / calculatedQuotePrice * 100;
            calculateMarginPercentage = Number(calculateMarginPercentage.toFixed(2));
            formContext.getAttribute("hso_marginpercentage").setValue(calculateMarginPercentage);
        };
    } else if (ProjectType != 100000000 && SalesPrice != null && SalesPrice != 0 && DiscountPercentage != null && DiscountPercentage != 0) {
        // calculate Quoted Price per Unit
        let calculatedQuotePricePerUnit = SalesPricePerUnit / (1 - (DiscountPercentage / 100));
        calculatedQuotePricePerUnit = Number(calculatedQuotePricePerUnit.toFixed(2));
        formContext.getAttribute("hso_quotedpriceperunit").setValue(calculatedQuotePricePerUnit);
        // calculate Quoted Price 
        let calculatedQuotePrice = calculatedQuotePricePerUnit * Quantity;
        calculatedQuotePrice = Number(calculatedQuotePrice.toFixed(2));
        formContext.getAttribute("hso_quotedprice").setValue(calculatedQuotePrice);
        // calculate Discount
        let calculatedDiscount = calculatedQuotePrice - SalesPrice;
        calculatedDiscount = Number(calculatedDiscount.toFixed(2));
        formContext.getAttribute("hso_discount").setValue(calculatedDiscount);
        // calculate Negotiation Surcharge Percentage
        let calculatedNegotiationSurchargePercentage = calculatedDiscount / SalesPrice * 100;
        calculatedNegotiationSurchargePercentage = Number(calculatedNegotiationSurchargePercentage.toFixed(2));
        formContext.getAttribute("hso_negotiationsurchargepercentage").setValue(calculatedNegotiationSurchargePercentage);
        // calculate Margin and Margin Percentage
        let calculatedMargin = calculatedQuotePrice - CostOfMaterials;
        calculatedMargin = Number(calculatedMargin.toFixed(2));
        formContext.getAttribute("hso_margin").setValue(calculatedMargin);
        if (calculatedMargin < 0) {
            formContext.getAttribute("hso_marginpercentage").setValue(0);
        } else {
            let calculateMarginPercentage = calculatedMargin / calculatedQuotePrice * 100;
            calculateMarginPercentage = Number(calculateMarginPercentage.toFixed(2));
            formContext.getAttribute("hso_marginpercentage").setValue(calculateMarginPercentage);
        };
    } else {
        // set calculated Discount to zero
        let calculatedDiscount = 0;
        formContext.getAttribute("hso_discount").setValue(calculatedDiscount);
        // set calculated Quote Price to Sales Price
        let calculatedQuotePrice = SalesPrice;
        formContext.getAttribute("hso_quotedprice").setValue(calculatedQuotePrice);
        // calculate Quoted Price per Unit
        let calculatedQuotePricePerUnit = calculatedQuotePrice / Quantity;
        formContext.getAttribute("hso_quotedpriceperunit").setValue(calculatedQuotePricePerUnit);
        // set Negotiation Surcharge Percentage to zero
        let calculatedNegotiationSurchargePercentage = 0;
        formContext.getAttribute("hso_negotiationsurchargepercentage").setValue(calculatedNegotiationSurchargePercentage);
        // set Margin and Margin Percentage to zero
        let calculatedMargin = 0;
        formContext.getAttribute("hso_margin").setValue(calculatedMargin);
        let calculateMarginPercentage = 0;
        formContext.getAttribute("hso_marginpercentage").setValue(calculateMarginPercentage);
    };

    console.log("saveForm = " + saveForm);
    if (saveForm == "true") {
        let FormType = formContext.ui.getFormType();
        if (FormType == 2) {// only when updating an already existing record
            formContext.data.save(1).then(
                result => {
                    console.log("Successfully Saved!");
                },
                error => {
                    alert("Failed while saving!");
                });
        };
        // Reset saveForm
        saveForm = "false";
    }

};

