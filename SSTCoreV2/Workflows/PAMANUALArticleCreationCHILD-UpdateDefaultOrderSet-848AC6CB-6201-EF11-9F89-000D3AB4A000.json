                    "value": "Default order settings updated for @{triggerBody()['text']}."
                  }
                },
                "Apply_to_each_company": {
                  "foreach": "@body('Fetch_companies_by_default_order_settings')?['value']",
                  "actions": {
                    "Update_Product_default_order_setting": {
                      "runAfter": {},
                      "metadata": {
