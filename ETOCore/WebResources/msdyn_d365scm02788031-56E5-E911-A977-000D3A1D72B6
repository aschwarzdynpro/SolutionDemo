function autoFillCategoryOnGlobalProduct(formContext, globalProductId) {
    var targetFieldInfoArr = getSalesProductCategoryTargetFieldInfoArr();
    if (globalProductId) {
		var salesHierarchyRoleId = "192350001";
        queryFilter = 
        "?$expand=msdyn_ProductCategory($expand=msdyn_Hierarchy($filter=(msdyn_msdyn_productcategoryhierarchy_msdyn_productcategoryhierarchyrole_Hierarchy/any(r:r/msdyn_hierarchyrole%20eq%20"
        + salesHierarchyRoleId
        + "))))&$select=msdyn_ProductCategory&$filter=_msdyn_globalproduct_value%20eq%20"
        + globalProductId;
		Xrm.WebApi.online.retrieveMultipleRecords("msdyn_productcategoryassignment", queryFilter)
			.then((result) => {
				var value = result["entities"];
				if (value && value.length > 0) {
					// run through the available entities until the end, or a success assignment
                    // The query above is meant to sort out categories that are not of type 'sales category',
                    // but it still returns unfitting categories - but without the msdyn_hierarchy field, so we filter on that
					for (var i = 0; i < value.length; i++) {
						if (autoFillTargetFieldsOnSourceRecordWithFirstFittingValue(formContext, value[i], targetFieldInfoArr)){
							break;
						}
					}
				}
				else {
					autoFillTargetFieldsNull(formContext, targetFieldInfoArr);
				}
			});
    }
    // if no global id, then empty the category field
    autoFillTargetFieldsNull(formContext, targetFieldInfoArr);
}

